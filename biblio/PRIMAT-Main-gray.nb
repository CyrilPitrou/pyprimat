 FontFamily->"Arial",ExpressionUUID->"c66a1a02-579f-4bf1-901a-0f44ab1816f3"],

Cell[BoxData[
 RowBox[{"LoadNEVOGrid", ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{"$NEVO", ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Not", "[", 
           RowBox[{"ValueQ", "[", "LinearGrid", "]"}], "]"}], "||", 
          "$RecomputeWeakRates"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"FileGrid", "=", 
           RowBox[{
           "$CSVDirectory", "<>", "\"\<NEVOGrid\>\"", "<>", "$FileSuffix", 
            "<>", "\"\<.csv\>\""}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"TableGrid", "=", 
           RowBox[{"Flatten", "@", 
            RowBox[{"SafeImport", "[", 
             RowBox[{"FileGrid", ",", "\"\<CSV\>\""}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"ymin", "=", 
           RowBox[{"First", "@", "TableGrid"}]}], ";", "\[IndentingNewLine]", 
          
          RowBox[{"ymax", " ", "=", 
           RowBox[{"Last", "@", "TableGrid"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"GS", "=", 
           RowBox[{"Length", "[", "TableGrid", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Ny", "=", "GS"}], ";", "\[IndentingNewLine]", 
          RowBox[{"LinearGrid", "=", 
           RowBox[{"DeleteDuplicates", "[", 
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"Table", "[", 
               RowBox[{"y", ",", 
                RowBox[{"{", 
                 RowBox[{"y", ",", "ymin", ",", "ymax", ",", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"ymax", "-", "ymin"}], ")"}], "/", 
                   RowBox[{"(", 
                    RowBox[{"Ny", "-", "1"}], ")"}]}]}], "}"}]}], "]"}], ",", 
              
              RowBox[{"{", "ymax", "}"}]}], "]"}], "]"}]}], ";"}]}], 
        "\[IndentingNewLine]", "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], 
    ";"}], "\[IndentingNewLine]", ")"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.934964216668354*^9, 3.934964236725067*^9}, {
   3.934964283890222*^9, 3.934964301095991*^9}, 3.934964468259618*^9, 
   3.934964575515979*^9, {3.934965585541032*^9, 3.934965586014164*^9}, {
   3.9349656168433857`*^9, 3.934965633420542*^9}, {3.936190284452739*^9, 
   3.936190289354086*^9}, {3.93635548939843*^9, 3.936355497229281*^9}, {
   3.936355591493734*^9, 3.936355617120707*^9}, {3.9363558190664797`*^9, 
   3.9363558204913683`*^9}, {3.936368716550338*^9, 3.9363687404834146`*^9}, {
   3.9363709830890913`*^9, 3.936371032166471*^9}, {3.93637107820711*^9, 
