Cell["\<\
We define a function which launches the Monte-Carlo on subKernels and \
collects the results. Note that if $RecomputeWeakRates=True this can be \
absurdely slow since weak rates will be computed all the time.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.699803693652607*^9, 3.699803710624123*^9}, 
   3.722687726669211*^9, {3.93719142177528*^9, 
   3.937191447558716*^9}},ExpressionUUID->"e2e3419d-887e-4191-ad21-\
7e4ad6cf5ecc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"RunPRIMATMonteCarlo", "[", "number_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "res", ",", "time", ",", "timref", ",", "Abundances", ",", 
        "mytabfunctions", ",", "sss", ",", "RandomVariables", ",", 
        "CosmoParametersList", ",", "oldbookrecomputeweakrates"}], "}"}], ",",
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{"$Verbose", ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{
           "\"\<Reaction file used is : \>\"", ",", "ChosenReactionFile"}], 
           "]"}], ";"}]}], "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"StringJoin", "@@", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"#", "<>", "\"\< \>\""}], "&"}], "/@", 
              RowBox[{
               RowBox[{"SafeImport", "[", "ChosenReactionFile", "]"}], "[", 
               RowBox[{"[", "1", "]"}], "]"}]}], ")"}]}], "]"}], ";"}], 
         "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"MyGrid", "[", 
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"{", 
                RowBox[{
                "\"\<Reaction Number\>\"", ",", "\"\<Reaction Name\>\"", ",", 
                 "\"\<Initial species\>\"", ",", "\"\<Final Species\>\"", 
                 ",", "\"\<Reference\>\""}], "}"}], "}"}], ",", 
              RowBox[{"PadLeftNumberRowFromZero", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Drop", "[", 
                  RowBox[{"#", ",", 
                   RowBox[{"{", "4", "}"}]}], "]"}], "&"}], "/@", 
                RowBox[{"(", 
                 RowBox[{
                 "NiceDisplayReaction", "/@", "ListReactionsUpToChosenMass"}],
                  ")"}]}], "]"}]}], "]"}], "]"}], "]"}], ";"}], "*)"}], 
        "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "We", " ", "deal", " ", "with", " ", "weak", " ", "rates", " ", 
         "first"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"oldbookrecomputeweakrates", "=", "$RecomputeWeakRates"}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Not", "@", 
           RowBox[{"FileExistsQ", "[", "NamePENFilenp", "]"}]}], "||", 
          RowBox[{"Not", "@", 
           RowBox[{"FileExistsQ", "[", "NamePENFilepn", "]"}]}], "||", 
          "$RecomputeWeakRates"}], ",", 
         RowBox[{"RunBackgroundThermo", ";", "ComputeWeakRates", ";"}]}], 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"$RecomputeWeakRates", "=", "False"}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"number", ">", "1"}], ",", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{
           "\"\<Running a Monte-Carlo with \>\"", ",", "number", ",", " ", 
            "\"\< points.\>\""}], "]"}], ";"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Off", "[", 
        RowBox[{"CompiledFunction", "::", "cfta"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"mytabfunctions", "=", 
        RowBox[{"If", "[", 
         RowBox[{"$ParallelBool", ",", "ParallelTable", ",", "Table"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
         "If", " ", "there", " ", "are", " ", "no", " ", "existing", " ", 
          "PEN", " ", "rates", " ", "on", " ", "hard", " ", "disk", " ", "we",
           " ", "compute", " ", "them", " ", "BEFORE", " ", "the", " ", 
          "MOnte"}], "-", 
         RowBox[{
         "Carlo", " ", "is", " ", "run", " ", "to", " ", "avoid", " ", "all", 
          " ", "subKernels", " ", "from", " ", "computing", " ", 
          RowBox[{"them", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{"$ParallelBool", ",", 
         RowBox[{"InitializeKernels", ";", "\[IndentingNewLine]", 
          RowBox[{"ParallelEvaluate", "[", 
           RowBox[{
            RowBox[{"$HistoryLength", "=", "0"}], ";"}], "]"}]}]}], "]"}], 
       ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "We", " ", "always", " ", "use", " ", "the", " ", "same", " ", "seed",
          " ", "so", " ", "that", " ", "we", " ", "always", " ", "use", " ", 
         "the", " ", "same", " ", "sequence", " ", "of", " ", "random", " ", 
         "number", " ", "as", " ", "advocated", " ", 
         RowBox[{
          RowBox[{"in", " ", "[", 
           RowBox[{"Cyburt", " ", "et", " ", 
            RowBox[{"al", ".", " ", "2015"}]}], "]"}], "."}]}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"timref", "=", 
        RowBox[{"AbsoluteTime", "[", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"res", "=", 
        RowBox[{"mytabfunctions", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"$Seed", ":=", "i"}], ";", 
           RowBox[{"(*", " ", 
            RowBox[{
            "We", " ", "use", " ", "a", " ", "different", " ", "seed", " ", 
             "so", " ", "that", " ", "for", " ", "each", " ", "MC", " ", 
             "point", " ", "we", " ", "have", " ", "a", " ", "different", " ",
              "sequence", " ", "of", " ", "reaction", " ", "rates"}], " ", 
            "*)"}], "\[IndentingNewLine]", 
           RowBox[{"InitializeRandom", "[", "$Seed", "]"}], ";", 
           RowBox[{"(*", " ", 
            RowBox[{
            "We", " ", "restart", " ", "our", " ", "random", " ", "list", " ",
              "from", " ", "the", " ", "beginning"}], " ", "*)"}], 
           "\[IndentingNewLine]", "\[IndentingNewLine]", 
           RowBox[{"h2\[CapitalOmega]b0", "=", 
            RowBox[{"Meanh2\[CapitalOmega]b0", "+", 
             RowBox[{"If", "[", 
              RowBox[{"$Randomh2\[CapitalOmega]b", ",", 
               RowBox[{
               "\[Sigma]h2\[CapitalOmega]b0", " ", "NormalRealisation"}], ",",
                "0"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"\[Tau]neutron", "=", 
            RowBox[{"Mean\[Tau]neutron", "+", 
             RowBox[{"If", "[", 
              RowBox[{"$Random\[Tau]neutron", ",", 
               RowBox[{"\[Sigma]\[Tau]neutron", " ", "NormalRealisation"}], 
               ",", "0"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"CosmoParametersList", "=", 
            RowBox[{"{", 
             RowBox[{"h2\[CapitalOmega]b0", ",", "\[Tau]neutron"}], "}"}]}], 
           ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
           RowBox[{"time", "=", 
            RowBox[{
             RowBox[{"AbsoluteTiming", "[", "RunNumericalIntegrals", "]"}], 
             "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"RandomVariables", "=", 
            RowBox[{"Rest", "@", 
             RowBox[{"ListReactionsUpToChosenMass", "[", 
              RowBox[{"[", 
               RowBox[{"All", ",", "4"}], "]"}], "]"}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"Share", "[", "]"}], ";"}], "*)"}], 
           "\[IndentingNewLine]", 
           RowBox[{"Print", "[", 
            RowBox[{
            "\"\<Iteration \>\"", ",", "i", ",", " ", 
             "\"\<  Memory usage = \>\"", ",", 
             RowBox[{"MemoryInUse", "[", "]"}], ",", "\"\< time = \>\"", ",", 
             "time", ",", " ", "\"\<  Kernel : \>\"", ",", "$KernelID"}], 
            "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"Abundances", "=", 
            RowBox[{
             RowBox[{"YPeriodTime", "[", "\"\<LT\>\"", "]"}], "[", "tend", 
             "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"ClearSystemCache", "[", "]"}], ";"}], "*)"}], 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{"$Verbose", ",", 
             RowBox[{"Print", "[", "Abundances", 
              RowBox[{"(*", 
               RowBox[{",", "\"\< \>\"", ",", "RandomVariables"}], "*)"}], 
              "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"{", 
            RowBox[{
            "Abundances", ",", "RandomVariables", ",", 
             "CosmoParametersList"}], "}"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "number"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{"$ParallelBool", ",", 
         RowBox[{"CloseKernels", "[", "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Share", "[", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"ClearSystemCache", "[", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Time in the MC for that cosmology was \>\"", ",", 
         RowBox[{
          RowBox[{"AbsoluteTime", "[", "]"}], "-", "timref"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"h2\[CapitalOmega]b0", "=", "Meanh2\[CapitalOmega]b0"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[Tau]neutron", "=", "Mean\[Tau]neutron"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"MC", "=", 
        RowBox[{"res", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"RV", "=", 
        RowBox[{"res", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Cosmo", "=", 
        RowBox[{"res", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "3"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"$RecomputeWeakRates", "=", "oldbookrecomputeweakrates"}], ";",
        "\[IndentingNewLine]", "\[IndentingNewLine]", "res"}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RunPRIMAT", ":=", 
   RowBox[{"RunPRIMATMonteCarlo", "[", "1", "]"}]}], ";"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{
  3.936295460586651*^9, {3.936295510549679*^9, 3.936295522309157*^9}, {
   3.936331962797372*^9, 3.9363319669987307`*^9}, {3.936495792260079*^9, 
   3.9364958183002996`*^9}, {3.9365109323402567`*^9, 3.936510934226712*^9}, {
   3.936525639588331*^9, 3.936525745988982*^9}, {3.9365258671778383`*^9, 
   3.936525879200491*^9}, {3.93652850772192*^9, 3.936528520952898*^9}, {
   3.936528553798377*^9, 3.936528566061288*^9}, {3.9365296418149*^9, 
   3.9365296560096416`*^9}, {3.936529761565497*^9, 3.9365297620899076`*^9}, {
   3.936529809911756*^9, 3.936529852566345*^9}, {3.936970711310774*^9, 
   3.936970714767671*^9}, {3.936971052064313*^9, 3.936971122236293*^9}, {
   3.936971304260372*^9, 3.93697134889639*^9}, {3.936971470253285*^9, 
   3.936971470695888*^9}, {3.937191220370757*^9, 3.937191235375807*^9}, {
   3.937191353727333*^9, 3.9371914159568787`*^9}, {3.937191452568557*^9, 
   3.9371915471884527`*^9}, 3.937191720749629*^9, {3.937191813762355*^9, 
   3.937191814755485*^9}, {3.937272869188519*^9, 3.937272886777607*^9}},
 CellLabel->
  "In[2589]:=",ExpressionUUID->"64997192-9ea3-4cf5-8341-255cecbdcb6d"],

Cell["\<\
The results of RunPRIMAT are gathered in the files MC (abundances) RV (rates \
variations) Cosmo (List of cosmological parameters, limited to baryons \
abundances and neutron lifetime)\
\>", "Text",
 CellChangeTimes->{{3.7226878213161993`*^9, 3.722687886209819*^9}, 
   3.722698611505405*^9, 3.725263178319779*^9, 
   3.809771817279756*^9},ExpressionUUID->"095e8f97-a5d0-450c-8083-\
a8c93d9eb231"],

Cell["\<\
We define functions to dump the results of a Monte-Carlo in a file and also \
the converse to load the result so as to analyze and use it.\
\>", "Text",ExpressionUUID->"e9612649-c510-4bb9-ab0c-c1360d079832"],

Cell[BoxData[
 RowBox[{"Clear", "[", 
  RowBox[{"LoadMC", ",", "DumpMC"}], "]"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.720344641965357*^9, 3.720344645338798*^9}},
 CellLabel->
  "In[2591]:=",ExpressionUUID->"6481ea29-13d3-4f51-8507-846d43f68016"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"DumpMC", "[", "File_String", "]"}], ":=", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Exporting \>\"", ",", 
        RowBox[{"\"\<Results/MC\>\"", "<>", "File", "<>", "\"\<.dat\>\""}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Export", "[", 
       RowBox[{
        RowBox[{
        "$ResultsDirectory", "<>", "\"\<MC\>\"", "<>", "File", "<>", 
         "\"\<.dat\>\""}], ",", "MC"}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Exporting \>\"", ",", 
        RowBox[{"\"\<Results/MC\>\"", "<>", "File", "<>", "\"\<.mx\>\""}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"DumpSave", "[", 
       RowBox[{
        RowBox[{
        "$ResultsDirectory", "<>", "\"\<MC\>\"", "<>", "File", "<>", 
         "\"\<.mx\>\""}], ",", "MC"}], "]"}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Exporting \>\"", ",", 
        RowBox[{"\"\<Results/RV\>\"", "<>", "File", "<>", "\"\<.dat\>\""}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Export", "[", 
       RowBox[{
        RowBox[{
        "$ResultsDirectory", "<>", "\"\<RV\>\"", "<>", "File", "<>", 
         "\"\<.dat\>\""}], ",", "RV"}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Exporting \>\"", ",", 
        RowBox[{"\"\<Results/RV\>\"", "<>", "File", "<>", "\"\<.mx\>\""}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"DumpSave", "[", 
       RowBox[{
        RowBox[{
        "$ResultsDirectory", "<>", "\"\<RV\>\"", "<>", "File", "<>", 
         "\"\<.mx\>\""}], ",", "RV"}], "]"}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Exporting \>\"", ",", 
        RowBox[{
        "\"\<Results/Cosmo\>\"", "<>", "File", "<>", "\"\<.dat\>\""}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Export", "[", 
       RowBox[{
        RowBox[{
        "$ResultsDirectory", "<>", "\"\<Cosmo\>\"", "<>", "File", "<>", 
         "\"\<.dat\>\""}], ",", "Cosmo"}], "]"}], ";"}], 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"DumpSave", "[", 
        RowBox[{
         RowBox[{"\"\<Results/Cosmo\>\"", "<>", "File", "<>", "\"\<.mx\>\""}],
          ",", "Cosmo"}], "]"}], ";"}], "*)"}], "\[IndentingNewLine]", 
     ")"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"LoadMC", "[", "File_String", "]"}], ":=", 
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Get", "[", 
      RowBox[{
      "$ResultsDirectory", "<>", "\"\<MC\>\"", "<>", "File", "<>", 
       "\"\<.mx\>\""}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"MCfile", "=", 
        RowBox[{"\"\<Results/MC\>\"", "<>", "File", "<>", "\"\<.dat\>\""}]}], 
       ";", "\[IndentingNewLine]", " ", 
       RowBox[{"MC", "=", 
        RowBox[{"Import", "[", "MCfile", "]"}]}], ";"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"Get", "[", 
      RowBox[{
      "$ResultsDirectory", "<>", "\"\<RV\>\"", "<>", "File", "<>", 
       "\"\<.mx\>\""}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"RVfile", "=", 
        RowBox[{"\"\<Results/RV\>\"", "<>", "File", "<>", "\"\<.dat\>\""}]}], 
