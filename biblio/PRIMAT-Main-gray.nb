c415212a8f81"],

Cell[BoxData[{
 RowBox[{"If", "[", 
  RowBox[{"$PaperPlots", ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Tab\[Delta]\[Lambda]FMnTOp", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
