Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"zT", "[", "T_", "]"}], ":=", 
   FractionBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", "[", "T", "]"}], "T"}], ")"}], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", "[", "Ti", "]"}], "Ti"}], ")"}]]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"znuT", "[", "T_", "]"}], ":=", 
   FractionBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", "[", "T", "]"}], 
      RowBox[{"T\[Nu]overT", "[", "T", "]"}], " ", "T"}], ")"}], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", "[", "Ti", "]"}], 
      RowBox[{"T\[Nu]overT", "[", "Ti", "]"}], " ", "Ti"}], ")"}]]}], 
  ";"}]}], "Input",
