Cell["\<\
Analytic expression for Fermi - Dirac distributions : number and energy \
densities. We hard code them below to save time.\
\>", "Text",
 CellChangeTimes->{{3.936188488322072*^9, 3.936188508798431*^9}, {
  3.936188743909072*^9, 3.936188775995955*^9}, {3.9372746714153976`*^9, 
  3.9372746716888638`*^9}},ExpressionUUID->"6a90ea12-0772-4be2-a585-\
4684a958c6a9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"\[Rho]FD", "[", "c_", "]"}], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"2", 
       SuperscriptBox["\[Pi]", "2"]}]], 
     RowBox[{
      SubsuperscriptBox["\[Integral]", "0", "Infinity"], 
      RowBox[{
       FractionBox[
        SuperscriptBox["y", "3"], 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"y", "-", "c"}]], "+", "1"}], ")"}]], 
       RowBox[{"\[DifferentialD]", "y"}]}]}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"nFD", "[", "c_", "]"}], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"2", 
       SuperscriptBox["\[Pi]", "2"]}]], 
     RowBox[{
      SubsuperscriptBox["\[Integral]", "0", "Infinity"], 
      RowBox[{
       FractionBox[
        SuperscriptBox["y", "2"], 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"y", "-", "c"}]], "+", "1"}], ")"}]], 
       RowBox[{"\[DifferentialD]", "y"}]}]}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"\[Rho]FD", "[", "0", "]"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Simplify", "@", 
    RowBox[{"Normal", "@", 
     RowBox[{"Series", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Rho]FD", "[", "c", "]"}], "+", 
        RowBox[{"\[Rho]FD", "[", 
         RowBox[{"-", "c"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"c", ",", "0", ",", "10"}], "}"}]}], "]"}]}]}], 
   "*)"}]}]], "Input",
 CellChangeTimes->{{3.719810734101269*^9, 3.7198107471472273`*^9}, {
  3.719810815158649*^9, 3.71981082002866*^9}, {3.719811098574154*^9, 
  3.71981129102695*^9}, {3.719814610298039*^9, 3.719814614720055*^9}, {
  3.719814801540749*^9, 3.719814803102343*^9}, {3.93618851424035*^9, 
  3.936188584051502*^9}, {3.93618866176676*^9, 3.936188662120618*^9}, {
  3.936188697801846*^9, 3.93618871685896*^9}},
 CellLabel->
  "In[1833]:=",ExpressionUUID->"9aba7bb8-273c-44f9-888c-6b2fdd096e80"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Eta]\[Nu]", "[", "c_", "]"}], "=", 
     FractionBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"nFD", "[", "c", "]"}], "-", 
        RowBox[{"nFD", "[", 
         RowBox[{"-", "c"}], "]"}]}], ")"}], 
      RowBox[{"(", 
       RowBox[{"2", 
        RowBox[{
         RowBox[{"Zeta", "[", "3", "]"}], "/", 
         RowBox[{"\[Pi]", "^", "2"}]}]}], ")"}]]}], ";"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Series", "[", 
     RowBox[{
      RowBox[{"\[Eta]\[Nu]", "[", "c", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"c", ",", "0", ",", "3"}], "}"}]}], "]"}], ";"}], 
   "*)"}]}]], "Input",
 CellChangeTimes->{{3.719814504607613*^9, 3.719814521303194*^9}, {
   3.719814580948283*^9, 3.719814586509248*^9}, {3.719814621290133*^9, 
   3.719814654938307*^9}, 3.719815891598236*^9, {3.722691651949795*^9, 
   3.722691657571014*^9}, {3.936188692862177*^9, 3.936188726060939*^9}},
 CellLabel->
  "In[1834]:=",ExpressionUUID->"9c6fc28b-e57d-4306-8c03-a9f73728c1ef"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Rho]FDNonDegenerate", "=", 
   FractionBox[
    RowBox[{"7", " ", 
     SuperscriptBox["\[Pi]", "2"]}], "240"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Total\[Rho]FD", "[", "c_", "]"}], "=", 
   RowBox[{
    FractionBox[
     SuperscriptBox["c", "2"], "4"], "+", 
    FractionBox[
     SuperscriptBox["c", "4"], 
     RowBox[{"8", " ", 
      SuperscriptBox["\[Pi]", "2"]}]], "+", 
    FractionBox[
     RowBox[{"7", " ", 
      SuperscriptBox["\[Pi]", "2"]}], "120"]}]}], 
  ";"}], "\[IndentingNewLine]"}], "Input",
 InitializationCell->True,
