   3.8532287206329403`*^9}, 3.935049188380743*^9, {3.9350493300558167`*^9, 
   3.9350493304660797`*^9}, {3.935049508349324*^9, 3.935049511951804*^9}, {
   3.935108837784831*^9, 3.93510884030479*^9}, {3.9351253083207893`*^9, 
   3.935125319717774*^9}, {3.936901237351651*^9, 3.936901242774785*^9}, {
   3.936901407565106*^9, 3.9369014106604023`*^9}},
 CellLabel->
  "In[1793]:=",ExpressionUUID->"87cac1a8-954a-4d5c-ac10-d92706906a11"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Spectral distortions", "Subsubsection",
 CellChangeTimes->{{3.9349585834081793`*^9, 
  3.934958592648448*^9}},ExpressionUUID->"81883b1c-3353-4c03-8a45-\
88b5e57db759"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"$SpectralDistortions", " ", "=", " ", "True"}], ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{"Recommended", " ", "True"}], " ", "*)"}], " "}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9349586266270227`*^9, 3.934958651206327*^9}, 
   3.9361642343784733`*^9, {3.936164274003263*^9, 3.936164274006312*^9}},
 CellLabel->
  "In[1796]:=",ExpressionUUID->"a331f3ab-6c99-4f71-a21f-c828ca6dd86f"],

Cell[TextData[{
 "If $SpectralDistortions = True then spectral distortions are added to \
electronic neutrinos (and also all other flavours but this could be changed)\n\
\n",
 StyleBox["1) $NEVO distortions",
  FontWeight->"Bold"],
 "\nIf $IncompleteNeutrinoDecoupling = True and $NEVO=$TrueT\[Nu]e=True, then \
it is advised to also ask for $SpectralDistortions since they were computed \
in the decoupling code NEVO. They are then used if $AnalyticDistortions=False \
below and superseded otherwise. In the case NEVO distortions are used, they \
induce no change of neutrino energy density since in that case distortions \
are defined with respect to a reference spectrum in such a way that there is \
no energy density contained in the distortions (of both neutrino and \
antineutrino)."
}], "Text",
 CellChangeTimes->{{3.934958836453772*^9, 3.934958944828168*^9}, {
   3.93495898049043*^9, 3.934959116502496*^9}, {3.9349601236433*^9, 
   3.93496016976295*^9}, {3.934960200948889*^9, 3.934960201937944*^9}, {
   3.9349602764791403`*^9, 3.9349603342589397`*^9}, {3.934960507003312*^9, 
   3.934960535407981*^9}, {3.9349606389108686`*^9, 3.9349606628936157`*^9}, {
   3.935104553546282*^9, 3.935104653387372*^9}, {3.93512532635079*^9, 
   3.935125345235951*^9}, {3.935567884278405*^9, 3.93556788453069*^9}, {
   3.935567932150331*^9, 3.935567946062463*^9}, 
   3.935574584689624*^9},ExpressionUUID->"d8a59167-244a-455b-9294-\
9d60e0d29086"],

Cell[TextData[{
 StyleBox["2)",
  FontWeight->"Bold"],
 " The user can define ",
 StyleBox["custom distortions",
  FontWeight->"Bold"],
 " (which are the same in neutrinos and antineutrinos) with analytic forms by \
setting $AnalyticDistortions=True.\n It is slightly inconsistent because \
these would impact the neutrino decoupling. Hence the most consistent set of \
parameters consists in setting $IncompleteNeutrinoDecoupling=False, so they \
can be viewed as distortion which are added after decoupling but before \
neutron/proton freeze out.\nIf $AnalyticDistortions = True, then an analytic \
form of the distortions is used. The user can modify the code to define \
custom distortions inside the code itself.\nFor the moment the same \
distortion shape is put in all neutrino flavors. Also only the electronic \
neutrino distortion affects the weak-interaction, but the fact that we put \
the distortion in all flavors has an impact on the energy density contained \
in the distortion.\n\nTwo basic analytic forms are however readily provided  \
:\n\n  ",
 StyleBox["a) A \[Mu]-type distortion",
  FontVariations->{"Underline"->True}],
 ", corresponding to the difference between a Fermi-Dirac spectrum with a \
given chemical potential with and a Fermi-Dirac spectrum with a reference \
chemical potential. \n  If $DegenerateNeutrinos=True above, then the chemical \
potential of the reference neutrino spectrum is with a non-vanishing chemical \
potential \[Xi]\[Nu]=\[Mu]OverT\[Nu] (and otherwise \[Xi]\[Nu]=0), that is ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"1", " "}], 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"y", "-", "\[Xi]\[Nu]"}]], "+", "1"}]], TraditionalForm]],
  ExpressionUUID->"b4f216cf-da2a-4509-8163-52d324d87e09"],
 " for neutrinos and  ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"1", " "}], 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"y", "-", "\[Xi]\[Nu]"}]], "+", "1"}]], TraditionalForm]],
  ExpressionUUID->"0cd6a354-7764-4bdb-887d-f1ee8aab6c17"],
 " for antineutrinos (with y = ",
 Cell[BoxData[
  FormBox[
   RowBox[{"E", "/", 
    SubscriptBox["T", "\[Nu]"]}], TraditionalForm]],ExpressionUUID->
  "f05b0ba9-c5e4-4cca-80c1-8b7421ff3cf5"],
 "). Then the \[Mu]-type distortion, corresponds to a Fermi-Dirac spectrum \
with \[Xi]\[Nu] + \[CapitalDelta]\[Xi]\[Nu]. Hence the distortion for \
neutrinos is defined by ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"1", " "}], 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"y", "-", 
       RowBox[{"(", 
        RowBox[{"\[Xi]\[Nu]", "+", "\[CapitalDelta]\[Xi]\[Nu]"}], ")"}]}]], 
     "+", "1"}]], TraditionalForm]],ExpressionUUID->
  "81b78572-283d-47d4-a0c3-1c2beb22e7fd"],
 " - ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"1", " "}], 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"y", "-", "\[Xi]\[Nu]"}]], "+", "1"}]], TraditionalForm]],
  ExpressionUUID->"64cbb3fc-4af7-49f9-8de2-e33ef400b819"],
 " and for antineutrinos it is ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"1", " "}], 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"y", "+", 
       RowBox[{"(", 
        RowBox[{"\[Xi]\[Nu]", "+", "\[CapitalDelta]\[Xi]\[Nu]"}], ")"}]}]], 
     "+", "1"}]], TraditionalForm]],ExpressionUUID->
  "23f16843-1365-4f9c-bc46-dd1643c07b7a"],
 " - ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"1", " "}], 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"y", "+", "\[Xi]\[Nu]"}]], "+", "1"}]], TraditionalForm]],
  ExpressionUUID->"a90c30e1-aa22-440a-be82-b0c1af8904ec"],
 ". It is ill-considered to use this kind of distortion, because whatever the \
chemical potential, it can be put in the reference chemical potential. Hence \
this usage is only meant to test the code, for instance checking that having \
\[Mu]OverT\[Nu]=Somevalue and \[CapitalDelta]\[Xi]\[Nu]=0 is equivalent to \
\[Mu]OverT\[Nu]=0 and \[CapitalDelta]\[Xi]\[Nu] = somevalue.\n  \n  ",
 StyleBox["b) A Y-type distortion",
  FontVariations->{"Underline"->True}],
 " corresponding to the equivalent of the SZ (Sunyaev-Zeldovich) distortion, \
that is corresponding to the spectrum shaped by the Kompaneets equation \
(Kompaneets 1957, Soviet Phys JETP, Vol. 4 N. 5 p 730) but with an \
up-scattered Fermi-Dirac distribution (instead of an up-scattered Planck \
spectrum as for the SZ effect on photons of the CMB).\n  The collision term \
of the Kompaneets equation is of the form ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"1", " "}], 
    SuperscriptBox["E", "2"]], TraditionalForm]],ExpressionUUID->
  "9e254b1d-7173-4ed6-b27e-616813c9fa4e"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "E"], 
    RowBox[{"(", 
     SuperscriptBox["E", "4"]}]}], TraditionalForm]],ExpressionUUID->
  "e92c0421-af59-4328-9848-60477d0885b4"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "E"], "f"}], TraditionalForm]],ExpressionUUID->
  "ca2494b6-7b46-493b-9014-4a3222564f73"],
 ") where f is the reference spectrum  (Fermi-Dirac with or without chemical \
potential depending on $DegenerateNeutrinos option and \[Mu]OverT\[Nu] \
value). \n  Hence the distortion is of the form ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Y", "SZ"], TraditionalForm]],ExpressionUUID->
  "8cf86bde-0ee2-4e58-bb83-b1350faf2489"],
 "*",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"1", " "}], 
    SuperscriptBox["E", "2"]], TraditionalForm]],ExpressionUUID->
  "877aab46-0086-4381-a21b-ac78d9df123e"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "E"], 
    RowBox[{"(", 
     SuperscriptBox["E", "4"]}]}], TraditionalForm]],ExpressionUUID->
  "506d42d0-306c-48c9-b3dd-310f2f7dbd8f"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[PartialD]", "E"], TraditionalForm]],ExpressionUUID->
  "aa63a1ce-2da6-4e26-a437-75d593c85f51"],
 " ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"1", " "}], 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"y", "-", "\[Xi]\[Nu]"}]], "+", "1"}]], TraditionalForm]],
  ExpressionUUID->"6c201673-cf5d-46d5-bde9-f84c8c06eea2"],
 " ) for neutrinos and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Y", "SZ"], "*", 
    FractionBox[
     RowBox[{"1", " "}], 
     SuperscriptBox["E", "2"]]}], TraditionalForm]],ExpressionUUID->
  "1fff51b7-847a-473c-afcd-43186c723998"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "E"], 
    RowBox[{"(", 
     SuperscriptBox["E", "4"]}]}], TraditionalForm]],ExpressionUUID->
  "d229b733-eed7-42a8-a145-0ee044098500"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[PartialD]", "E"], TraditionalForm]],ExpressionUUID->
  "85942d0e-e7ab-4939-ba7a-0f783f126b83"],
 " ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"1", " "}], 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"y", "+", "\[Xi]\[Nu]"}]], "+", "1"}]], TraditionalForm]],
  ExpressionUUID->"888391ed-f437-4bfe-aee5-67f251f7b5bb"],
 " ). ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Y", "SZ"], TraditionalForm]],ExpressionUUID->
  "c04d98aa-7d02-4227-94f9-cc030ff2a4d5"],
 " is the amount of up-scattering and is proportional to the optical depth \
multiplied by (Ts/ms) where Ts and ms are temperature and mass of the heavy \
species which is responsible for the up-scattering. The total energy density \
in neutrinos is then modified to be \[Rho]\[Nu](1 + 4 ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Y", "SZ"], TraditionalForm]],ExpressionUUID->
  "2d053c8d-8601-4aca-8bfd-f892ccf43a48"],
 ") where \[Rho]\[Nu] is the energy density without the SZ distortion.\n  \n  \
Note that the true Kompaneets equation must be a stationary point if the \
species responsible for the up-scattering is at the same temperature ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["T", "s"], TraditionalForm]],ExpressionUUID->
  "5e28c23a-fc76-4234-9869-02747f36bfbf"],
 " as the scattered species. Hence the total rate per optical depth is\
\[LineSeparator]\t\t",
 Cell[BoxData[
  FormBox[
   FractionBox["df", "d\[Tau]"], TraditionalForm]],ExpressionUUID->
  "0dc9fa91-6131-4472-9f78-65ec6e0f8c6e"],
 "=",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"1", " "}], 
    RowBox[{
     SubscriptBox["m", "s"], 
     SuperscriptBox["E", "2"]}]], TraditionalForm]],ExpressionUUID->
  "03fa7d05-cc30-4564-86ab-b795600f5dac"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "E"], 
    RowBox[{"[", 
     SuperscriptBox["E", "4"]}]}], TraditionalForm]],ExpressionUUID->
  "07756b23-3aae-4a0b-953a-23bac22c528b"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    SubscriptBox["T", "s"]}], TraditionalForm]],ExpressionUUID->
  "4473d0e7-f898-442a-9b5d-e7d0eb37581d"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", "E"], "f"}], " ", "+", " ", 
    RowBox[{"f", "(", 
     RowBox[{"1", "-", "f"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "46d480a4-edd1-40ae-b2f1-8dfa9f28617a"],
 ")]  (note the change of sign with respect to a Kompaneets equation for \
bosons=photons where we have f(1+f) since for fermions we have Pauli-blocking \
instead of stimulated emission for bosons), and if f is initially a \
Fermi-Dirac distribution at temperature ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["T", "\[Nu]"], TraditionalForm]],ExpressionUUID->
  "189f12f4-b41d-4c51-9c11-f992a8366482"],
 " (with whatever chemical potential), then in the low scattering \
approximation (Born approximation)  f(1-f) = - ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["T", "\[Nu]"], TraditionalForm]],ExpressionUUID->
  "087f804a-4d04-4014-a268-ab410f1c70ed"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "E"], "f"}], TraditionalForm]],ExpressionUUID->
  "87af49ad-0334-4677-8c44-ed4cdcb0f0a1"],
 " hence the Kompaneets equation is in the form\n    ",
 Cell[BoxData[
  FormBox[
   FractionBox["df", "d\[Tau]"], TraditionalForm]],ExpressionUUID->
  "2cee4d4b-31d8-4a53-8708-cd70e36a7b27"],
 " ~",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["T", "s"], "-", 
      SubscriptBox["T", "\[Vee]"]}], ")"}], 
    SubscriptBox["m", "s"]], TraditionalForm]],ExpressionUUID->
  "7974df3d-0c76-4c0e-8b83-23a9fa1ce7c7"],
 " ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"1", " "}], 
    SuperscriptBox["E", "2"]], TraditionalForm]],ExpressionUUID->
  "c13bb2c1-f0ef-4959-b422-8db7b675f5df"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "E"], 
    RowBox[{"(", 
     SuperscriptBox["E", "4"]}]}], TraditionalForm]],ExpressionUUID->
  "ccdaa980-7ca8-41f0-9609-e72d33457e8f"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "E"], "f"}], TraditionalForm]],ExpressionUUID->
  "800aee11-47f3-4516-8af8-0484d64cc3f4"],
 ")   which implies that the distorted spectrum is approximately ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "-", 
    SubscriptBox["f", "FD"]}], TraditionalForm]],ExpressionUUID->
  "ea94290a-f065-43ca-85f6-b875a6ac11f2"],
 " =   ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Y", "SZ"], TraditionalForm]],ExpressionUUID->
  "8be0f548-6389-4cc4-8358-4bef0820f21b"],
 " ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"1", " "}], 
    SuperscriptBox["E", "2"]], TraditionalForm]],ExpressionUUID->
  "8783fdf6-fd53-4f2b-b80a-80a8e55f06b6"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "E"], 
    RowBox[{"(", 
     SuperscriptBox["E", "4"]}]}], TraditionalForm]],ExpressionUUID->
  "85c6b0bc-44f9-4975-b79d-4cb1617bbdde"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "E"], 
    SubscriptBox["f", "FD"]}], TraditionalForm]],ExpressionUUID->
  "899aee2f-3eb4-4ff9-8286-10ecbd4e385d"],
 ")  with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Y", "SZ"], TraditionalForm]],ExpressionUUID->
  "0650a9ad-e6ff-47e7-8df6-995797acbe36"],
 " = \[Tau]*",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["T", "s"], "-", 
      SubscriptBox["T", "\[Vee]"]}], ")"}], 
    SubscriptBox["m", "s"]], TraditionalForm]],ExpressionUUID->
  "f0f1d70d-6443-434b-9334-5656327ffb4d"],
 "."
}], "Text",
 CellChangeTimes->{{3.934958836453772*^9, 3.934958944828168*^9}, {
   3.93495898049043*^9, 3.934959116502496*^9}, {3.9349601236433*^9, 
   3.93496016976295*^9}, {3.934960200948889*^9, 3.934960201937944*^9}, {
   3.9349602764791403`*^9, 3.9349603342589397`*^9}, {3.934960551877527*^9, 
   3.934960617791566*^9}, {3.9351046676105757`*^9, 3.935104957251226*^9}, {
   3.9351049928656597`*^9, 3.935105088798341*^9}, {3.935105124027028*^9, 
   3.935105315272311*^9}, {3.9351053606321363`*^9, 3.9351054989349194`*^9}, {
   3.935105543729474*^9, 3.935105734939267*^9}, {3.9351058158821707`*^9, 
   3.9351062396390963`*^9}, {3.93510633381761*^9, 3.935106426610394*^9}, {
   3.93510648508484*^9, 3.935106499651602*^9}, {3.935114465217762*^9, 
   3.935114480570006*^9}, {3.935114577773529*^9, 3.935114721185417*^9}, {
   3.935114753736579*^9, 3.935114896313867*^9}, {3.935114939654108*^9, 
   3.9351151232091*^9}, 3.9351152682207127`*^9, {3.935116838238639*^9, 
   3.9351169689432096`*^9}, {3.935117067215535*^9, 3.9351170676085463`*^9}, {
   3.935567905289917*^9, 3.935567905531022*^9}, {3.9355679791839733`*^9, 
   3.935567984038039*^9}, {3.93556803622412*^9, 3.935568059987361*^9}, {
   3.935568155886408*^9, 3.935568232628367*^9}, {3.937274231713435*^9, 
   3.937274232912982*^9}, {3.937274265490967*^9, 3.937274276630128*^9}, {
   3.9372743202867117`*^9, 
   3.937274387876286*^9}},ExpressionUUID->"ab7b4be9-b556-428e-8ef7-\
c486ade27062"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"$AnalyticDistortions", " ", "=", " ", "False"}], ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{"Recommended", " ", 
    RowBox[{"False", ".", " ", "Only"}], " ", "for", " ", "experimental", " ",
     "investigation", " ", "of", " ", "neutrino", " ", 
    RowBox[{"distortions", "."}]}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalDelta]\[Xi]\[Nu]", "=", "0."}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"YSZ", "=", 
   RowBox[{"-", "0.1"}]}], ";"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.934960509585874*^9, 3.9349605180389137`*^9}, {
   3.9349605652581797`*^9, 3.934960565367208*^9}, {3.934964078903552*^9, 
   3.93496410218466*^9}, {3.935035278624117*^9, 3.935035279138665*^9}, {
   3.935039048566246*^9, 3.9350390491927977`*^9}, {3.935039233441308*^9, 
   3.935039233930318*^9}, {3.935049185156089*^9, 3.9350491857602987`*^9}, {
   3.935049504579124*^9, 3.93504950506949*^9}, {3.9351045176696653`*^9, 
   3.93510453865571*^9}, {3.935105189712318*^9, 3.9351051901394997`*^9}, {
   3.9351052614664783`*^9, 3.9351052621021223`*^9}, {3.935106001632679*^9, 
   3.935106002351879*^9}, {3.935106376724381*^9, 3.9351063819667873`*^9}, {
   3.935106530926674*^9, 3.9351065310107327`*^9}, {3.935108700491601*^9, 
   3.935108727039711*^9}, {3.935115473667647*^9, 3.935115473831222*^9}, {
   3.935115661985092*^9, 3.935115662142171*^9}, 3.935116119615991*^9, {
   3.935116153944372*^9, 3.935116156601638*^9}, {3.935116340535088*^9, 
   3.9351163660589943`*^9}, {3.935116800273435*^9, 3.935116800729765*^9}, {
   3.935117012978222*^9, 3.935117137883424*^9}, 3.9351171823311357`*^9, {
   3.935118527003799*^9, 3.935118530176733*^9}, {3.935118733396657*^9, 
   3.9351187343798*^9}, {3.9351190116156178`*^9, 3.935119012996093*^9}, {
   3.935119216787368*^9, 3.9351192177173147`*^9}, {3.935119462094247*^9, 
   3.935119465627594*^9}, {3.935119685735461*^9, 3.935119686769011*^9}, {
   3.935120214521652*^9, 3.9351202159252996`*^9}, {3.935120611633877*^9, 
   3.935120613432115*^9}, {3.935121562953248*^9, 3.935121564300507*^9}, {
   3.93512430792697*^9, 3.9351243093575087`*^9}, {3.935142316124761*^9, 
   3.93514231740446*^9}, {3.935543709691161*^9, 3.9355437134864902`*^9}, {
