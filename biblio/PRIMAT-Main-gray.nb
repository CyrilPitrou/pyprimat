Cell["\<\
Energy density corrections are obtained from the thermodynamic identity \
\[Rho] = -P + T dP/dT. See Eq. 50 of companion paper.\
\>", "Text",
 InitializationCell->
  True,ExpressionUUID->"846d03aa-9a30-4cc6-a0ac-8ab1140c3090"],

Cell[BoxData[{
