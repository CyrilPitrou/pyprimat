         RowBox[{"Take", "[", 
          RowBox[{"#", ",", 
           RowBox[{"{", 
            RowBox[{"5", ",", "8"}], "}"}]}], "]"}], "&"}], "/@", 
        "NubTabChar"}], ")"}]}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"MassExcessesString", "=", 
