Cell["\<\
We prefer using the most recent nubase (2020) (see comments about mass \
database at the top of this notebook) from the file nubase_4.mas20.txt  \
(Chinese Physics C 45 (2021) 030001).\
\>", "Text",
 CellChangeTimes->{{3.9355481542802467`*^9, 3.935548184579225*^9}, {
  3.9355487084541807`*^9, 
  3.935548728031207*^9}},ExpressionUUID->"52938a65-a1bb-436d-a2db-\
dccede444591"],

