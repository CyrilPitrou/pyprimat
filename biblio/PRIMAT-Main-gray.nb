Cell["\<\
We gather all operations needed to compute incomplete neutrino decoupling. \
Hence the function RecomputeIncompleteNeutrinoDecoupling can be called \
whenever we change some parameters so as to modify the incomplete decoupling \
of neutrinos.\
\>", "Text",ExpressionUUID->"e1f750aa-5876-473a-b2fc-5c3030237b27"],

Cell[BoxData[
 RowBox[{"RecomputeIncompleteNeutrinoDecoupling", ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{"$Verbose", ",", 
      RowBox[{
      "Print", "[", "\"\<Computing incomplete decoupling of neutrinos.\>\"", 
       "]"}]}], "]"}], ";", "\[IndentingNewLine]", "SolveaOFTwhenID", ";", 
    "\[IndentingNewLine]", "InvertaofTwhenID", ";", "\[IndentingNewLine]", 
    "Solve\[Rho]\[Nu]OFawhenID", ";"}], "\[IndentingNewLine]", 
   ")"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.72027043993437*^9, 3.720270450700762*^9}, {
   3.720270526724042*^9, 3.7202705586133738`*^9}, 3.7202712770688868`*^9, {
   3.9364096268113403`*^9, 3.93640964086517*^9}},
 CellLabel->
  "In[2035]:=",ExpressionUUID->"698fe341-7aa5-4f0a-971d-776655898494"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Neutrino Temperature", "Section",
 CellChangeTimes->{{3.722685770651433*^9, 
  3.722685774653966*^9}},ExpressionUUID->"60b5ba52-c2f6-4889-bb23-\
ff7ed44c9d2b"],

Cell["We extract the corresponding temperature of  neutrinos", "Text",
 CellChangeTimes->{{3.7005616261068707`*^9, 3.700561635784876*^9}, {
   3.7191618130489902`*^9, 3.7191618142780247`*^9}, 
   3.719163911934675*^9},ExpressionUUID->"0800104b-5b63-4c28-9126-\
343e7229094b"],

Cell["\<\
For full neutrino decoupling it is easy and deduced from entropy conservation.\
\>", "Text",ExpressionUUID->"50e1d0df-3dfe-4a0c-94fa-b996c16e9c72"],

Cell["\<\
We choose the correct temperature ratio depending on options chosen and we \
build the corresponding energy density\
\>", "Text",
 CellChangeTimes->{{3.719209291237646*^9, 3.7192093100451307`*^9}, 
   3.7226857875645123`*^9},ExpressionUUID->"6ba71344-65d6-4928-86a5-\
03bc689375dd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"T\[Nu]overTDecoupling", "[", "T_", "]"}], ":=", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"FourOverEleven", " ", 
      RowBox[{"DST", "[", "T", "]"}]}], ")"}], 
    RowBox[{"(", 
     RowBox[{"1", "/", "3"}], ")"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Rho]\[Nu]Decoupling", "[", "Tv_", "]"}], ":=", 
   RowBox[{"aBB", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"kB", " ", 
       RowBox[{"T\[Nu]overTDecoupling", "[", "Tv", "]"}], "Tv"}], ")"}], "4"],
     " ", 
    FractionBox["7", "8"], "Nneu"}]}], ";"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.700563327406941*^9, 3.7005633276335573`*^9}, {
   3.716095656342095*^9, 3.716095659528048*^9}, {3.71609573701258*^9, 
   3.716095741443993*^9}, 3.716095782805708*^9, 3.716169500742096*^9, {
   3.716524233319064*^9, 3.71652424196975*^9}, {3.717753524313467*^9, 
   3.71775354286467*^9}, {3.7177538881530247`*^9, 3.717753898181583*^9}, {
   3.718443702592679*^9, 3.7184437865384483`*^9}, {3.718443879625801*^9, 
   3.718443882298093*^9}, {3.718538820958219*^9, 3.718538865434722*^9}, {
   3.71853897731485*^9, 3.718538985223217*^9}, {3.718539036429387*^9, 
   3.71853904210015*^9}, {3.718607538685637*^9, 3.718607564039811*^9}, {
   3.7186078229414473`*^9, 3.718607828208805*^9}, {3.7191617906883163`*^9, 
   3.719161808504936*^9}, {3.719161933251923*^9, 3.719161949490152*^9}, 
   3.719209201541226*^9, {3.719209240918539*^9, 3.7192092870767307`*^9}, {
   3.722691959230715*^9, 3.722691959995078*^9}, {3.935113507024701*^9, 
   3.935113544145618*^9}, {3.935114311386683*^9, 3.93511431228421*^9}},
 CellLabel->
  "In[2036]:=",ExpressionUUID->"109f5f7a-3b4a-4081-820c-36a335edc939"],

Cell["\<\
When considering incomplete decoupling of neutrinos, we find the temperature \
variation, which is defined as a brightness temperature. See Eq. 64 of \
companion paper.\
\>", "Text",ExpressionUUID->"254c207d-a465-46fd-8516-92a130255bd7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"T\[Nu]overTIncompleteDecouplingQED", "[", "Tv_", "]"}], ":=", 
   SuperscriptBox[
    RowBox[{"(", 
     FractionBox[
      RowBox[{"\[Rho]\[Nu]CQED", "[", 
       RowBox[{"aCQED", "[", "Tv", "]"}], "]"}], 
      RowBox[{"aBB", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"kB", " ", "Tv"}], ")"}], "4"], " ", 
       FractionBox["7", "8"], "Nneu"}]], ")"}], 
    RowBox[{"(", 
     RowBox[{"1", "/", "4"}], ")"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"T\[Nu]overTIncompleteDecouplingNoQED", "[", "Tv_", "]"}], ":=", 
    SuperscriptBox[
     RowBox[{"(", 
      FractionBox[
       RowBox[{"\[Rho]\[Nu]CNoQED", "[", 
        RowBox[{"aCNoQED", "[", "Tv", "]"}], "]"}], 
       RowBox[{"aBB", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"kB", " ", "Tv"}], ")"}], "4"], " ", 
        FractionBox["7", "8"], "Nneu"}]], ")"}], 
     RowBox[{"(", 
      RowBox[{"1", "/", "4"}], ")"}]]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"T\[Nu]overTIncompleteDecoupling", "[", "T_", "]"}], ":=", 
  RowBox[{"If", "[", 
   RowBox[{"$QEDPlasmaCorrections", ",", 
    RowBox[{"T\[Nu]overTIncompleteDecouplingQED", "[", "T", "]"}], ",", 
    RowBox[{"T\[Nu]overTIncompleteDecouplingNoQED", "[", "T", "]"}]}], 
   "]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.700563327406941*^9, 3.7005633276335573`*^9}, {
   3.716095656342095*^9, 3.716095659528048*^9}, {3.71609573701258*^9, 
