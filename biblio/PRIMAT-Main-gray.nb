Cell[CellGroupData[{

Cell["Gathering the numerical results", "Section",
 CellChangeTimes->{{3.718604911174055*^9, 
  3.718604918252721*^9}},ExpressionUUID->"7505da4f-2f59-4a40-8579-\
bce4bf3ae2b6"],

Cell["\<\
We define a pseudo-mass fraction as a function of time using the interpolated \
results\
\>", "Text",ExpressionUUID->"d3d4e6b6-9cfe-4f23-9c71-c6edcabd3163"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"XI", "[", 
    RowBox[{"key_", "?", "KeyQ"}], "]"}], "[", "t_", "]"}], ":=", 
  RowBox[{
   RowBox[{"Ai", "[", "key", "]"}], 
   RowBox[{
    RowBox[{"YI", "[", "key", "]"}], "[", "t", 
    "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"XI", "[", "\"\<CNO\>\"", "]"}], "[", "t_", "]"}], ":=", 
  RowBox[{"Plus", "@@", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"Ai", "[", "#", "]"}], 
        RowBox[{
         RowBox[{"YI", "[", "#", "]"}], "[", "t", "]"}]}], "&"}], ")"}], "/@",
      "CNONuclei"}], ")"}]}]}]}], "Input",
 InitializationCell->True,
 CellLabel->
  "In[2546]:=",ExpressionUUID->"234de24b-4c53-41b1-9e69-45d8307d0421"],

Cell["Final abundances are obtained by evaluation at t = tend.", "Text",ExpressionUUID->"e285831d-4ee5-4646-81a3-3de69350cff4"],

Cell["\<\
We define a shorthand for the final abundances (Yf) and pseudo mass fraction \
(Xf).\
\>", "Text",
 CellChangeTimes->{{3.722759594295979*^9, 3.722759602181882*^9}, {
  3.7228449721421824`*^9, 
  3.722844986512885*^9}},ExpressionUUID->"1097da73-a081-421e-bfed-\
e5ea977e3265"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Yf", "[", "key_", "]"}], ":=", 
  RowBox[{
   RowBox[{"YLT", "[", "key", "]"}], "[", "tend", 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Xf", "[", "key_", "]"}], ":=", 
   RowBox[{
    RowBox[{"Ai", "[", "key", "]"}], 
    RowBox[{"Yf", "[", "key", "]"}]}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Xf", "[", "\"\<CNO\>\"", "]"}], ":=", 
  RowBox[{"Plus", "@@", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Xf", "[", "#", "]"}], "&"}], ")"}], "/@", "CNONuclei"}], 
    ")"}]}]}]}], "Input",
 InitializationCell->True,
 CellLabel->
  "In[2548]:=",ExpressionUUID->"78831074-5dc1-4c86-8bb8-272f38d6e29f"],

