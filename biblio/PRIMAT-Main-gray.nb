          RowBox[{"{", 
           RowBox[{"1", ",", "3"}], "}"}]}], "]"}], "&"}], "/@", 
       "NubTabChar"}], ")"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Zlist", "=", 
