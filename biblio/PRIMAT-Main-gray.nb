85b5a209fb7e"],

Cell[BoxData[
 RowBox[{"Computeaoft", ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"aoft", "=", 
     RowBox[{"NDSolveValue", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"av", "'"}], "[", "tv", "]"}], "\[Equal]", 
          FractionBox["1", 
           RowBox[{
