Cell[BoxData["InvertaOFT"], "Input",
 CellChangeTimes->{3.7202705961696157`*^9},
 CellLabel->
  "In[2087]:=",ExpressionUUID->"d70d03b4-a04f-4f5b-bf15-a66ebeb51a8f"],

Cell[TextData[{
 "We can check how accurate is this inversion by checking how a(T(a)) is the \
identity. The error is below ",
 Cell[BoxData[
