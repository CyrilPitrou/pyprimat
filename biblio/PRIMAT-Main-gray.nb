        RowBox[{"{", 
         RowBox[{"x", ",", "_Real"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"znu", ",", "_Real"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"sgnq", ",", "_Integer"}], "}"}]}], "}"}], ",", 
      RowBox[{"Evaluate", "[", 
       RowBox[{"IPENCCRDiffBremsstrahlung", "[", 
        RowBox[{"en", ",", "k", ",", "x", ",", "znu", ",", "sgnq"}], "]"}], 
