Cell["\<\
We check the translation into equivalent number of neutrinos. See section \
II.G of companion paper for the definition of Neff.
This section is only informative.\
\>", "Text",ExpressionUUID->"cefbf0c1-cea1-4dca-8f64-6228541f5753"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"T\[Nu]overTDecouplingNoQED", "[", "T_", "]"}], ":=", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"FourOverElevenNoQED", "*", " ", 
      RowBox[{"DSTNoQED", "[", "T", "]"}]}], ")"}], 
    RowBox[{"(", 
     RowBox[{"1", "/", "3"}], ")"}]]}], ";"}], "\[IndentingNewLine]", 
