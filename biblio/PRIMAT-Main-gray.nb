Cell[CellGroupData[{

Cell["Nuclear Reaction rates", "Section",
 InitializationCell->True,
 CellChangeTimes->{{3.69399165953745*^9, 3.693991665079824*^9}, {
  3.717820115657531*^9, 
  3.717820116804473*^9}},ExpressionUUID->"5b41cfe6-a96c-4144-9348-\
4af499bc09e7"],

Cell[CellGroupData[{

Cell["Radiative Corrections from pair productions", "Subsection",ExpressionUUID->"c7c74f9f-498f-4843-afe6-672459c561da"],

Cell["\<\
For photon producing processes we need to rescale the rates because of pair \
producing reactions. This has been computed in [Pitrou&Pospelov 2020]\
\>", "Text",ExpressionUUID->"091b8ff1-7ef0-44e7-b503-2c248810b357"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"RescaleElectricDipoleKroll", "[", "Ea_", "]"}], "=", 
    RowBox[{"1", "-", 
     FractionBox[
      RowBox[{"10", " ", "\[Alpha]FS"}], 
      RowBox[{"9", " ", "\[Pi]"}]], "+", 
     FractionBox[
      RowBox[{"3", " ", "\[Alpha]FS"}], 
      RowBox[{"4", " ", 
       SuperscriptBox["Ea", "4"], " ", "\[Pi]"}]], "+", 
     FractionBox[
      RowBox[{"3", " ", "\[Alpha]FS", " ", 
       RowBox[{
        InterpretationBox[
         StyleBox["Log",
          ShowAutoStyles->False,
          AutoSpacing->False],
         Log,
         Editable->False], "[", "16", "]"}]}], 
      RowBox[{"4", " ", 
       SuperscriptBox["Ea", "4"], " ", "\[Pi]"}]], "+", 
     FractionBox[
      RowBox[{"2", " ", "\[Alpha]FS", " ", 
       RowBox[{
        InterpretationBox[
         StyleBox["Log",
          ShowAutoStyles->False,
          AutoSpacing->False],
         Log,
         Editable->False], "[", "64", "]"}]}], 
      RowBox[{"9", " ", "\[Pi]"}]], "-", 
     FractionBox[
      RowBox[{"\[Alpha]FS", " ", 
       RowBox[{
        InterpretationBox[
         StyleBox["Log",
          ShowAutoStyles->False,
          AutoSpacing->False],
         Log,
         Editable->False], "[", 
        FractionBox["4", 
         SuperscriptBox["Ea", "2"]], "]"}]}], 
      RowBox[{"3", " ", "\[Pi]"}]], "-", 
     FractionBox[
      RowBox[{"3", " ", "\[Alpha]FS", " ", 
       RowBox[{
        InterpretationBox[
         StyleBox["Log",
          ShowAutoStyles->False,
          AutoSpacing->False],
         Log,
         Editable->False], "[", 
        FractionBox["4", 
         SuperscriptBox["Ea", "2"]], "]"}]}], 
      RowBox[{"4", " ", 
       SuperscriptBox["Ea", "4"], " ", "\[Pi]"}]]}]}], ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "Ea", " ", "is", " ", "the", " ", "available", " ", "energy", " ", "in", 
    " ", "units", " ", "of", " ", "electron", " ", 
    RowBox[{"mass", "."}]}], "*)"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"EML", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Z1_", ",", "A1_"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Z2_", ",", "A2_"}], "}"}]}], "]"}], "[", "T9_", "]"}], "=", 
    RowBox[{"0.1220", "*", 
     RowBox[{"Z1", "^", 
      RowBox[{"(", 
       RowBox[{"2", "/", "3"}], ")"}]}], "*", 
     RowBox[{"Z2", "^", 
      RowBox[{"(", 
       RowBox[{"2", "/", "3"}], ")"}]}], "*", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"A1", "*", "A2"}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"A1", "+", "A2"}], ")"}]}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{"1", "/", "3"}], ")"}]}], " ", 
     RowBox[{"T9", "^", 
      RowBox[{"(", 
       RowBox[{"2", "/", "3"}], ")"}]}], "MeV"}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "is", " ", "the", " ", "most", " ", "likely", " ", "Kinetic", 
    " ", "energy", " ", "in", " ", "MeV"}], "*)"}], "\[IndentingNewLine]", 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{"Clear", "[", "RescaleElectricDipoleZAZAQ", 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"RescaleElectricDipoleZAZAQ", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Z1_", ",", "A1_"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Z2_", ",", "A2_"}], "}"}], ",", "Qv_"}], "]"}], "[", "T9_", 
     "]"}], "=", 
    RowBox[{"(", 
     RowBox[{"RescaleElectricDipoleKroll", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"EML", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"Z1", ",", "A1"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"Z2", ",", "A2"}], "}"}]}], "]"}], "[", "T9", "]"}], "+",
          "Qv"}], ")"}], "/", "me"}], "]"}], ")"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "We", " ", "use", " ", "a", " ", "rescaling", " ", "computed", " ", "at", 
     " ", "the", " ", "most", " ", "likely", " ", "kinetic", " ", "energy"}], 
    ",", " ", 
    RowBox[{
    "On", " ", "top", " ", "of", " ", "which", " ", "we", " ", "add", " ", 
     "the", " ", "mass", " ", "gap", " ", "to", " ", "the", " ", "total", " ",
      "available", " ", "energy"}]}], " ", "*)"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{"Clear", "[", "RescaleElectricDipole", 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RescaleElectricDipole", "[", 
   RowBox[{"Nucl1_", ",", "Nucl2_", ",", "Nuclfinal_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"RescaleElectricDipole", "[", 
    RowBox[{"Nucl1", ",", "Nucl2", ",", "Nuclfinal"}], "]"}], "=", 
   RowBox[{"Function", "[", 
    RowBox[{
     RowBox[{"{", "T9", "}"}], ",", 
     RowBox[{"Evaluate", "@", 
      RowBox[{
       RowBox[{"RescaleElectricDipoleZAZAQ", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Zi", "[", "Nucl1", "]"}], ",", 
           RowBox[{"Ai", "[", "Nucl1", "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Zi", "[", "Nucl2", "]"}], ",", 
           RowBox[{"Ai", "[", "Nucl2", "]"}]}], "}"}], ",", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Mass", "[", "Nucl1", "]"}], "+", 
           RowBox[{"Mass", "[", "Nucl2", "]"}], "-", 
           RowBox[{"Mass", "[", "Nuclfinal", "]"}]}], ")"}]}], "]"}], "[", 
       "T9", "]"}]}]}], "]"}]}]}], "\[IndentingNewLine]"}], "Input",
 InitializationCell->True,
 CellLabel->
  "In[2392]:=",ExpressionUUID->"15634116-4d3f-4ea5-8904-1a4ac6cd20e0"],

Cell["\<\
The some rescaling factors due to possible pair production for reactions \
which produce a photon in the final state. These are functions of T9 \
(=Temperature in GigaK).\
\>", "Text",ExpressionUUID->"4a707d07-f5c9-4839-9b55-1de7c52b2617"],

