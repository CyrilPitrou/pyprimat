Cell[BoxData[{
 RowBox[{"Tfreeze1", "=", 
  RowBox[{
   RowBox[{"FindRoot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"LnTOp", "[", "T", "]"}], "==", 
       RowBox[{"HofT", "[", "T", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"T", ",", 
       RowBox[{"10", "^", "10"}]}], "}"}]}], "]"}], "[", 
   RowBox[{"[", 
    RowBox[{"1", ",", "2"}], "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Tfreeze2", "=", 
  RowBox[{
   RowBox[{"FindRoot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"LnTOp", "[", "T", "]"}], "+", 
        RowBox[{"LpTOn", "[", "T", "]"}]}], "\[Equal]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"Q", "/", 
            RowBox[{"(", 
             RowBox[{"kB", " ", "T"}], ")"}]}], "]"}], "/", 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"Exp", "[", 
             RowBox[{"Q", "/", 
              RowBox[{"(", 
               RowBox[{"kB", " ", "T"}], ")"}]}], "]"}]}], ")"}]}], ")"}], 
        RowBox[{"Q", "/", 
         RowBox[{"(", 
          RowBox[{"kB", " ", "T"}], ")"}]}], 
        RowBox[{"HofT", "[", "T", "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"T", ",", 
       RowBox[{"10", "^", "10"}]}], "}"}]}], "]"}], "[", 
   RowBox[{"[", 
    RowBox[{"1", ",", "2"}], "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Tfreeze3", "=", 
  RowBox[{
   RowBox[{"FindRoot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"LnTOp", "[", "T", "]"}], "+", 
        RowBox[{"LpTOn", "[", "T", "]"}]}], "==", 
       RowBox[{"HofT", "[", "T", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"T", ",", 
       RowBox[{"10", "^", "10"}]}], "}"}]}], "]"}], "[", 
   RowBox[{"[", 
    RowBox[{"1", ",", "2"}], "]"}], "]"}]}]}], "Input",
