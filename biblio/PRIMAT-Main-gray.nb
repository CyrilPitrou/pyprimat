Cell["\<\
FormalReactions is the list of rhs of differential equation in an abstract \
level.
-The species are given by Y[1], Y[2],Y[3], and we need the dictionary KeyVal \
to know to which species it corresponds. 
-The reactions are L[1], L[2],L[3] and we also need a dictionary \
(KeyReaction) to know to which reaction it corresponds.\
\>", "Text",
 CellChangeTimes->{{3.715951010870778*^9, 3.715951038990868*^9}, {
   3.7159510812935133`*^9, 3.7159511562737827`*^9}, {3.715951243923992*^9, 
   3.715951249875843*^9}, 
   3.722699554963182*^9},ExpressionUUID->"77664b24-3c9c-4f09-9fae-\
3a47ba972918"],

Cell["\<\
We might define compiled version which are used if the $CompileNDSolve option \
is set to True. This is much faster.
Otherwise if $CompileNDSolve=False, the DY, DY18 and DYPEN are called in \
DefineEquations further below when it is associated with the l.h.s to form \
the differential system.\
\>", "Text",
 CellChangeTimes->{{3.700218512613139*^9, 3.700218528897544*^9}, {
   3.7033017122887774`*^9, 3.703301712534875*^9}, {3.715951556626285*^9, 
   3.715951558808896*^9}, 3.7159516079466667`*^9, {3.722759158159699*^9, 
   3.722759183513303*^9}, {3.722759242293557*^9, 3.7227592547733517`*^9}, {
   3.936394976679821*^9, 
   3.9363949842855988`*^9}},ExpressionUUID->"333e04e7-ad63-4220-8861-\
a0a3c68e764f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CompileFromFormal", "[", "FormalReactions_List", "]"}], ":=", 
  RowBox[{"ReleaseHold", "[", 
   RowBox[{
    RowBox[{"Hold", "[", 
     RowBox[{"Compile", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"A\[Rho]B", ",", "_Real"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"L", ",", "_Real", ",", "1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"Lbar", ",", "_Real", ",", "1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"Y", ",", "_Real", ",", "1"}], "}"}]}], "}"}], ",", 
       "inside", ",", 
       RowBox[{"CompilationTarget", "\[Rule]", "\"\<C\>\""}], ",", 
       RowBox[{"\"\<RuntimeOptions\>\"", "\[Rule]", "\"\<Speed\>\""}], ",", 
       RowBox[{"CompilationOptions", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"\"\<InlineExternalDefinitions\>\"", "\[Rule]", "True"}], 
         "}"}]}], ",", 
       RowBox[{"Parallelization", "->", "False"}]}], "]"}], "]"}], "//.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"inside", "\[Rule]", "FormalReactions"}], ",", 
      RowBox[{
       RowBox[{"Y", "[", "m_", "]"}], "\[RuleDelayed]", 
       RowBox[{"Y", "[", 
        RowBox[{"[", "m", "]"}], "]"}]}], ",", 
      RowBox[{
       RowBox[{"L", "[", "m_", "]"}], "\[RuleDelayed]", 
       RowBox[{"L", "[", 
        RowBox[{"[", "m", "]"}], "]"}]}], ",", 
      RowBox[{
       RowBox[{"Lbar", "[", "m_", "]"}], "\[RuleDelayed]", 
       RowBox[{"Lbar", "[", 
        RowBox[{"[", "m", "]"}], "]"}]}]}], "}"}]}], "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.700218370142746*^9, 3.700218394152357*^9}, {
   3.936254562423377*^9, 3.936254566407043*^9}, {3.936266954848549*^9, 
   3.936266955089767*^9}, {3.9362872902063713`*^9, 3.936287290896915*^9}, 
   3.936287421445949*^9, 3.936287452517172*^9, {3.936287588282391*^9, 
   3.936287589041873*^9}, {3.93628766601722*^9, 3.936287666622177*^9}, {
   3.936288971224639*^9, 3.9362889725600986`*^9}, 3.936295153080003*^9},
 CellLabel->
