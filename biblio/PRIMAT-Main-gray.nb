               RowBox[{
                RowBox[{"LinearTable2DNue", "[", "fn", "]"}], "[", 
                RowBox[{"[", 
                 RowBox[{"lxi", ",", "yi"}], "]"}], "]"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"yi", ",", "1", ",", "Ny"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"lxi", ",", "1", ",", 
               RowBox[{"Lengthxrange", "[", "fn", "]"}]}], "}"}]}], "]"}], 
           ",", "1"}], "]"}]}]}], ";", "\n", 
       RowBox[{"(*", " ", 
        RowBox[{
        "If", " ", "points", " ", "are", " ", "outside", " ", "interpolation",
          " ", "we", " ", "put", " ", "0"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"dfNuelogxySafey", "[", "fn", "]"}], "[", 
