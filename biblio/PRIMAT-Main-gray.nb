Cell["\<\
Baryons density is obtained from its valued today scaled by dilution (no \
thermal effects, so it is only the energy density due to rest mass of \
baryons).\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.698381548831592*^9, 3.698381587689069*^9}, {
  3.698381712674609*^9, 3.698381713847342*^9}, {3.72268429270203*^9, 
  3.7226842927788467`*^9}},ExpressionUUID->"de1b50c7-8d47-4232-a1e0-\
4c5a6aee99ea"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[Rho]B", "[", "av_", "]"}], ":=", 
   FractionBox[
    RowBox[{"\[Rho]B0", " "}], 
    SuperscriptBox["av", "3"]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"nB", "[", "av_", "]"}], ":=", 
   FractionBox[
    RowBox[{"nbaryons0", " "}], 
    SuperscriptBox["av", "3"]]}], ";"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.6940760647311373`*^9, 3.694076086584598*^9}, 
   3.6940775812992077`*^9, {3.6950153891602573`*^9, 3.695015401945507*^9}, 
   3.699777730164369*^9, {3.703301763791449*^9, 3.7033017812452106`*^9}, {
   3.703301856829289*^9, 3.703301884160434*^9}, {3.7033019622788973`*^9, 
   3.703302010284329*^9}, {3.703309078528803*^9, 3.703309084459551*^9}, {
   3.70330915000527*^9, 3.7033091551230507`*^9}, {3.7033094268067408`*^9, 
   3.70330943101259*^9}, {3.703310624023806*^9, 3.7033106326646957`*^9}, {
   3.703572255417985*^9, 3.703572262727487*^9}, {3.713914269515983*^9, 
   3.713914315642177*^9}, {3.7159380312627573`*^9, 3.715938033149338*^9}, 
   3.7159381136083307`*^9, {3.715943152076902*^9, 3.715943152585827*^9}, {
