0631b3ae2e4b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ListThermalValuesMT", "=", 
    RowBox[{"If", "[", 
     RowBox[{"$ReducedNetwork", ",", 
      RowBox[{"{", 
       RowBox[{
       "\"\<d\>\"", ",", "\"\<t\>\"", ",", "\"\<He3\>\"", ",", "\"\<a\>\"", 
        ",", "\"\<Be7\>\"", ",", "\"\<Li7\>\""}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
       "\"\<d\>\"", ",", "\"\<t\>\"", ",", "\"\<He3\>\"", ",", "\"\<a\>\"", 
        ",", "\"\<Be7\>\"", ",", "\"\<Li7\>\"", ",", "\"\<Li6\>\""}], "}"}]}],
      "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ListThermalValuesUsedMT", ":=", 
  RowBox[{"Intersection", "[", 
   RowBox[{"VariablesInEquations", ",", "ListThermalValuesMT"}], 
   "]"}]}]}], "Input",
 InitializationCell->True,
