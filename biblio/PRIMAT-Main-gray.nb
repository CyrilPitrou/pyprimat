           " ", "can", " ", "interpolate", " ", "in", " ", "two", " ", 
          "dimensions"}]}], " ", "*)"}], "\[IndentingNewLine]", " ", 
       RowBox[{
        RowBox[{"dfNuelogxy", "[", "fn", "]"}], "=", 
