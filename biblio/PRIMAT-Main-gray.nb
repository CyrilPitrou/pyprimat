            RowBox[{
             RowBox[{"dfNuelogxySafey", "[", "fn", "]"}], "[", 
             RowBox[{"Lxmin", ",", "y"}], "]"}]}], "]"}]}], " ", "]"}]}], " ",
        ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{"Finally", ",", " ", 
         RowBox[{"after", " ", "all", " ", "this"}], ",", " ", 
         RowBox[{
         "we", " ", "obtain", " ", "a", " ", "function", " ", "which", " ", 
          "depends", " ", "on", " ", "xNEVO", " ", 
