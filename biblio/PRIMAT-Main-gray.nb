Cell[BoxData[{
 RowBox[{
  RowBox[{"ReactionWithArrow", "[", "name_String", "]"}], ":=", 
  RowBox[{"StringReplace", "[", 
   RowBox[{"name", ",", 
    RowBox[{"\"\<TO\>\"", "\[Rule]", "\"\< -> \>\""}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"NiceDisplayReaction", "[", "reaction_List", "]"}], ":=", 
  RowBox[{"Join", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"ReactionWithArrow", "[", 
      RowBox[{"First", "[", "reaction", "]"}], "]"}], "}"}], ",", 
    RowBox[{"Rest", "[", "reaction", "]"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PadLeftNumberRow", "[", "tab_List", "]"}], ":=", 
  RowBox[{"MapThread", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Prepend", "[", 
      RowBox[{"#2", ",", "#1"}], "]"}], "&"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Range", "@", 
       RowBox[{"Length", "@", "tab"}]}], ",", "tab"}], "}"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
