Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "When", " ", "providing", " ", "different", " ", "files", " ", "for", " ", 
    "neutrinos", " ", "and", " ", "antineutrinos"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"FileNEVOneutrinos", " ", "=", " ", 
     RowBox[{
     "\"\<CSV/NEVOneutrinos\>\"", "<>", "$FileSuffix", "<>", 
      "\"\<.csv\>\""}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"FileNEVOantineutrinos", " ", "=", " ", 
     RowBox[{
     "\"\<CSV/NEVOantineutrinos\>\"", "<>", "$FileSuffix", "<>", 
      "\"\<.csv\>\""}]}], ";"}], "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"FileNEVOneutrinos", " ", ":=", " ", 
     RowBox[{"$CSVDirectory", "<>", 
      RowBox[{"If", "[", 
       RowBox[{"$QEDPlasmaCorrections", ",", 
        RowBox[{"If", "[", 
         RowBox[{
         "$QEDOe3", ",", " ", "\"\<NEVOPRIMAT\>\"", " ", ",", 
          "\"\<NEVOPRIMAT_QED2\>\""}], "]"}], ",", 
        "\"\<NEVOPRIMAT_NoQED\>\""}], "]"}], "<>", "$LocalSuffix", "<>", 
      "\"\<.csv\>\""}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"FileNEVOantineutrinos", " ", ":=", " ", "FileNEVOneutrinos"}], 
    ";"}], "\[IndentingNewLine]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9361933219730387`*^9, 3.936193354581106*^9}, {
   3.936193459981976*^9, 3.936193460493421*^9}, {3.9363670532799263`*^9, 
