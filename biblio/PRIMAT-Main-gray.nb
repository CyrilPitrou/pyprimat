Cell["\<\
We can also perform a fit in Hermite polynomials of the NEVO heating \
function. Just for information. \
\>", "Text",ExpressionUUID->"93dafe56-baa9-41fa-865c-d1077bfb4633"],

Cell[BoxData[
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{"$NEVO", ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"Nlz", "[", "lz_", "]"}], ":=", 
      RowBox[{
       RowBox[{"\[ScriptCapitalN]NEVO", "[", "FileNEVOneutrinos", "]"}], "[", 
       
       RowBox[{"Exp", "@", "lz"}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{"Gram", "-", 
       RowBox[{"Charlier", " ", 
        RowBox[{"expansion", ".", " ", "Works"}], " ", "better", " ", "in", 
        " ", "that", " ", "case"}]}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"MyHermiteN", "[", 
       RowBox[{"n_", ",", "x_"}], "]"}], ":=", 
      RowBox[{"Expand", "@", 
       RowBox[{"Simplify", "[", 
        RowBox[{
         RowBox[{"HermiteH", "[", 
          RowBox[{"n", ",", 
           RowBox[{"x", "/", 
            RowBox[{"Sqrt", "[", "2", "]"}]}]}], "]"}], "/", 
         RowBox[{
          RowBox[{"Sqrt", "[", "2", "]"}], "^", "n"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", "\n", 
     RowBox[{"Fitfun", "=", 
      RowBox[{
       RowBox[{"A", "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{"2", "Pi"}], "]"}], "\[Sigma]"}], ")"}]}], 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"lz", "-", "\[Mu]"}], ")"}], "^", "2"}]}], "/", 
         RowBox[{"(", 
          RowBox[{"2", 
           RowBox[{"\[Sigma]", "^", "2"}]}], ")"}]}], "]"}], 
       RowBox[{"(", 
        RowBox[{"1", "\[IndentingNewLine]", "+", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"S3", "/", 
            RowBox[{"3", "!"}]}], 
           RowBox[{"MyHermiteN", "[", 
            RowBox[{"3", ",", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"lz", "-", "\[Mu]"}], ")"}], "/", "\[Sigma]"}]}], 
            "]"}]}], ")"}], "\[IndentingNewLine]", "+", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"S4", "/", 
            RowBox[{"4", "!"}]}], 
           RowBox[{"MyHermiteN", "[", 
            RowBox[{"4", ",", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"lz", "-", "\[Mu]"}], ")"}], "/", "\[Sigma]"}]}], 
            "]"}]}], ")"}], "\[IndentingNewLine]", "+", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"S5", "/", 
            RowBox[{"5", "!"}]}], " ", 
           RowBox[{"MyHermiteN", "[", 
            RowBox[{"5", ",", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"lz", "-", "\[Mu]"}], ")"}], "/", "\[Sigma]"}]}], 
            "]"}]}], ")"}], "\[IndentingNewLine]", "+", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"S6", "/", 
            RowBox[{"6", "!"}]}], " ", 
           RowBox[{"MyHermiteN", "[", 
            RowBox[{"6", ",", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"lz", "-", "\[Mu]"}], ")"}], "/", "\[Sigma]"}]}], 
            "]"}]}], ")"}], "\[IndentingNewLine]", "+", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"S7", "/", 
            RowBox[{"7", "!"}]}], " ", 
           RowBox[{"MyHermiteN", "[", 
            RowBox[{"7", ",", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"lz", "-", "\[Mu]"}], ")"}], "/", "\[Sigma]"}]}], 
            "]"}]}], ")"}], "\[IndentingNewLine]", "+", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"S8", "/", 
            RowBox[{"8", "!"}]}], " ", 
           RowBox[{"MyHermiteN", "[", 
            RowBox[{"8", ",", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"lz", "-", "\[Mu]"}], ")"}], "/", "\[Sigma]"}]}], 
            "]"}]}], ")"}], "\[IndentingNewLine]", "+", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"S9", "/", 
            RowBox[{"9", "!"}]}], " ", 
           RowBox[{"MyHermiteN", "[", 
            RowBox[{"9", ",", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"lz", "-", "\[Mu]"}], ")"}], "/", "\[Sigma]"}]}], 
            "]"}]}], ")"}], "\[IndentingNewLine]", "+", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"S10", "/", 
            RowBox[{"10", "!"}]}], " ", 
           RowBox[{"MyHermiteN", "[", 
            RowBox[{"10", ",", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"lz", "-", "\[Mu]"}], ")"}], "/", "\[Sigma]"}]}], 
            "]"}]}], ")"}]}], ")"}]}]}], ";", "\n", 
     RowBox[{"fitlzmax", "=", "1.7"}], 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"-", "1"}], "+", "2.7"}], "*)"}], ";", "\[IndentingNewLine]", 
     RowBox[{"fitlzmin", "=", 
      RowBox[{"-", "4.3"}]}], 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"-", "1"}], "-", "3."}], "*)"}], ";", "\n", 
     RowBox[{"TableVals", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"lz", ",", 
          RowBox[{"Nlz", "[", "lz", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"lz", ",", "fitlzmin", ",", "fitlzmax", ",", "0.01"}], 
         "}"}]}], "]"}]}], ";", "\n", 
     RowBox[{"Fitvals", "=", 
      RowBox[{"FindFit", "[", 
       RowBox[{"TableVals", ",", "Fitfun", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"A", ",", "0.01"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Mu]", ",", 
            RowBox[{"-", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Sigma]", ",", "1"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"S3", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"S4", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"S5", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"S6", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"S7", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"S8", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"S9", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"S10", ",", "0"}], "}"}]}], "}"}], ",", "lz"}], "]"}]}], 
     ";", "\n", 
     RowBox[{
      RowBox[{"NlzFit", "[", "lz_", "]"}], "=", 
      RowBox[{"Fitfun", "/.", "Fitvals"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"NFit", "[", "z_", "]"}], ":=", 
      RowBox[{"NlzFit", "[", 
       RowBox[{"Log", "[", "z", "]"}], "]"}]}], ";", "\n", 
     RowBox[{"LogLogPlot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"\[ScriptCapitalN]NEVO", "[", "FileNEVOneutrinos", "]"}], 
          "[", 
          RowBox[{"me", "/", 
           RowBox[{"(", 
            RowBox[{"kB", "*", "Tv"}], ")"}]}], "]"}], ",", 
         RowBox[{"\[ScriptCapitalN]Parthenope", "[", 
          RowBox[{"me", "/", 
           RowBox[{"(", 
            RowBox[{"kB", "*", "Tv"}], ")"}]}], "]"}], ",", 
         RowBox[{"NFit", "[", 
          RowBox[{"me", "/", 
           RowBox[{"(", 
            RowBox[{"kB", "*", "Tv"}], ")"}]}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Tv", ",", 
         RowBox[{"1.2", "*", 
          RowBox[{"10", "^", "9"}]}], ",", 
         RowBox[{"4", "*", 
          RowBox[{"10", "^", "11"}]}]}], "}"}], ",", 
       RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
       RowBox[{"Frame", "\[Rule]", "True"}]}], "]"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]"}]], "Input",
 CellChangeTimes->{{3.934967018574979*^9, 3.934967037313529*^9}},
 CellLabel->
  "In[2005]:=",ExpressionUUID->"c308f443-2ad1-4800-afdb-92e59e2784f7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "By", " ", "construction", " ", "\[ScriptCapitalN]", " ", "is", " ", "the", 
   " ", "heat", " ", "rate", " ", "transfered", " ", "in", " ", "unit", " ", 
   "of", " ", "Hubble", " ", 
   RowBox[{"rate", ".", " ", "Or"}], " ", "more", " ", "precisely"}], ",", 
  " ", 
  RowBox[{
   RowBox[{"the", " ", "volumic", " ", "heat", " ", "rate", " ", 
    RowBox[{"(", 
     RowBox[{"the", " ", "source", " ", "on", " ", "the", " ", 
      RowBox[{"r", ".", "h", ".", "s"}], " ", "of", " ", 
      RowBox[{"d\[Rho]", "/", "dt"}], " ", "equation"}], ")"}], " ", "is", 
    " ", 
    RowBox[{"dq", "/", "dt"}]}], " ", "=", " ", 
   RowBox[{"H", "  ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"kB", " ", "T"}], ")"}], "4"], "\[ScriptCapitalN]", " ", "with",
     " ", "plus", " ", "sign", " ", "for", " ", "neutrinos", " ", "and", " ", 
    "minus", " ", "sign", " ", "for", " ", 
    RowBox[{"electron", "/", "photons"}], " ", 
    RowBox[{
    "plasma", ".", "\[IndentingNewLine]", "\[IndentingNewLine]", "See"}], " ",
     "companion", " ", "paper", " ", "for", " ", "more", " ", "details", " ", 
    "in", " ", "section", " ", 
    RowBox[{"II", ".", "F", ".", "\[IndentingNewLine]", "We"}], " ", 
    "transform", " ", "it", " ", "to", " ", "a", " ", "function", " ", "of", 
    " ", "temperature", " ", "or", " ", 
    RowBox[{
     RowBox[{"Log", "[", "T", "]"}], "."}]}]}]}]], "Text",
 FontFamily->"Arial",ExpressionUUID->"41bdc6c8-bd84-4ed2-a085-5dea7e16b7ac"],

