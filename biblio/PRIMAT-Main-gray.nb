Cell[CellGroupData[{

Cell["Random Number Generation for nuclear rates uncertainties", "Subsection",
 CellChangeTimes->{{3.722699012651712*^9, 
  3.7226990240929127`*^9}},ExpressionUUID->"3797721b-a2d5-4cba-95a8-\
9612ca7c21f8"],

Cell["\<\
Generator of random number according to Normal distribution. But we make sure \
to use always the same sequence to avoid noise in Monte-Carlo.
This is crucial because this reduces Monte-Carlo noise when evaluating \
uncertainty in rates.

So for a given seed we precompute a list of 1000 random numbers.
Then we call several times MyNormalRandom[seed] which gives successively the \
random numbers which were generated with the seed.\
\>", "Text",ExpressionUUID->"58e65082-0bf3-4fd0-a9bb-954f423869e8"],

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"TableRandom", ",", "MyNormalRandom"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$NRandomPoints", " ", "=", " ", "1000"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "We", " ", "put", " ", "something", " ", "larger", " ", "than", " ", "the",
     " ", "max", " ", "number", " ", "of", " ", "reactions"}], " ", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TableRandom", "[", "seed_", "]"}], ":=", 
  RowBox[{
   RowBox[{"TableRandom", "[", "seed", "]"}], "=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"SeedRandom", "[", "seed", "]"}], ";", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"RandomVariate", "[", 
        RowBox[{"NormalDistribution", "[", "]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "$NRandomPoints"}], "}"}]}], "]"}]}], 
    ")"}]}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.699766963198509*^9, 3.699766963966271*^9}, {
   3.69976703547722*^9, 3.699767035856285*^9}, {3.699768351284984*^9, 
   3.69976839402356*^9}, {3.699768889239374*^9, 3.699768909792739*^9}, {
   3.699769352120776*^9, 3.699769354378643*^9}, 3.6998083333573313`*^9, {
   3.6998683268209352`*^9, 3.699868328642433*^9}, {3.699885248638185*^9, 
   3.699885250791157*^9}, {3.69988582533889*^9, 3.699885828570672*^9}, {
   3.699885919935988*^9, 3.699885942921461*^9}, {3.6999736989165077`*^9, 
   3.699973708383046*^9}, 3.719928709518571*^9, {3.720920852602211*^9, 
   3.720920912818491*^9}, {3.720920962197095*^9, 3.720920965772393*^9}, {
   3.720921347018948*^9, 3.720921367697701*^9}, {3.7209214037553988`*^9, 
   3.720921409707602*^9}, {3.720921867489841*^9, 3.720921960136424*^9}, {
   3.720922032125073*^9, 3.720922034733049*^9}},
 CellLabel->
  "In[2406]:=",ExpressionUUID->"a43490de-030e-45ac-bf6a-bf677ab89ef7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"InitializeRandom", "[", "seed_", "]"}], ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"IndexRandom", "[", "seed", "]"}], "=", "1"}], ")"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RandomFromTable", "[", "seed_", "]"}], ":=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", "=", 
      RowBox[{
       RowBox[{"TableRandom", "[", "seed", "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"IndexRandom", "[", "seed", "]"}], "]"}], "]"}]}], "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"IndexRandom", "[", "seed", "]"}], "=", 
      RowBox[{
       RowBox[{"IndexRandom", "[", "seed", "]"}], "+", "1"}]}], ";", "r"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MyNormalRandom", "[", "seed_", "]"}], ":=", 
  RowBox[{"RandomFromTable", "[", "seed", "]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.699766963198509*^9, 3.699766963966271*^9}, {
