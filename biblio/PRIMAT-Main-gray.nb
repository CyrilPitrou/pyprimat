   RowBox[{"Drop", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"#", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "&"}], "/@", 
      RowBox[{"Import", "[", 
       RowBox[{"\"\<nubase_4.mas20.txt\>\"", ",", "\"\<TSV\>\""}], "]"}]}], 
     ",", "25"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"NubTabChar", "=", 
   RowBox[{"Select", "[", 
    RowBox[{
