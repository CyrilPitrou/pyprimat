Cell["\<\
We build a function which selects all species having the same mass number A \
or Z number\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.699359803314328*^9, 3.699359858955772*^9}, 
   3.699362234476458*^9, {3.699365446381321*^9, 3.69936545121282*^9}, 
