  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
   "TabulatedReactionsFileSmallNetwork", "=", 
    "\"\<BBNRatesAC2024_small_network.dat\>\""}], ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "For", " ", "small", " ", "network", " ", "of", " ", "12", " ", "nuclear", 
    " ", "reactions"}], " ", "*)"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.86110089065913*^9, 3.861100890784301*^9}, {
