Cell[TextData[StyleBox["Numerical values",
 FontVariations->{"Underline"->True}]], "Text",
 CellChangeTimes->{{3.7198913618920717`*^9, 3.719891367888267*^9}},
 FontSize->16,
 FontSlant->"Italic",ExpressionUUID->"397fd8eb-d5b0-470e-9ddd-70aca5d912eb"],

Cell[TextData[{
 "[Planck 2015 XIII] Ade et al. A.&A. 594, A13 (2016).\n[Planck 2018 VI] \
A.&A. (2020). We use TT+TE+EE+lowE+Lensing+BAO parameters (last column of \
table 2).\n[PDG17] ",
 ButtonBox["Particle Data Group 2017",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://pdg.lbl.gov/index.html"], None},
  ButtonNote->"http://pdg.lbl.gov/index.html"],
 ".\n[PDG20] Particle Data group 2020.\n[PDG23] Particle Data group 2023\n\
[PDG24] ",
 ButtonBox["Particle Data Group 2024 ",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://pdg.lbl.gov/2024/reviews/contents_sports.html"], None},
  ButtonNote->"https://pdg.lbl.gov/2024/reviews/contents_sports.html"],
 "\n\nMasses of nuclei previously from ",
 ButtonBox["nubase2016.asc",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www-nds.iaea.org/amdc/ame2016/NUBASE2016.pdf"], None},
  ButtonNote->"https://www-nds.iaea.org/amdc/ame2016/NUBASE2016.pdf"],
 "  (Chinese Physics C 36 (2012) 1157-1286) which can be downloaded from ",
 ButtonBox["Nuclear Data Services",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www-nds.iaea.org/amdc/"], None},
  ButtonNote->"https://www-nds.iaea.org/amdc/"],
 ".\nSwitched to the 2020 update of that database which is ",
 ButtonBox["nubase_ 4.mas20.txt",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www-nds.iaea.org/amdc/ame2020/nubase_4.mas20.txt"], None},
  ButtonNote->"https://www-nds.iaea.org/amdc/ame2020/nubase_4.mas20.txt"],
 "  (Chinese Physics C 45 (2021) 030001) which is also found on from ",
 ButtonBox["Nuclear Data Services",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www-nds.iaea.org/amdc/"], None},
  ButtonNote->"https://www-nds.iaea.org/amdc/"],
 ".  "
}], "Text",
 CellChangeTimes->{{3.9355469502805843`*^9, 3.935547007206937*^9}, {
   3.935547061790922*^9, 3.9355472217516537`*^9}, {3.9355473282259703`*^9, 
