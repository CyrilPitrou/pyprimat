Cell[CellGroupData[{

Cell["Checking detailed balance", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{{3.696567923324329*^9, 
  3.6965679285243692`*^9}},ExpressionUUID->"407ffaf2-b818-4363-9238-\
9091c35dd2be"],

Cell["Born approximation detailed balance checks.", "Text",
 InitializationCell->
  True,ExpressionUUID->"1b8e61f3-b155-4e8f-ba50-ee327b62f4b1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DetailedBalanceRatio0", "[", "T_", "]"}], ":=", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", 
      FractionBox["Q", 
       RowBox[{"(", 
