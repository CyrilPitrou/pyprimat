Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"PlotDeutEq", "=", 
    RowBox[{"Show", "[", 
     RowBox[{
      RowBox[{"LogLogPlot", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"YnF", "[", 
           RowBox[{"tofa", "@", 
            RowBox[{"a", "[", 
             RowBox[{
              RowBox[{"10", "^", "8"}], " ", "Tv"}], "]"}]}], "]"}], ",", 
          RowBox[{"YNSE", "[", 
           RowBox[{"\"\<d\>\"", ",", 
            RowBox[{"YnF", "[", 
             RowBox[{"tofa", "@", 
              RowBox[{"a", "[", 
               RowBox[{
                RowBox[{"10", "^", "8"}], "Tv"}], "]"}]}], "]"}], ",", 
            RowBox[{"YpF", "[", 
             RowBox[{"tofa", "@", 
              RowBox[{"a", "[", 
               RowBox[{
                RowBox[{"10", "^", "8"}], "Tv"}], "]"}]}], "]"}], ",", 
            RowBox[{
             RowBox[{"10", "^", "8"}], "Tv"}]}], "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"Tv", ",", 
          RowBox[{"0.05", "*", 
           RowBox[{"10", "^", "2"}]}], ",", 
          RowBox[{"0.1", "*", 
           RowBox[{"10", "^", "2"}]}]}], "}"}], ",", 
        RowBox[{"GridLines", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"{", 
             RowBox[{"Tnuc", ",", 
              RowBox[{"{", 
               RowBox[{"Gray", ",", 
                RowBox[{"Thickness", "[", "0.005", "]"}]}], "}"}]}], "}"}], 
            "}"}], ",", 
           RowBox[{"{", "}"}]}], "}"}]}], ",", 
        RowBox[{"Frame", "\[Rule]", "True"}], ",", 
        RowBox[{"PlotRange", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"0.05", "*", 
              RowBox[{"10", "^", "2"}]}], ",", 
             RowBox[{"0.1", "*", 
              RowBox[{"10", "^", "2"}]}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"10", "^", 
              RowBox[{"-", "3"}]}], ",", 
             RowBox[{"10", "^", "3"}]}], "}"}]}], "}"}]}], ",", 
        RowBox[{"PlotRangePadding", "\[Rule]", "None"}], ",", 
        RowBox[{"FrameStyle", "\[Rule]", 
         RowBox[{"Thickness", "[", "0.004", "]"}]}], ",", 
        RowBox[{"PlotStyle", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Black", ",", 
             RowBox[{"Thickness", "[", "0.004", "]"}], ",", 
             RowBox[{"Dashing", "[", "0.01", "]"}]}], "}"}], ",", 
           RowBox[{"{", 
