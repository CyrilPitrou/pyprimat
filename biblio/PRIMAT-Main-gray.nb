Cell["\<\
We define this by default so that the user can uses the names of nuclei. This \
is overwritten whenever BuildVariables is called.\
\>", "Text",
 CellChangeTimes->{{3.6993578885233192`*^9, 3.699357901021969*^9}, {
  3.699358090844161*^9, 3.6993580965395737`*^9}, {3.700215187248361*^9, 
  3.700215187507609*^9}, {3.700217360489999*^9, 3.700217360646062*^9}, {
  3.7002176517872677`*^9, 3.700217654609886*^9}, {3.70022020757413*^9, 
  3.700220208913258*^9}, {3.715949732667901*^9, 3.715949734308297*^9}, {
  3.936391683802421*^9, 3.9363916877804317`*^9}, {3.936433283882263*^9, 
  3.936433335764492*^9}},ExpressionUUID->"c0a57b2d-8053-4c6d-b3cd-\
14104eb4f038"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ShortNames", "=", 
   RowBox[{"NamesWithWeightsAll", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "1"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"KeyVal", "=", 
   RowBox[{"Association", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"#", "\[Rule]", 
       RowBox[{
        RowBox[{"Position", "[", 
         RowBox[{"ShortNames", ",", "#"}], "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1"}], "]"}], "]"}]}], "&"}], "/@", "ShortNames"}],
     "]"}]}], ";"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.936433243708634*^9, 3.936433263066779*^9}},
 CellLabel->
  "In[2459]:=",ExpressionUUID->"99eeb131-95fa-47a8-a692-7d3ba561eb4e"],

Cell[BoxData[
 RowBox[{"BuildVariables", ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ListReactionsNames", "=", 
     RowBox[{"ListReactionsUpToChosenMass", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", "\n", 
    RowBox[{"ListNuclearReactionsNames", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"ListReactionsNames", ",", 
       RowBox[{
        RowBox[{"#", "=!=", "\"\<nTOp\>\""}], "&"}]}], "]"}]}], ";", "\n", 
    RowBox[{"(*", 
     RowBox[{
     "We", " ", "can", " ", "define", " ", "an", " ", "association", " ", 
      RowBox[{"(", 
       RowBox[{"a", " ", "dictionary"}], ")"}], " ", "between", " ", 
      "reaction", " ", "names", " ", "and", " ", "number"}], "*)"}], "\n", 
    RowBox[{"KeyNuclearReaction", "=", 
     RowBox[{"Association", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "\[Rule]", 
         RowBox[{
          RowBox[{"Position", "[", 
           RowBox[{"ListNuclearReactionsNames", ",", "#"}], "]"}], "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "1"}], "]"}], "]"}]}], "&"}], "/@", 
       "ListNuclearReactionsNames"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"KeyReaction", "=", 
     RowBox[{"Association", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "\[Rule]", 
         RowBox[{
          RowBox[{"Position", "[", 
           RowBox[{"ListReactionsNames", ",", "#"}], "]"}], "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "1"}], "]"}], "]"}]}], "&"}], "/@", 
       "ListReactionsNames"}], "]"}]}], ";", "\n", 
    RowBox[{"(*", 
     RowBox[{
     "Let", " ", "us", " ", "collect", " ", "all", " ", "the", " ", "species",
       " ", "involved", " ", "in", " ", "the", " ", 
      RowBox[{"reactions", ".", " ", "These"}], " ", "are", " ", "the", " ", 
      "species", " ", "whose", " ", "abundance", " ", "we", " ", "are", " ", 
      "going", " ", "to", " ", "solve", " ", 
      RowBox[{"numerically", "."}]}], "*)"}], "\n", 
    RowBox[{"VariablesInEquations", "=", 
     RowBox[{"Union", "@", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"RemoveNonNuclear", "[", 
            RowBox[{"#", "[", 
             RowBox[{"[", "2", "]"}], "]"}], "]"}], ",", 
           RowBox[{"RemoveNonNuclear", "[", 
            RowBox[{"#", "[", 
             RowBox[{"[", "3", "]"}], "]"}], "]"}]}], "]"}], "&"}], "/@", 
        "ListReactionsUpToChosenMass"}], "]"}]}]}], ";", "\n", 
    RowBox[{"(*", 
     RowBox[{
     "We", " ", "can", " ", "check", " ", "the", " ", "number", " ", "of", 
      " ", "species", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
        "59", " ", "for", " ", "the", " ", "full", " ", "network", " ", "of", 
         " ", "423", " ", "equations"}], ")"}], "."}]}], "*)"}], "\n", 
    RowBox[{"NumberVariable", "=", 
     RowBox[{"Length", "@", "VariablesInEquations"}]}], ";", "\n", 
    RowBox[{"(*", 
     RowBox[{
     "Let", " ", "us", " ", "collect", " ", "all", " ", "the", " ", "species",
       " ", "used", " ", "together", " ", "with", " ", "their", " ", 
      "weights", " ", "in", " ", "terms", " ", "of", " ", "neutrons", " ", 
      "and", " ", "protons"}], "*)"}], "\n", 
    RowBox[{"NamesWithWeights", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"NamesWithWeightsAll", ",", 
       RowBox[{
        RowBox[{"MemberQ", "[", 
         RowBox[{"VariablesInEquations", ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "&"}]}], "]"}]}], ";", 
    "\n", 
    RowBox[{"(*", 
     RowBox[{
     "WeightsNuclear", " ", "is", " ", "the", " ", "list", " ", "of", " ", 
      "nuclear", " ", "weights", " ", "for", " ", "the", " ", "variables", 
      " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
        "their", " ", "A", " ", "in", " ", "nuclear", " ", "physics", " ", 
         "notation"}], ")"}], ".", " ", "It"}], " ", "is", " ", "obtained", 
      " ", "by", " ", "summing", " ", "the", " ", 
      RowBox[{"(", 
       RowBox[{"n", ",", "p"}], ")"}], " ", "numbers"}], "*)"}], "\n", 
    RowBox[{"WeightsNuclear", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"Plus", "@@", 
         RowBox[{"(", 
          RowBox[{"#", "[", 
           RowBox[{"[", "2", "]"}], "]"}], ")"}]}], ")"}], "&"}], "/@", 
      "NamesWithWeights"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
      "The", " ", "list", " ", "of", " ", "all", " ", "shortnames", " ", 
       "available", " ", "is", " ", "ShortNames"}], ",", " ", 
      RowBox[{
      "and", " ", "we", " ", "associate", " ", "a", " ", "number", " ", 
       "through", " ", "a", " ", "dictionary", " ", "KeyVal"}]}], "*)"}], 
    "\n", "\n", "     ", 
    RowBox[{"ShortNames", "=", 
     RowBox[{"NamesWithWeights", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
    
    RowBox[{"KeyVal", "=", 
     RowBox[{"Association", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "\[Rule]", 
         RowBox[{
          RowBox[{"Position", "[", 
           RowBox[{"ShortNames", ",", "#"}], "]"}], "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "1"}], "]"}], "]"}]}], "&"}], "/@", 
       "ShortNames"}], "]"}]}], ";", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "We", " ", "now", " ", "build", " ", "list", " ", "of", " ", "variable", 
      " ", "in", " ", "standard", " ", "Ynipj", " ", "forms", " ", "are"}], 
     "*)"}], "\[IndentingNewLine]", 
    RowBox[{"VarList", "=", 
     RowBox[{"ToExpression", "/@", 
      RowBox[{"(", 
       RowBox[{"StackY", "/@", "ShortNames"}], ")"}]}]}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
      RowBox[{
      "Finally", " ", "for", " ", "the", " ", "abstract", " ", "reactions"}], 
      ",", " ", 
      RowBox[{
      "we", " ", "also", " ", "define", " ", "rules", " ", "to", " ", 
       "replace", " ", "the", " ", "abstract", " ", "reaction", " ", 
       RowBox[{"L", "[", "i", "]"}], " ", "or", " ", "its", " ", "reverse", 
       " ", 
       RowBox[{"Lbar", "[", "i", "]"}], " ", "by", " ", "the", " ", "actual", 
       " ", 
       RowBox[{"rate", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{"Li", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"L", "[", 
        RowBox[{"KeyReaction", "[", 
         RowBox[{"[", "#", "]"}], "]"}], "]"}], "&"}], "/@", 
      "ListReactionsNames"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Lbari", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"Lbar", "[", 
        RowBox[{"KeyReaction", "[", 
         RowBox[{"[", "#", "]"}], "]"}], "]"}], "&"}], "/@", 
      "ListReactionsNames"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"FunList", "[", "tv_", "]"}], ":=", 
      RowBox[{"SetTimeDependence", "[", 
       RowBox[{"VarList", ",", "tv"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"FunPrimeList", "[", "tv_", "]"}], ":=", 
      RowBox[{
       RowBox[{"FunList", "'"}], "[", "tv", "]"}]}], ";"}], "*)"}], 
   "\[IndentingNewLine]", ")"}]}]], "Input",
 InitializationCell->True,
