Cell[CellGroupData[{

Cell["Nuclear Statistical Equilibrium", "Subsection",
 CellChangeTimes->{{3.7175055052290983`*^9, 3.717505511565686*^9}, {
  3.7202702222681026`*^9, 
  3.720270223229328*^9}},ExpressionUUID->"dee32181-5789-48e0-9ec7-\
f2126a5eee78"],

Cell["This is Eq. A24 of companion paper.", "Text",ExpressionUUID->"46e9fbda-4d5a-419d-bc5d-b8e34f81b666"],

Cell[BoxData[
 RowBox[{
  RowBox[{"YNSE", "[", 
   RowBox[{"name_", ",", "Yn_", ",", "Yp_", ",", "Tv_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "Pair", ",", "N", ",", "A", ",", "Z", ",", "mN", ",", "A32Overmn"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"mN", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"mn", "+", "mp"}], ")"}], "/", "2"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Pair", "=", 
      RowBox[{"KeySpecies", "[", "name", "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"Z", "=", 
      RowBox[{"Pair", "[", 
       RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"N", "=", 
      RowBox[{"Pair", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"A", "=", 
      RowBox[{"Z", "+", "N"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"A32Overmn", "=", 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox[
         RowBox[{"Mass", "[", "name", "]"}], 
         RowBox[{
          SuperscriptBox["mn", 
           RowBox[{"A", "-", "Z"}]], "*", 
          SuperscriptBox["mp", "Z"]}]], ")"}], 
       RowBox[{"3", "/", "2"}]]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", "*", 
         RowBox[{"SpinKeys", "[", "name", "]"}]}], "+", "1"}], ")"}], 
      SuperscriptBox[
       RowBox[{"Zeta", "[", "3", "]"}], 
       RowBox[{"(", 
        RowBox[{"A", "-", "1"}], ")"}]], 
      SuperscriptBox["\[Pi]", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", "A"}], ")"}], "/", "2"}], ")"}]], 
      SuperscriptBox["2", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"3", "A"}], "-", "5"}], ")"}], "/", "2"}], ")"}]], 
      "A32Overmn", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"kB", " ", "Tv"}], ")"}], 
       RowBox[{"3", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"A", "-", "1"}], ")"}], "/", "2"}]}]], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"\[Eta]factorT", "[", "Tv", "]"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"A", "-", "1"}], ")"}]], 
      SuperscriptBox["Yp", "Z"], 
      SuperscriptBox["Yn", 
       RowBox[{"A", "-", "Z"}]], 
      RowBox[{"Exp", "[", 
       FractionBox[
        RowBox[{
         RowBox[{"BindingEnergy", "[", "name", "]"}], "*", "keV"}], 
        RowBox[{"kB", " ", "Tv"}]], "]"}]}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.717504272550345*^9, 3.717504503308123*^9}, {
   3.717504562482438*^9, 3.7175045675158587`*^9}, {3.7175049046018057`*^9, 
   3.717504905149528*^9}, {3.717504952123888*^9, 3.717504964811468*^9}, {
   3.71758112212117*^9, 3.717581138226132*^9}, 3.717581566949359*^9, {
