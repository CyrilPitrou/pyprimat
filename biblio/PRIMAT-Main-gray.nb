Cell[TextData[{
 "Standard abundances as reported in most BBN papers.  ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Note", " ", "the", " ", "definition", " ", 
    SubscriptBox["Y", "P"]}], " ", "=", " ", 
   RowBox[{"4", " ", 
    RowBox[{
     SubscriptBox["Y", "He4"], ".", " ", "Since"}], " ", "the", " ", "atomic",
     " ", "mass", " ", "of", " ", "Helium", " ", "is", " ", "not", " ", 
    "exactly", " ", "4", " ", "this", " ", "is", " ", "not", " ", "exactly", 
    " ", "Helium", " ", "mass", " ", "abundance"}]}]], "Text",
  InitializationCell->True,
  CellChangeTimes->{{3.6965697849287443`*^9, 3.696569794035966*^9}, {
