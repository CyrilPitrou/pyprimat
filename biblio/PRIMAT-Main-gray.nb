Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Spectral", " ", "distortions", " ", "with", " ", "Born", " ", 
    "approximation"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"IPENdpSD", "[", 
      RowBox[{"pe_", ",", "x_", ",", "znu_", ",", "sgnq_"}], "]"}], ":=", 
     RowBox[{"IPENdpFrom\[Chi]NoCCR", "[", 
      RowBox[{
       RowBox[{"enOFpe", "[", 
        RowBox[{"pe", ",", "x"}], "]"}], ",", "pe", ",", "x", ",", 
       RowBox[{"If", "[", 
        RowBox[{"$TnuEqualT", ",", "x", ",", "znu"}], "]"}], ",", "sgnq", ",",
        "\[Delta]\[Chi]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"IPENdpSDCCR", "[", 
      RowBox[{"pe_", ",", "x_", ",", "znu_", ",", "sgnq_"}], "]"}], ":=", 
     RowBox[{"IPENdpFrom\[Chi]CCR", "[", 
      RowBox[{
       RowBox[{"enOFpe", "[", 
        RowBox[{"pe", ",", "x"}], "]"}], ",", "pe", ",", "x", ",", 
       RowBox[{"If", "[", 
        RowBox[{"$TnuEqualT", ",", "x", ",", "znu"}], "]"}], ",", "sgnq", ",",
        "\[Delta]\[Chi]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Lambda]nTOpSD", "[", "Tv_", "]"}], ":=", 
     RowBox[{"IntegrateRatedp", "[", 
      RowBox[{"IPENdpSD", ",", "1", ",", "Tv"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Lambda]pTOnSD", "[", "Tv_", "]"}], ":=", 
     RowBox[{"IntegrateRatedp", "[", 
      RowBox[{"IPENdpSD", ",", 
       RowBox[{"-", "1"}], ",", "Tv"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Lambda]nTOpSDCCR", "[", "Tv_", "]"}], ":=", 
     RowBox[{"IntegrateRatedp", "[", 
      RowBox[{"IPENdpSDCCR", ",", "1", ",", "Tv"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Lambda]pTOnSDCCR", "[", "Tv_", "]"}], ":=", 
     RowBox[{"IntegrateRatedp", "[", 
      RowBox[{"IPENdpSDCCR", ",", 
       RowBox[{"-", "1"}], ",", "Tv"}], "]"}]}], ";"}]}]}]], "Input",
