   3.936367205074987*^9}, {3.936369017750938*^9, 3.936369055013803*^9}, 
   3.93636909311665*^9, {3.936369167152863*^9, 3.936369168408801*^9}, {
   3.936369391425378*^9, 3.9363693962080317`*^9}, {3.9364014890802717`*^9, 
   3.936401492647367*^9}, {3.9364076694158278`*^9, 3.9364076728167887`*^9}, {
