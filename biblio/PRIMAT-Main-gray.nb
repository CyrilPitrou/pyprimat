    RowBox[{"funcLoc_", ",", "fnamestring_"}], "]"}], ":=", 
   RowBox[{"$libDirectory", "<>", "fnamestring", "<>", "\"\<.\>\"", "<>", 
    RowBox[{
     RowBox[{"StringSplit", "[", 
      RowBox[{"funcLoc", ",", "\"\<.\>\""}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"-", "1"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
