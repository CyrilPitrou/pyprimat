             RowBox[{"Thickness", "[", "0.004", "]"}]}], "}"}]}], "}"}]}], 
        ",", 
        RowBox[{"PlotRange", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"10", "^", 
            RowBox[{"-", "3"}]}], ",", "1000"}], "}"}]}], ",", 
        RowBox[{"FrameLabel", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
          "\"\<T (\!\(\*SuperscriptBox[\(10\), \(\(8\)\(\\\ \)\)]\)K)\>\"", 
           ",", "\"\<\!\(\*SubsuperscriptBox[\(Y\), \(d\), \(NSE\)]\)      \!\
\(\*SubscriptBox[\(Y\), \(n\)]\)=\!\(\*SubsuperscriptBox[\(Y\), \(d\), \(F\)]\
\) exp[-(t-\!\(\*SubscriptBox[\(t\), \(F\)]\))/\!\(\*SubscriptBox[\(\[Tau]\), \
\(n\)]\)]\>\""}], "}"}]}], ",", 
        RowBox[{"LabelStyle", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"FontSize", "\[Rule]", "12"}], "}"}]}]}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"Graphics", "[", 
       RowBox[{"{", 
        RowBox[{"Rotate", "[", 
