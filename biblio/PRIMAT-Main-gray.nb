     RowBox[{"LoadCompiledFunction", "[", 
      RowBox[{
       RowBox[{"Hold", "[", "Fdp1dp2", "]"}], ",", 
       RowBox[{"Hold", "[", "Fdp1dp2Def", "]"}]}], "]"}], ";", "Fdp1dp2"}], 
    ")"}]}], ";"}]}], "Input",
 InitializationCell->True,
