Cell[BoxData[
 RowBox[{
  RowBox[{"Solve\[Rho]\[Nu]OFawhenID", ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Timing", "[", 
      RowBox[{
       RowBox[{"a4\[Rho]\[Nu]LogaQED", "=", 
        RowBox[{
         RowBox[{"NDSolveValue", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"bar\[Rho]aNQED", "'"}], "[", "lav", "]"}], "\[Equal]", 
              RowBox[{
               RowBox[{"1", "/", 
                RowBox[{"(", 
                 RowBox[{
                  SuperscriptBox["hbar", "3"], 
                  SuperscriptBox["clight", "5"]}], ")"}]}], 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"kB", " ", 
                  RowBox[{"aTofaCQED", "[", 
                   RowBox[{"Exp", "@", "lav"}], "]"}]}], ")"}], "^", "4"}], 
               " ", 
               RowBox[{"\[ScriptCapitalN]T", "[", 
                RowBox[{"TofaCQED", "[", 
                 RowBox[{"Exp", "@", "lav"}], "]"}], "]"}]}]}], ",", 
             RowBox[{
              RowBox[{"bar\[Rho]aNQED", "[", 
               RowBox[{"Log", "@", 
                RowBox[{"aCQED", "@", "Ti"}]}], "]"}], "\[Equal]", 
              RowBox[{"aBB", " ", 
               SuperscriptBox[
                RowBox[{"(", 
                 RowBox[{"kB", " ", 
                  RowBox[{"aTCQED", "[", "Ti", "]"}]}], ")"}], "4"], 
               FractionBox["7", "8"], "Nneu"}]}]}], "}"}], ",", 
           RowBox[{"{", "bar\[Rho]aNQED", "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"lav", ",", 
             RowBox[{"Log", "[", 
              RowBox[{"aCQED", "[", "Ti", "]"}], "]"}], ",", 
             RowBox[{"Log", "[", 
              RowBox[{"aCQED", "[", "Tf", "]"}], "]"}]}], "}"}], ",", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"Method", "\[Rule]", "\"\<StiffnessSwitching\>\""}], 
             ","}], "*)"}], 
           RowBox[{"PrecisionGoal", "\[Rule]", "13"}], ",", 
           RowBox[{"AccuracyGoal", "\[Rule]", "43"}]}], "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Timing", "[", 
      RowBox[{
       RowBox[{"a4\[Rho]\[Nu]LogaNoQED", "=", 
        RowBox[{
         RowBox[{"NDSolveValue", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"bar\[Rho]aNNoQED", "'"}], "[", "lav", "]"}], 
              "\[Equal]", 
              RowBox[{
               RowBox[{"1", "/", 
                RowBox[{"(", 
                 RowBox[{
                  SuperscriptBox["hbar", "3"], 
                  SuperscriptBox["clight", "5"]}], ")"}]}], 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"kB", " ", 
                  RowBox[{"aTofaCNoQED", "[", 
                   RowBox[{"Exp", "@", "lav"}], "]"}]}], ")"}], "^", "4"}], 
               " ", 
               RowBox[{"\[ScriptCapitalN]T", "[", 
                RowBox[{"TofaCNoQED", "[", 
                 RowBox[{"Exp", "@", "lav"}], "]"}], "]"}]}]}], ",", 
             RowBox[{
              RowBox[{"bar\[Rho]aNNoQED", "[", 
               RowBox[{"Log", "@", 
                RowBox[{"aCNoQED", "@", "Ti"}]}], "]"}], "\[Equal]", 
              RowBox[{"aBB", " ", 
               SuperscriptBox[
                RowBox[{"(", 
                 RowBox[{"kB", " ", 
                  RowBox[{"aTCNoQED", "[", "Ti", "]"}]}], ")"}], "4"], 
               FractionBox["7", "8"], "Nneu"}]}]}], "}"}], ",", 
           RowBox[{"{", "bar\[Rho]aNNoQED", "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"lav", ",", 
             RowBox[{"Log", "[", 
              RowBox[{"aCNoQED", "[", "Ti", "]"}], "]"}], ",", 
             RowBox[{"Log", "[", 
              RowBox[{"aCNoQED", "[", "Tf", "]"}], "]"}]}], "}"}], ",", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"Method", "\[Rule]", "\"\<StiffnessSwitching\>\""}], 
             ","}], "*)"}], 
           RowBox[{"PrecisionGoal", "\[Rule]", "13"}], ",", 
           RowBox[{"AccuracyGoal", "\[Rule]", "43"}]}], "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "]"}], ";"}], 
