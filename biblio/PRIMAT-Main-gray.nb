Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SimplifyReactionStringRules", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<+\>\"", "\[Rule]", "\"\< + \>\""}], ",", 
      RowBox[{"\"\<>\>\"", "\[Rule]", "\"\< > \>\""}], ",", 
      RowBox[{"\"\<;\>\"", "\[Rule]", "\"\< ; \>\""}], ",", 
      RowBox[{"\"\<2n\>\"", "\[Rule]", "\"\< n + n \>\""}], ",", 
      RowBox[{"\"\<2p\>\"", "\[Rule]", "\"\< p + p \>\""}], ",", 
      RowBox[{"\"\<2g\>\"", "\[Rule]", "\"\< g + g \>\""}], ",", " ", 
      RowBox[{"\"\<2d\>\"", "\[Rule]", "\"\< d + d \>\""}], ",", 
      RowBox[{"\"\<2a\>\"", "\[Rule]", "\"\< a + a \>\""}], ",", 
      RowBox[{"\"\<He4\>\"", "\[Rule]", "\"\< a \>\""}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ReshapheReactionString", "[", "string_String", "]"}], ":=", 
    RowBox[{"Select", "[", 
     RowBox[{
      RowBox[{"StringSplit", "[", 
       RowBox[{
        RowBox[{"StringReplace", "[", 
         RowBox[{"string", ",", "SimplifyReactionStringRules"}], "]"}], ",", 
        "\"\< \>\""}], "]"}], ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"#", "=!=", "\"\<+\>\""}], "&&", 
         RowBox[{"#", "=!=", "\"\<*-\>\""}], "&&", 
         RowBox[{"#", "=!=", "\"\<\>\""}]}], ")"}], "&"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TreatReactionString", "[", 
   RowBox[{"reac_String", ",", "source_String", ",", "f_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "reacshaped", ",", "wedgeposition", ",", "colonposition", ",", 
      "InitialParticles", ",", "FinalParticles", ",", "Name"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"reacshaped", "=", 
      RowBox[{"ReshapheReactionString", "[", "reac", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"wedgeposition", "=", 
      RowBox[{
       RowBox[{"Position", "[", 
        RowBox[{"reacshaped", ",", "\"\<>\>\""}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"colonposition", "=", 
      RowBox[{
       RowBox[{"Position", "[", 
        RowBox[{"reacshaped", ",", "\"\<;\>\""}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"InitialParticles", "=", 
      RowBox[{"Take", "[", 
       RowBox[{"reacshaped", ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", 
          RowBox[{"wedgeposition", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"FinalParticles", "=", 
      RowBox[{"Take", "[", 
       RowBox[{"reacshaped", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"wedgeposition", "+", "1"}], ",", 
          RowBox[{"colonposition", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
       "We", " ", "check", " ", "that", " ", "the", " ", "reaction", " ", 
        "is", " ", "possible"}], ",", " ", 
       RowBox[{
       "that", " ", "is", " ", "it", " ", "should", " ", "conserve", " ", "N",
         " ", "and", " ", "Z"}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{"If", " ", "not", " ", "the", " ", "case"}], ",", " ", 
       RowBox[{
       "the", " ", "code", " ", "will", " ", "violently", " ", "quit", " ", 
        "after", " ", "spitting", " ", "out", " ", "warning", " ", 
        RowBox[{"messages", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"CheckReaction", "[", 
      RowBox[{"InitialParticles", ",", "FinalParticles"}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Name", "=", 
      RowBox[{
       RowBox[{"StringJoin", "@@", 
        RowBox[{"ToString", "/@", "InitialParticles"}]}], "<>", "\"\<TO\>\"", 
       "<>", 
       RowBox[{"StringJoin", "@@", 
        RowBox[{"ToString", "/@", "FinalParticles"}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
      "Name", ",", "InitialParticles", ",", "FinalParticles", ",", 
       "NormalRealisation", ",", "source", ",", "f"}], "}"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]}], "Input",
 InitializationCell->True,
 CellLabel->
  "In[2428]:=",ExpressionUUID->"e1d99da3-d030-4108-b773-923dc438647d"],

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"PostTreatT9", "[", 
      RowBox[{"var_", ",", "funT9_"}], "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{"$InterpolateAnalytics", ",", "\[IndentingNewLine]", 
       RowBox[{"MyInterpolationRate", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"i", ",", 
            RowBox[{"var", " ", 
             RowBox[{"MyChop", "[", 
              RowBox[{"funT9", "[", 
               RowBox[{"i", "/", 
                RowBox[{"10", "^", "9"}]}], "]"}], "]"}]}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "TableInterpolationTemperature"}], "}"}]}], 
         "]"}], "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"var", " ", 
          RowBox[{"MyChop", "[", 
           RowBox[{"funT9", "[", 
            RowBox[{"#", "/", 
             RowBox[{"10", "^", "9"}]}], "]"}], "]"}]}], ")"}], "&"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"GenRateT9", "[", 
      RowBox[{"var_", ",", "funT9_"}], "]"}], ":=", 
     RowBox[{"PostTreatT9", "[", 
      RowBox[{"var", ",", "funT9"}], "]"}]}], ";"}]}]}]], "Input",
 InitializationCell->True,
 CellLabel->
  "In[2431]:=",ExpressionUUID->"50c6b94d-4331-44de-ab1f-89872cb1024c"],

Cell["\<\
This is the actual function where all analytic rates are defined. And it \
outputs the list of reactions.\
\>", "Text",
 CellDingbat->"\[FilledSquare]",
 CellChangeTimes->{{3.6999477364545927`*^9, 
  3.699947755668178*^9}},ExpressionUUID->"c04fc883-caaa-483d-8056-\
6db95381d1f2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DefineAnalyticRates", ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "f", ",", "Var", ",", "Name", ",", "\[Lambda]Reac", ",", 
       "\[Lambda]barReac", ",", "treatedreac", ",", "source", ",", "reac", 
       ",", "analyticforward", ",", "AddReaction", ",", "initialparticles", 
       ",", "finalparticles", ",", "InfoFromAudi2017", ",", "FrontFactor", 
       ",", "Qoverkb", ",", "PoweronT9", ",", "forward", ",", "reslist"}], 
      "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Most", " ", "recent", " ", "implementation", " ", "with", " ", 
       "automatic", " ", "computation", " ", "of", " ", "reverse", " ", 
       "rate"}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"AddReaction", "[", 
        RowBox[{
        "reac_String", ",", "source_String", ",", "f_", ",", "ForwardT9_", 
         ",", "BoolBackward_"}], "]"}], ":=", 
       RowBox[{"(", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"treatedreac", "=", 
          RowBox[{"TreatReactionString", "[", 
           RowBox[{"reac", ",", "source", ",", "f"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Name", "=", 
          RowBox[{"treatedreac", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", " ", 
          RowBox[{"Building", " ", "the", " ", "backward", " ", "ratio"}], 
          " ", "*)"}], "\[IndentingNewLine]", 
         RowBox[{"initialparticles", "=", 
          RowBox[{"treatedreac", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"finalparticles", "=", 
          RowBox[{"treatedreac", "[", 
           RowBox[{"[", "3", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"InfoFromAudi2017", "=", 
          RowBox[{"InfoReaction", "[", 
           RowBox[{"initialparticles", ",", "finalparticles"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"Print", "[", 
            RowBox[{
            "InitialParticles", ",", "\"\< \>\"", ",", "FinalParticles", ",", 
             "\"\< \>\"", ",", "InfoFromAudi2017"}], "]"}], ";"}], "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{"FrontFactor", "=", 
          RowBox[{"InfoFromAudi2017", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"Qoverkb", "=", 
          RowBox[{"InfoFromAudi2017", "[", 
           RowBox[{"[", "4", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"PoweronT9", "=", 
          RowBox[{"InfoFromAudi2017", "[", 
           RowBox[{"[", "3", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"(*", " ", 
          RowBox[{
          "End", " ", "of", " ", "building", " ", "backward", " ", "ratio"}], 
          " ", "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"\[Lambda]Reac", "=", 
          RowBox[{"ToExpression", "[", 
           RowBox[{"\"\<Hold@L\>\"", "<>", "Name"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"\[Lambda]barReac", "=", 
          RowBox[{"ToExpression", "[", 
           RowBox[{"\"\<Hold@Lbar\>\"", "<>", "Name"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Sow", "[", "treatedreac", "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"Var", "=", 
          RowBox[{"f", "^", 
           RowBox[{"treatedreac", "[", 
            RowBox[{"[", "4", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", 
         RowBox[{"MySet", "[", 
