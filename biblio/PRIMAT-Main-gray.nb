Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"dPe3", "[", "T_", "]"}], ":=", 
   RowBox[{
    RowBox[{"dPe3", "[", "T", "]"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", "\[Alpha]FS", ")"}], "^", 
      RowBox[{"(", 
       RowBox[{"3", "/", "2"}], ")"}]}], "*", 
     RowBox[{"(", 
      RowBox[{"4", "/", "3"}], ")"}], 
     RowBox[{"Sqrt", "[", 
      RowBox[{"2", "Pi"}], "]"}], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"kB", " ", "T"}], ")"}], "4"], 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
