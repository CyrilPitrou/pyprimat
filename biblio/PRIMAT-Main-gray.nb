Cell[CellGroupData[{

Cell["Reverse reaction information", "Subsection",
 CellChangeTimes->{{3.717819638535145*^9, 
  3.717819650274837*^9}},ExpressionUUID->"254207d9-ed7a-4cb7-90f4-\
841e7a4246a7"],

Cell["\<\
The reverse reaction depends on three constants (\[Alpha], \[Beta], \[Gamma]) \
defined in companion paper in Eq. 142. 
From the Spin, mass and binding energy we can find these constants.\
\>", "Text",ExpressionUUID->"1035cfd4-b11e-4db8-a990-7b18d15a499d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Qreaction", "[", 
    RowBox[{"ListIn_", ",", "ListOut_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Ni", "=", 
        RowBox[{"Length", "@", "ListIn"}]}], ",", 
       RowBox[{"Nf", "=", 
        RowBox[{"Length", "@", "ListOut"}]}], ",", "factorin", ",", 
       "factorout", ",", "Units"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"factorin", "=", 
       RowBox[{"Plus", "@@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"BindingEnergy", "[", "#", "]"}], ")"}], "&"}], "/@", 
          "ListIn"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"factorout", "=", 
       RowBox[{"Plus", "@@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"BindingEnergy", "[", "#", "]"}], ")"}], "&"}], "/@", 
          "ListOut"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Units", "=", "keV"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"-", "Units"}], 
       RowBox[{"(", 
        RowBox[{"factorin", "-", "factorout"}], ")"}]}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7178141360820017`*^9, 3.717814273514077*^9}, {
   3.717814447924711*^9, 3.717814449610565*^9}, 3.717815170650117*^9},
 CellLabel->
  "In[2381]:=",ExpressionUUID->"3baaa868-65c8-41b2-abed-7150ae1170e9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PowerT9", "[", 
    RowBox[{"ListIn_", ",", "ListOut_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Ni", "=", 
        RowBox[{"Length", "@", "ListIn"}]}], ",", 
       RowBox[{"Nf", "=", 
        RowBox[{"Length", "@", "ListOut"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"3", "/", "2."}], "*", 
      RowBox[{"(", 
       RowBox[{"Ni", "-", "Nf"}], ")"}]}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.717814883709282*^9, 3.7178149129481897`*^9}, 
   3.717815149708033*^9},
 CellLabel->
  "In[2382]:=",ExpressionUUID->"74f85a4d-dfd6-4630-ae03-4737c9383f0a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"FactorInverseReaction", "[", 
    RowBox[{"ListIn_", ",", "ListOut_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Ni", "=", 
        RowBox[{"Length", "@", "ListIn"}]}], ",", 
       RowBox[{"Nf", "=", 
        RowBox[{"Length", "@", "ListOut"}]}], ",", "factorin", ",", 
       "factorout", ",", "Units"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"factorin", "=", 
       RowBox[{"Times", "@@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"2", " ", 
                   RowBox[{"SpinKeys", "[", 
                    RowBox[{"#", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "+", "1"}], 
                 ")"}], 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"2", 
                   RowBox[{
                    RowBox[{"Pi", "/", 
                    RowBox[{"Mass", "[", 
                    RowBox[{"#", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "/", 
                    RowBox[{"(", 
                    RowBox[{"kB", " ", 
                    RowBox[{"10", "^", "9"}]}], ")"}]}]}], ")"}], "^", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"-", "3"}], "/", "2"}], ")"}]}]}], ")"}], "^", 
              RowBox[{"(", 
               RowBox[{"#", "[", 
                RowBox[{"[", "2", "]"}], "]"}], ")"}]}], "/", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "2", "]"}], "]"}], "!"}], ")"}]}], ")"}], "&"}], 
          "/@", 
          RowBox[{"(", 
           RowBox[{"Tally", "@", "ListIn"}], ")"}]}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"factorout", "=", 
       RowBox[{"Times", "@@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"2", " ", 
                   RowBox[{"SpinKeys", "[", 
                    RowBox[{"#", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "+", "1"}], 
                 ")"}], 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"2", 
                   RowBox[{
                    RowBox[{"Pi", "/", 
                    RowBox[{"Mass", "[", 
                    RowBox[{"#", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "/", 
                    RowBox[{"(", 
                    RowBox[{"kB", " ", 
                    RowBox[{"10", "^", "9"}]}], ")"}]}]}], ")"}], "^", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"-", "3"}], "/", "2"}], ")"}]}]}], ")"}], "^", 
              RowBox[{"(", 
               RowBox[{"#", "[", 
                RowBox[{"[", "2", "]"}], "]"}], ")"}]}], "/", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "2", "]"}], "]"}], "!"}], ")"}]}], ")"}], "&"}], 
          "/@", 
          RowBox[{"(", 
           RowBox[{"Tally", "@", "ListOut"}], ")"}]}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Units", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"ma", "/", 
            RowBox[{"clight", "^", "2"}]}], ")"}], "/", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"hbar", " ", "clight"}], ")"}], "^", "3"}]}], ")"}], "^", 
        
        RowBox[{"(", 
         RowBox[{"Ni", "-", "Nf"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"factorin", "/", " ", "factorout"}], " ", "Units"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.717813296647108*^9, 3.717813311600706*^9}, {
  3.717813361276043*^9, 3.717813590641451*^9}, {3.717813667511178*^9, 
  3.717813694980289*^9}, {3.717814741387458*^9, 3.71781480703903*^9}, {
