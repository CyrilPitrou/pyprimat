Cell[CellGroupData[{

Cell["Gathering integrations on all periods in one function", "Section",
 CellChangeTimes->{{3.7226280375363293`*^9, 3.722628055752345*^9}, {
  3.72268723737062*^9, 
  3.722687241049088*^9}},ExpressionUUID->"b39c5007-e1c0-446d-abc8-\
f089483d9311"],

Cell["\<\
We define an interpolation of the results. We join the results from high, \
middle and low temperature eras. This is joined in the function 

YI[\[OpenCurlyDoubleQuote]key\[CloseCurlyDoubleQuote]][time] where key is the \
name of the nuclide (e.g. \[OpenCurlyDoubleQuote]a\[CloseCurlyDoubleQuote] \
for He4, \[OpenCurlyDoubleQuote]t\[CloseCurlyDoubleQuote] for tritium and \
\[OpenCurlyDoubleQuote]d\[CloseCurlyDoubleQuote] for deuterium but otherwise \
\[OpenCurlyDoubleQuote]Li7\[CloseCurlyDoubleQuote], \
\[OpenCurlyDoubleQuote]C12\[CloseCurlyDoubleQuote] etc...).\
\>", "Text",ExpressionUUID->"3297213c-d1b3-408b-9fd9-7b2b9baf2edf"],

Cell[BoxData[
 RowBox[{
  RowBox[{"InterpolateResults", ":=", 
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Clear", "[", 
      RowBox[{"Yall", ",", "YI"}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Yall", "[", 
       RowBox[{"key_", "?", "KeyQ"}], "]"}], ":=", 
      RowBox[{
       RowBox[{"Yall", "[", "key", "]"}], "=", 
       RowBox[{"Function", "[", 
        RowBox[{
         RowBox[{"{", "tv", "}"}], ",", 
         RowBox[{"Piecewise", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"Y", "[", "\"\<HT\>\"", "]"}], "[", "key", "]"}], "[",
                "tv", "]"}], ",", 
              RowBox[{"tv", "<", "tmiddle"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"Y", "[", "\"\<MT\>\"", "]"}], "[", "key", "]"}], "[",
                "tv", "]"}], ",", 
              RowBox[{
               RowBox[{"tv", "<", "t18"}], "&&", 
               RowBox[{"tv", ">=", "tmiddle"}]}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"Y", "[", "\"\<LT\>\"", "]"}], "[", "key", "]"}], "[",
                "tv", "]"}], ",", 
              RowBox[{
               RowBox[{"tv", "<=", "tend"}], "&&", 
               RowBox[{"tv", ">=", "t18"}]}]}], "}"}]}], "}"}], "]"}]}], 
        "]"}]}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"YI", "[", 
       RowBox[{"key_", "?", "KeyQ"}], "]"}], ":=", 
      RowBox[{
       RowBox[{"YI", "[", "key", "]"}], "=", 
       RowBox[{"Interpolation", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"tv", ",", 
             RowBox[{
              RowBox[{"Yall", "[", "key", "]"}], "[", "tv", "]"}]}], "}"}], 
           ",", 
           RowBox[{"{", 
            RowBox[{"tv", ",", 
             RowBox[{"Join", "[", 
              RowBox[{"tHT", ",", 
               RowBox[{"Rest", "@", "tMT"}], ",", 
               RowBox[{"Rest", "@", "tLT"}]}], "]"}]}], "}"}]}], "]"}], ",", 
         RowBox[{"InterpolationOrder", "\[Rule]", "1"}]}], "]"}]}]}], ";"}], 
    ")"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.936397443956875*^9, 3.9363974547425222`*^9}, 
   3.936397548738124*^9},
 CellLabel->
  "In[2541]:=",ExpressionUUID->"c85ba854-ab52-4a5c-bb47-7e94a99532b0"],

Cell[BoxData[
 RowBox[{"InterpolateResults", ";"}]], "Input",
 CellLabel->
  "In[2542]:=",ExpressionUUID->"c34adbc7-44a9-47f2-9172-6b680ddb0f09"],

Cell["\<\
The function RunNumericalIntegrals below performs the integrations of \
incomplete neutrino decoupling
and then the Friedmann equation integration.
Then it defines the nuclear reactions, possibly having introduced uncertainty \
on rates depending on options, 
and solves for the high, middle and low temperature era. 
This is the Driver of PRIMAT which needs to be called whenever we rerun \
PRIMAT with new parameters (e.g. exploring dependence in baryons or \
neutrinos).\
\>", "Text",ExpressionUUID->"d2a72700-89fc-4b02-ba89-7f952468e4e6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"RunNumericalIntegralsNuclearReactions", ":=", 
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{"Middle", " ", "temperature", " ", "integration"}], " ", "*)"}], 
    "\[IndentingNewLine]", " ", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{"$Verbose", ",", 
       RowBox[{"Print", "[", 
        RowBox[{
        "\"\< Launching middle temperatures, with only the lightest elements, \
from T=\>\"", ",", "TMiddle", ",", "\"\<(K) to T=\>\"", ",", "T18", ",", 
         "\"\<(K)\>\""}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "SolveValueMiddleTemperatures", ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{"Low", " ", "temperature", " ", "integration"}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{"$Verbose", ",", 
       RowBox[{"Print", "[", 
        RowBox[{
        "\"\< Launching low temperatures, with all elements, from T=\>\"", 
         ",", "T18", ",", "\"\<(K) to T=\>\"", ",", "Tend", ",", 
         "\"\<(K)\>\""}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "SolveValueLowTemperatures", ";"}], "\[IndentingNewLine]", ")"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.698482902889802*^9, 3.698482903074573*^9}, {
   3.6984831152402363`*^9, 3.698483193847485*^9}, {3.69848363147342*^9, 
   3.698483670741968*^9}, {3.698484662720364*^9, 3.698484692192534*^9}, {
   3.698484875275259*^9, 3.698484875745953*^9}, {3.698488699482767*^9, 
   3.6984887012123632`*^9}, {3.6996138623084707`*^9, 3.699613883458496*^9}, {
   3.699694100647065*^9, 3.699694115710478*^9}, {3.699698369919157*^9, 
   3.699698384476474*^9}, {3.6996991316792517`*^9, 3.699699132924425*^9}, {
   3.69976939170261*^9, 3.6997694564616756`*^9}, {3.6998158975526867`*^9, 
   3.699815913197035*^9}, {3.6998531085211163`*^9, 3.6998531732420177`*^9}, {
   3.699854175010599*^9, 3.699854198144642*^9}, {3.699854671362863*^9, 
   3.6998546763074636`*^9}, 3.699860651020768*^9, {3.6998871010462627`*^9, 
   3.6998871036889133`*^9}, {3.715956233276729*^9, 3.715956234891129*^9}, {
   3.9363282228134727`*^9, 3.936328229754616*^9}, {3.936328450413885*^9, 
   3.9363284571964684`*^9}, {3.936328589907666*^9, 3.9363285932643642`*^9}, {
   3.93633553825569*^9, 3.9363355383819942`*^9}, {3.936664618783736*^9, 
   3.9366646544017467`*^9}, {3.9366647502572937`*^9, 3.936664795626237*^9}},
 CellLabel->
  "In[2543]:=",ExpressionUUID->"1b5a379e-df91-481d-91f3-688ffc9e84e3"],

Cell[BoxData[
 RowBox[{"RunBackgroundThermo", ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"time", "=", 
     RowBox[{
      RowBox[{"Timing", "[", 
       RowBox[{"LoadPlasma", ";"}], "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Timing for plasma is\>\"", ",", "time"}], "]"}], ";"}], 
     "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"time", "=", 
     RowBox[{
      RowBox[{"Timing", "[", 
       RowBox[{"If", "[", 
        RowBox[{"$NEVO", ",", "LoadNEVO"}], "]"}], "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Timing for loading NEVO is\>\"", ",", "time"}], "]"}], 
      ";"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
    "LoadDistortions", ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
      RowBox[{
      "In", " ", "case", " ", "of", " ", "incomplete", " ", "neutrino", " ", 
       "decoupling"}], ",", " ", 
      RowBox[{
      "we", " ", "recompute", " ", "all", " ", "the", " ", "integrations", 
       " ", "a", 
       RowBox[{"(", "T", ")"}], " ", "then", " ", "inversion", " ", "T", 
       RowBox[{"(", "a", ")"}]}], ",", " ", 
      RowBox[{"then", " ", 
       SubscriptBox["\[Rho]", "\[Nu]"], 
       RowBox[{
        RowBox[{"(", "a", ")"}], "."}]}]}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{"$IncompleteNeutrinoDecoupling", ",", 
      RowBox[{"RecomputeIncompleteNeutrinoDecoupling", ";"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
      "In", " ", "case", " ", "the", " ", "plasma", " ", "conditions", " ", 
       "have", " ", "changed", " ", "in", " ", "a", " ", "MC", " ", 
       "exploration"}], ",", " ", 
      RowBox[{
      "we", " ", "recompute", " ", "the", " ", "inversion", " ", "of", " ", 
       RowBox[{"a", "[", "T", "]"}]}]}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
      RowBox[{
      "This", " ", "is", " ", "needed", " ", "if", " ", "we", " ", "have", 
       " ", "recomputed", " ", "the", " ", "neutrino", " ", "decoupling"}], 
      ",", " ", 
      RowBox[{
      "but", " ", "I", " ", "am", " ", "wondering", " ", "if", " ", "this", 
       " ", "is", " ", "always", " ", 
       RowBox[{"needed", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
    "InvertaOFT", ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{"$Verbose", ",", 
      RowBox[{
       RowBox[{"Print", "[", "\"\<Infer a<->t relations\>\"", "]"}], ";"}]}], 
     "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
     "scale", " ", "factor", " ", "integration", " ", "from", " ", 
      "Friedmann", " ", 
      RowBox[{"equation", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
    "Computetofa", ";", "\[IndentingNewLine]", "Computeaoft", ";"}], 
   "\[IndentingNewLine]", ")"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.936616964820112*^9, 3.93661697518509*^9}, {
   3.936617015122328*^9, 3.9366170331202602`*^9}, 3.936617064127572*^9},
 CellLabel->
  "In[2544]:=",ExpressionUUID->"a3be2a60-3c40-4b7a-bcd9-64095bbbd13d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"RunNumericalIntegrals", ":=", 
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{"$Verbose", ",", "\"\<Checking Options.\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", "CheckOptions", ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", "RunBackgroundThermo", ";", "\[IndentingNewLine]",
      "\[IndentingNewLine]", "LoadWeakRates", ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{"Build", " ", 
       RowBox[{"equations", ".", " ", "Needed"}], " ", "since", " ", "rate", 
       " ", "are", " ", "modified", " ", "randomly", " ", "by", " ", "the", 
       " ", "f", " ", "factor", " ", "of", " ", "each", " ", "reaction"}], 
      "*)"}], "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{"$Verbose", ",", 
       RowBox[{
        RowBox[{
        "Print", "[", "\"\<Loading nuclear rates and building reactions.\>\"",
          "]"}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", "LoadRatesFull", 
     ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{"$Verbose", ",", 
       RowBox[{"Print", "[", 
        RowBox[{"MyGrid", "[", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"{", 
             RowBox[{
             "\"\<Reaction Number\>\"", ",", "\"\<Reaction Name\>\"", ",", 
              "\"\<Initial species\>\"", ",", "\"\<Final Species\>\"", ",", 
              "\"\<Reference\>\""}], "}"}], "}"}], ",", 
           RowBox[{"PadLeftNumberRowFromZero", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Drop", "[", 
               RowBox[{"#", ",", 
                RowBox[{"{", "4", "}"}]}], "]"}], "&"}], "/@", 
             RowBox[{"(", 
              RowBox[{
              "NiceDisplayReaction", "/@", "ListReactionsUpToChosenMass"}], 
              ")"}]}], "]"}]}], "]"}], "]"}], "]"}]}], "]"}], ";", 
