Cell[CellGroupData[{

Cell["QED modified relativistic degrees of freedom ", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{{3.698030933447967*^9, 3.69803094673423*^9}, {
  3.716005595697619*^9, 3.716005597079631*^9}, {3.716369140196299*^9, 
