Cell["\<\
This is the solver for the inverse function, that is for da/dt, giving a(t)\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.694751160214758*^9, 3.694751176466654*^9}, {
  3.6998158219357843`*^9, 3.699815824158242*^9}, {3.699849617874919*^9, 
