         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"zNEVORescale", "[", "fn", "]"}], "*", " ", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"T", "\[GreaterEqual]", "Tgmax"}], ",", 
            RowBox[{
             RowBox[{"zNEVOofT", "[", "fn", "]"}], "[", "Tgmax", "]"}], ",", 
            RowBox[{"If", "[", 
