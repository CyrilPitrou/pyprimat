       RowBox[{"RV", "=", 
        RowBox[{"Import", "[", "RVfile", "]"}]}], ";"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"Cosmofile", "=", 
      RowBox[{
      "$ResultsDirectory", "<>", "\"\<Cosmo\>\"", "<>", "File", "<>", 
       "\"\<.dat\>\""}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Cosmo", "=", 
      RowBox[{"Import", "[", "Cosmofile", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"TMC", "=", 
      RowBox[{"Transpose", "[", "MC", "]"}]}], ";"}], "\[IndentingNewLine]", 
    ")"}]}], ";"}]}], "Input",
