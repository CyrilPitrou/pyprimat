Cell["\<\
Whenever a Monte-Carlo is finished, or loaded, we can obtain the table of \
values for a given element, or a given reaction\
\>", "Text",
 CellChangeTimes->{{3.7226879167402687`*^9, 
  3.722687950095561*^9}},ExpressionUUID->"a961fbfb-55df-42ea-a9ff-\
c50c682f6dfc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ElementColumn", "[", "el_", "]"}], ":=", 
   RowBox[{"MC", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", 
      RowBox[{"KeyVal", "[", 
       RowBox[{"[", "el", "]"}], "]"}]}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ReactionColumn", "[", "el_", "]"}], ":=", 
   RowBox[{"RV", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", 
      RowBox[{"KeyNuclearReaction", "[", "el", "]"}]}], "]"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"h2\[CapitalOmega]b0List", ":=", 
   RowBox[{"Cosmo", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "1"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Tau]neutronList", ":=", 
   RowBox[{"Cosmo", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.699888472755859*^9, 3.699888568573728*^9}, {
   3.6998885997439537`*^9, 3.699888607248598*^9}, 3.699892178853861*^9, {
   3.7002210338590803`*^9, 3.700221037439067*^9}, 3.715956578169876*^9, 
   3.719923896887396*^9, {3.7199250253513527`*^9, 3.719925026936667*^9}},
 CellLabel->
  "In[2594]:=",ExpressionUUID->"09447937-81af-418e-a30d-f1940e3e1dd7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "I", " ", "think", " ", "this", " ", "function", " ", "is", " ", "never", 
    " ", 
    RowBox[{"used", " ", "!"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ReSetCosmology", ":=", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
      "Meanh2\[CapitalOmega]b0", "=", "Meanh2\[CapitalOmega]b0Planck"}], ";", 
      " ", "\[IndentingNewLine]", 
      RowBox[{"NeutrinosGenerations", "=", "3"}], ";", "\[IndentingNewLine]", 
      
      RowBox[{"Nrelat", "=", "0"}], ";"}], 
     RowBox[{"(*", " ", 
      RowBox[{"Not", " ", "sure", " ", "this", " ", "is", " ", 
       RowBox[{"needed", "."}]}], " ", "*)"}], "\[IndentingNewLine]", ")"}]}],
    ";"}]}]], "Input",
