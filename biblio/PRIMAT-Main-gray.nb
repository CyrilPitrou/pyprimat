          RowBox[{"Text", "[", 
           RowBox[{
            RowBox[{"Style", "[", 
             RowBox[{"\"\<0.066 MeV\>\"", ",", 
              RowBox[{"FontSize", "\[Rule]", "10"}], ",", "Black"}], "]"}], 
            ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{"Log", "@", "Tnuc"}], "-", "0.015"}], ",", "2"}], 
             "}"}]}], "]"}], ",", 
          RowBox[{"90", " ", "Degree"}]}], "]"}], "}"}], "]"}]}], "]"}]}], 
