Cell["\<\
The grid in comoving momentum (variable y = a p), is stored in the file \
NEVOGrid which has been loaded in FileGrid \
\>", "Text",ExpressionUUID->"4437955e-307d-4056-8e7f-bd911514e3ef"],

Cell[BoxData["LoadNEVOGrid"], "Input",
 CellChangeTimes->{3.936355822921011*^9},
 CellLabel->
  "In[1916]:=",ExpressionUUID->"d68a730b-9bdb-4828-b0b4-1f29c7b663eb"],

Cell["\<\
If QED effects are taken into account, we import results from a NEVO \
simulation incorporating the same QED corrections to the pressure and the \
energy density (but not to the weak rates of the reactions relevant from \
neutrino decoupling, as it results in a higher order effect).\
\>", "Text",
 CellChangeTimes->{{3.782799311459034*^9, 3.782799363163158*^9}, {
   3.782799397427043*^9, 3.782799427124404*^9}, {3.782799495316697*^9, 
   3.7827995508449697`*^9}, {3.782799621974224*^9, 3.7827999225997334`*^9}, {
   3.782800344188129*^9, 3.782800548349637*^9}, {3.7828006078940477`*^9, 
   3.782800633955887*^9}, {3.782800673644404*^9, 3.782800767885181*^9}, 
   3.782808543811873*^9},ExpressionUUID->"85bb89d3-c682-4f1d-94e3-\
1de7ac69750c"],

Cell[TextData[{
 "In NEVO, the \[OpenCurlyDoubleQuote]time\[CloseCurlyDoubleQuote] variable \
(proxy for the scale factor) is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "NEVO"], "\[Proportional]", 
    RowBox[{
     SubscriptBox["m", "e"], "a"}]}], TraditionalForm]],ExpressionUUID->
  "98b57671-3d57-4361-b3d9-061d876364b6"],
 ", while in PRIMAT we have used the notation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", 
    RowBox[{"1", "/", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["k", "B"], "T"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"6201441d-e008-4abf-acbf-6ac956ea9acf"],
 ".\nTo avoid possible confusion we explicitly use xNEVO below. \nSee e.g. \
[Froustey et al. 2020] for historical definitions of x, y, z in the context \
of neutrino decoupling ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    SubscriptBox["y", "NEVO"]}], TraditionalForm]],ExpressionUUID->
  "d455b35d-57df-441b-a149-e836ea484a58"],
 " = a p and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["z", "NEVO"], TraditionalForm]],ExpressionUUID->
  "54b78289-19ca-498d-95c8-5e45b246e9ed"],
 "= a ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["T", "\[Gamma]"], TraditionalForm]],ExpressionUUID->
  "19670045-9515-4158-a89a-468801eec5c6"],
 "), but this notation is standard in neutrino decoupling literature."
}], "Text",
 CellChangeTimes->{
  3.809770001022314*^9, {3.935569625828795*^9, 
   3.9355696263931513`*^9}},ExpressionUUID->"9db9fa24-d52e-4354-b6d1-\
dc30c2750425"],

Cell["\<\
A function to read the actual NEVO results and perform all needed \
interpolations :\
\>", "Text",
 CellChangeTimes->{{3.937275027916147*^9, 
  3.937275043797802*^9}},ExpressionUUID->"7d31137b-33c2-400d-b189-\
802708c54bb1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TreatNEVOFile", "[", "fn_", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"TableNEVO", " ", "=", 
     RowBox[{"TableNEVOLoaded", "[", "fn", "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"First", " ", "column", " ", "of", " ", 
      RowBox[{"NEVO", ".", "cvs"}], " ", "file", " ", "is", " ", "xNEVO"}], 
     "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"xNEVO", "[", "fn", "]"}], "=", 
     RowBox[{"TableNEVO", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
    
    RowBox[{"(*", " ", 
     RowBox[{"Second", " ", "column", " ", "is", " ", "zNEVO"}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"zNEVO", "[", "fn", "]"}], "=", 
     RowBox[{"TableNEVO", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
    
    RowBox[{"(*", " ", 
     RowBox[{
     "By", " ", "definition", " ", "the", " ", "temperature", " ", "of", " ", 
      "photons", " ", "is", " ", "related", " ", 
      RowBox[{"by", " ", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"T\[Gamma]NEVO", "[", "fn", "]"}], "=", 
     RowBox[{"me", "*", 
      RowBox[{
       RowBox[{
        RowBox[{"zNEVO", "[", "fn", "]"}], "/", 
        RowBox[{"xNEVO", "[", "fn", "]"}]}], "/", "kB"}]}]}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
      RowBox[{
      "The", " ", "heating", " ", "function", " ", "\[ScriptCapitalN]"}], ",",
       " ", 
      RowBox[{"is", " ", "the", " ", "6", "th", " ", "column"}]}], " ", 
     "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"HeatingNNEVO", "[", "fn", "]"}], "=", 
     RowBox[{"TableNEVO", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "6"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
    
    RowBox[{
     RowBox[{"\[ScriptCapitalN]NEVO", "[", "fn", "]"}], "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"me", "/", 
           RowBox[{"(", 
            RowBox[{"kB", " ", 
             RowBox[{"T\[Gamma]NEVO", "[", "fn", "]"}]}], ")"}]}], ",", 
          RowBox[{"HeatingNNEVO", "[", "fn", "]"}]}], "}"}], "]"}], ",", 
       RowBox[{"InterpolationOrder", "\[Rule]", "1"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
       RowBox[{"TcomNEVO", "[", "fn", "]"}], "=", 
       RowBox[{
        RowBox[{"me", "/", 
         RowBox[{"xNEVO", "[", "fn", "]"}]}], "/", "kB"}]}], ";"}], "*)"}], 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"T\[Gamma]max", "[", "fn", "]"}], "=", 
     RowBox[{"First", "[", 
      RowBox[{"T\[Gamma]NEVO", "[", "fn", "]"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"T\[Gamma]min", "[", "fn", "]"}], "=", 
     RowBox[{"Last", "[", 
      RowBox[{"T\[Gamma]NEVO", "[", "fn", "]"}], "]"}]}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"T\[Gamma]OFxNEVO", "[", "fn", "]"}], "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"xNEVO", "[", "fn", "]"}], ",", 
          RowBox[{"T\[Gamma]NEVO", "[", "fn", "]"}]}], "}"}], "]"}], ",", 
       RowBox[{"InterpolationOrder", "\[Rule]", "1"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"Columns", " ", "3"}], ",", " ", "4", ",", " ", 
      RowBox[{
      "and", " ", "5", " ", "are", " ", "the", " ", "effective", " ", 
       "temperatures", " ", "of", " ", "nu_e"}], ",", " ", 
      RowBox[{"nu_mu", " ", "and", " ", "nu_tau"}]}], " ", "*)"}], "\n", 
    "     ", 
    RowBox[{
     RowBox[{"T\[Nu]e", "[", "fn", "]"}], "=", 
     RowBox[{
      RowBox[{"TableNEVO", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "3"}], "]"}], "]"}], "*", 
      RowBox[{
       RowBox[{"me", "/", 
        RowBox[{"xNEVO", "[", "fn", "]"}]}], "/", "kB"}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"T\[Nu]\[Mu]", "[", "fn", "]"}], "=", 
     RowBox[{
      RowBox[{"TableNEVO", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "4"}], "]"}], "]"}], "*", 
      RowBox[{
       RowBox[{"me", "/", 
        RowBox[{"xNEVO", "[", "fn", "]"}]}], "/", "kB"}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"T\[Nu]\[Tau]", "[", "fn", "]"}], "=", 
     RowBox[{
      RowBox[{"TableNEVO", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "5"}], "]"}], "]"}], "*", 
      RowBox[{
       RowBox[{"me", "/", 
        RowBox[{"xNEVO", "[", "fn", "]"}]}], "/", "kB"}]}]}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
      RowBox[{
      "We", " ", "build", " ", "interpolation", " ", "functions", " ", "of", 
       " ", "these", " ", "neutrino", " ", "temperatures"}], ",", " ", 
      RowBox[{"as", " ", "function", " ", "of", " ", 
       RowBox[{"photon", "/", "plasma"}], " ", "temperature"}]}], " ", "*)"}],
     "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
       RowBox[{"T\[Nu]eOFT\[Gamma]NEVO", "[", "fn", "]"}], "=", 
       RowBox[{"Interpolation", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"T\[Gamma]NEVO", "[", "fn", "]"}], ",", 
            RowBox[{"T\[Nu]e", "[", "fn", "]"}]}], "}"}], "]"}], ",", 
         RowBox[{"InterpolationOrder", "\[Rule]", "1"}]}], "]"}]}], ";"}], 
     "*)"}], "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
       RowBox[{"T\[Nu]\[Mu]OFT\[Gamma]NEVO", "[", "fn", "]"}], "=", 
       RowBox[{"Interpolation", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"T\[Gamma]NEVO", "[", "fn", "]"}], ",", 
            RowBox[{"T\[Nu]\[Mu]", "[", "fn", "]"}]}], "}"}], "]"}], ",", 
         RowBox[{"InterpolationOrder", "\[Rule]", "1"}]}], "]"}]}], ";"}], 
     "*)"}], "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
       RowBox[{"T\[Nu]\[Tau]OFT\[Gamma]NEVO", "[", "fn", "]"}], "=", 
       RowBox[{"Interpolation", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"T\[Gamma]NEVO", "[", "fn", "]"}], ",", 
            RowBox[{"T\[Nu]\[Tau]", "[", "fn", "]"}]}], "}"}], "]"}], ",", 
         RowBox[{"InterpolationOrder", "\[Rule]", "1"}]}], "]"}]}], ";"}], 
     "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
       RowBox[{"T\[Nu]eOFxNEVO", "[", "fn", "]"}], "=", 
       RowBox[{"Interpolation", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"xNEVO", "[", "fn", "]"}], ",", 
            RowBox[{"T\[Nu]e", "[", "fn", "]"}]}], "}"}], "]"}], ",", 
         RowBox[{"InterpolationOrder", "\[Rule]", "1"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"T\[Nu]\[Mu]OFxNEVO", "[", "fn", "]"}], "=", 
       RowBox[{"Interpolation", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"xNEVO", "[", "fn", "]"}], ",", 
            RowBox[{"T\[Nu]\[Mu]", "[", "fn", "]"}]}], "}"}], "]"}], ",", 
         RowBox[{"InterpolationOrder", "\[Rule]", "1"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"T\[Nu]\[Tau]OFxNEVO", "[", "fn", "]"}], "=", 
       RowBox[{"Interpolation", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"xNEVO", "[", "fn", "]"}], ",", 
            RowBox[{"T\[Nu]\[Tau]", "[", "fn", "]"}]}], "}"}], "]"}], ",", 
         RowBox[{"InterpolationOrder", "\[Rule]", "1"}]}], "]"}]}], ";"}], 
     "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
      "We", " ", "build", " ", "the", " ", "ratio", " ", "of", " ", "the", 
       " ", "nu_e", " ", "temperature", " ", "with", " ", "the", " ", 
       "photon", " ", "temperature"}], ",", " ", 
      RowBox[{
      "as", " ", "a", " ", "function", " ", "of", " ", "the", " ", "photon", 
       " ", "temperature"}]}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"T\[Nu]eOverT\[Gamma]OFT\[Gamma]NEVO", "[", "fn", "]"}], "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"T\[Gamma]NEVO", "[", "fn", "]"}], ",", 
          RowBox[{
           RowBox[{"T\[Nu]e", "[", "fn", "]"}], "/", 
           RowBox[{"T\[Gamma]NEVO", "[", "fn", "]"}]}]}], "}"}], "]"}], ",", 
       RowBox[{"InterpolationOrder", "\[Rule]", "1"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
     "We", " ", "avoid", " ", "issues", " ", "when", " ", "outside", " ", 
      "of", " ", "the", " ", "interpolation", " ", "range"}], " ", "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"T\[Nu]eOverT\[Gamma]OFT\[Gamma]NEVOS", "[", "fn", "]"}], "[", 
      RowBox[{"T_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Tgmax", "=", 
          RowBox[{"T\[Gamma]max", "[", "fn", "]"}]}], ",", 
         RowBox[{"Tgmin", "=", 
          RowBox[{"T\[Gamma]min", "[", "fn", "]"}]}]}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"T", "\[GreaterEqual]", "Tgmax"}], ",", 
         RowBox[{
          RowBox[{"T\[Nu]eOverT\[Gamma]OFT\[Gamma]NEVO", "[", "fn", "]"}], 
          "[", "Tgmax", "]"}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"T", "\[GreaterEqual]", "Tgmin"}], ",", 
           RowBox[{
            RowBox[{"T\[Nu]eOverT\[Gamma]OFT\[Gamma]NEVO", "[", "fn", "]"}], 
            "[", "T", "]"}], ",", 
           RowBox[{
            RowBox[{"T\[Nu]eOverT\[Gamma]OFT\[Gamma]NEVO", "[", "fn", "]"}], 
            "[", "Tgmin", "]"}]}], "]"}]}], " ", "]"}]}], " ", "]"}]}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
      RowBox[{
      "We", " ", "also", " ", "build", " ", "the", " ", "same", " ", "type", 
       " ", "of", " ", "ratio"}], ",", " ", 
      RowBox[{
      "but", " ", "with", " ", "the", " ", "average", " ", "temperature", " ",
        "of", " ", "neutrinos"}]}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"T\[Nu]AverageOverT\[Gamma]OFT\[Gamma]NEVO", "[", "fn", "]"}], 
     "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"T\[Gamma]NEVO", "[", "fn", "]"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"1", "/", "3"}], "*", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                 RowBox[{"T\[Nu]e", "[", "fn", "]"}], "^", "4"}], "+", 
                RowBox[{
                 RowBox[{"T\[Nu]\[Mu]", "[", "fn", "]"}], "^", "4"}], "+", 
                RowBox[{
                 RowBox[{"T\[Nu]\[Tau]", "[", "fn", "]"}], "^", "4"}]}], 
               ")"}]}], ")"}], "^", 
            RowBox[{"(", 
             RowBox[{"1", "/", "4"}], ")"}]}], "/", 
           RowBox[{"T\[Gamma]NEVO", "[", "fn", "]"}]}]}], "}"}], "]"}], ",", 
       RowBox[{"InterpolationOrder", "\[Rule]", "1"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"T\[Nu]AverageOverT\[Gamma]OFxNEVO", "[", "fn", "]"}], "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"xNEVO", "[", "fn", "]"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"1", "/", "3"}], "*", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                 RowBox[{"T\[Nu]e", "[", "fn", "]"}], "^", "4"}], "+", 
                RowBox[{
                 RowBox[{"T\[Nu]\[Mu]", "[", "fn", "]"}], "^", "4"}], "+", 
                RowBox[{
                 RowBox[{"T\[Nu]\[Tau]", "[", "fn", "]"}], "^", "4"}]}], 
               ")"}]}], ")"}], "^", 
            RowBox[{"(", 
             RowBox[{"1", "/", "4"}], ")"}]}], "/", 
           RowBox[{"T\[Gamma]NEVO", "[", "fn", "]"}]}]}], "}"}], "]"}], ",", 
       RowBox[{"InterpolationOrder", "\[Rule]", "1"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"T\[Nu]AverageOverT\[Gamma]OFT\[Gamma]NEVOS", "[", "fn", "]"}], 
      "[", 
      RowBox[{"T_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Tgmax", "=", 
          RowBox[{"T\[Gamma]max", "[", "fn", "]"}]}], ",", 
         RowBox[{"Tgmin", "=", 
          RowBox[{"T\[Gamma]min", "[", "fn", "]"}]}]}], "}"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"T", "\[GreaterEqual]", "Tgmax"}], ",", 
         RowBox[{
          RowBox[{
          "T\[Nu]AverageOverT\[Gamma]OFT\[Gamma]NEVO", "[", "fn", "]"}], "[", 
          "Tgmax", "]"}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"T", "\[GreaterEqual]", "Tgmin"}], ",", 
           RowBox[{
            RowBox[{
            "T\[Nu]AverageOverT\[Gamma]OFT\[Gamma]NEVO", "[", "fn", "]"}], 
            "[", "T", "]"}], ",", 
           RowBox[{
            RowBox[{
            "T\[Nu]AverageOverT\[Gamma]OFT\[Gamma]NEVO", "[", "fn", "]"}], 
            "[", "Tgmin", "]"}]}], "]"}]}], " ", "]"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
     "xNEVO", " ", "as", " ", "a", " ", "function", " ", "of", " ", "the", 
      " ", "inverse", " ", "neutrino", " ", 
      RowBox[{"temperature", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
       RowBox[{"xNEVOof\[Beta]", "[", "fn", "]"}], "=", 
       RowBox[{"Interpolation", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"me", "/", 
             RowBox[{"(", 
              RowBox[{"kB", " ", 
               RowBox[{"T\[Nu]e", "[", "fn", "]"}]}], ")"}]}], ",", 
            RowBox[{"xNEVO", "[", "fn", "]"}]}], "}"}], "]"}], ",", 
         RowBox[{"InterpolationOrder", "\[Rule]", "1"}]}], "]"}]}], ";"}], 
     "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"xNEVOofT", "=", 
       RowBox[{"Interpolation", "@", 
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{"T\[Gamma]NEVO", ",", "xNEVO"}], "}"}], "]"}]}]}], ";"}], 
     "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
       RowBox[{"zNEVOofT", "[", "fn", "]"}], "=", 
       RowBox[{"Interpolation", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"T\[Gamma]NEVO", "[", "fn", "]"}], ",", 
            RowBox[{"zNEVO", "[", "fn", "]"}]}], "}"}], "]"}], ",", 
         RowBox[{"InterpolationOrder", "\[Rule]", "1"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"zNEVORescale", "[", "fn", "]"}], "=", 
       RowBox[{"TCMB0", "/", 
        RowBox[{
         RowBox[{"zNEVOofT", "[", "fn", "]"}], "[", 
         RowBox[{"T\[Gamma]min", "[", "fn", "]"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"zNEVOofTSafe", "[", "fn", "]"}], "[", 
