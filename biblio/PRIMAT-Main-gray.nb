 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", "8"], TraditionalForm]],ExpressionUUID->
  "228cdf87-6d9e-426b-aa08-e86203a870c2"],
 " K it should be the case."
}], "Text",
