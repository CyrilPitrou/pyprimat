               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"FDp", "[", 
                   RowBox[{"e2", ",", "x"}], "]"}], 
                  FractionBox["p2", "p1"], 
                  FractionBox[
                   SuperscriptBox["e1", "2"], "e2"], 
                  RowBox[{"(", 
