Cell["\<\
So that now we can decide to use either the full decoupling or the incomplete \
decoupling neutrino temperature, depending on the options chosen\
\>", "Text",
 CellChangeTimes->{{3.700561640612377*^9, 3.700561663975296*^9}, {
  3.700562254772539*^9, 
  3.700562273176731*^9}},ExpressionUUID->"65915590-427d-4f7e-804a-\
c882402c9ebc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"T\[Nu]AverageoverT", "[", "T_", "]"}], ":=", 
    RowBox[{"If", "[", 
     RowBox[{"$IncompleteNeutrinoDecoupling", ",", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{"$Taverage\[ScriptCapitalN]", ",", 
        RowBox[{"T\[Nu]overTIncompleteDecoupling", "[", "T", "]"}], ",", 
        RowBox[{"If", "[", 
         RowBox[{"$NEVO", ",", 
          RowBox[{
          "T\[Nu]AverageOverT\[Gamma]OFT\[Gamma]NEVOSafe", "[", "T", "]"}], 
          ",", 
          RowBox[{"T\[Nu]overTIncompleteDecoupling", "[", "T", "]"}]}], 
         "]"}]}], "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"T\[Nu]overTDecoupling", "[", "T", "]"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"T\[Nu]overT", "[", "Tv_", "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{"$IncompleteNeutrinoDecoupling", ",", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"$TrueT\[Nu]e", "&&", "$NEVO"}], ",", 
       RowBox[{"T\[Nu]eOverT\[Gamma]OFT\[Gamma]NEVOSafe", "[", "Tv", "]"}], 
       ",", 
       RowBox[{"T\[Nu]AverageoverT", "[", "Tv", "]"}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"T\[Nu]overTDecoupling", "[", "Tv", "]"}]}], 
    "\[IndentingNewLine]", " ", "]"}]}], ";"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.936399548817359*^9, 3.936399626564719*^9}, {
  3.936399662390292*^9, 3.936399662840124*^9}, {3.9363996973192377`*^9, 
  3.936399700022542*^9}},
 CellLabel->
