Cell[BoxData[{
 RowBox[{"If", "[", 
  RowBox[{"$PaperPlots", ",", 
   RowBox[{"ListLogLogPlot", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"T", ",", 
         RowBox[{
          RowBox[{"1", "/", 
           RowBox[{"T", "^", "4"}]}], 
          RowBox[{"\[Rho]tot", "[", "T", "]"}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"T", ",", "ListT"}], "}"}]}], "]"}], ",", 
     RowBox[{"Frame", "\[Rule]", "True"}], ",", 
     RowBox[{"Joined", "\[Rule]", "True"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", "Black"}], ",", 
     RowBox[{"FrameLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
       "\"\<T (K)\>\"", ",", 
        "\"\<\!\(\*SuperscriptBox[\(T\), \(-4\)]\)\[Rho](T)    g \
\!\(\*SuperscriptBox[\(cm\), \(-3\)]\)\!\(\*SuperscriptBox[\(K\), \(-4\)]\)\>\
\""}], "}"}]}]}], "]"}]}], "]"}], "\[IndentingNewLine]", 
