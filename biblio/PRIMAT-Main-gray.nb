           RowBox[{"en", "<", "0"}], "&&", 
           RowBox[{"sgnq", "<", "0"}], "&&", 
           RowBox[{"x", ">=", "zminD"}], "&&", 
           RowBox[{"x", "<=", "zmaxD"}]}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"dFDneue4p1", "[", 
          RowBox[{
           RowBox[{"en_", "?", "NumericQ"}], ",", "\[Phi]_", ",", "x_", ",", 
           "znu_", ",", "sgnq_"}], "]"}], ":=", 
         RowBox[{"0", "/;", 
          RowBox[{
           RowBox[{"x", "<", "zminD"}], "||", 
           RowBox[{"x", ">", "zmaxD"}]}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"SetAttributes", "[", 
         RowBox[{"dFDneue4p1", ",", "Listable"}], "]"}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";"}]}], "]"}], "\[IndentingNewLine]", 
  "*)"}]], "Input",
