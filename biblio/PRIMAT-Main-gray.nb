Cell["\<\
This function selects the names of the species which all have the same mass \
number A\
\>", "Text",
 CellChangeTimes->{{3.7159425454848843`*^9, 
  3.715942560476961*^9}},ExpressionUUID->"11865beb-69a9-4050-b509-\
5537ce3eccf0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"NamesMassNumberAll", "[", "A_", "]"}], ":=", 
  RowBox[{
   RowBox[{"Select", "[", 
    RowBox[{"NamesWithWeightsAll", ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Plus", "@@", 
          RowBox[{"(", 
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}], ")"}]}], ")"}], "\[Equal]", "A"}],
        ")"}], "&"}]}], "]"}], "[", 
   RowBox[{"[", 
    RowBox[{"All", ",", "1"}], "]"}], "]"}]}]], "Input",
 InitializationGroup->True,
 CellChangeTimes->{{3.700892420262961*^9, 3.700892423360758*^9}},
 CellLabel->
  "In[2333]:=",ExpressionUUID->"19f6cea8-85a8-4c3f-adc1-e1201fcd8a9c"]
}, Open  ]],

