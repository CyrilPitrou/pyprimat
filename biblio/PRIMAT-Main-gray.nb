Cell["\<\
We build tools  to restrict the nuclides up to a maximum mass. Useless if \
MaximumNuclearMass has been set to Infinity.\
\>", "Text",
 CellChangeTimes->{{3.700892660268135*^9, 3.700892670590803*^9}, {
  3.715949073507998*^9, 3.715949092858328*^9}, {3.936391453643002*^9, 
  3.936391459550296*^9}},ExpressionUUID->"57642a2c-aa96-41e4-8824-\
abf2d8f21a67"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SpeciesUpToMaximumMass", "[", "A_Integer", "]"}], ":=", 
   RowBox[{
    RowBox[{"SpeciesUpToMaximumMass", "[", "A", "]"}], "=", 
    RowBox[{"Union", "@@", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"NamesMassNumberAll", "[", "i", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "A"}], "}"}]}], "]"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"NonBaryonicParticle", "[", "key_", "]"}], ":=", 
   RowBox[{
    RowBox[{"key", "==", "\"\<g\>\""}], "||", 
    RowBox[{"key", "==", "\"\<Bm\>\""}], "||", 
    RowBox[{"key", "==", "\"\<Bm\>\""}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ReactionUpToMaximumMass", "[", "A_Integer", "]"}], "[", 
    "Reaction_List", "]"}], ":=", 
   RowBox[{"And", "@@", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"MemberQ", "[", 
          RowBox[{
           RowBox[{"SpeciesUpToMaximumMass", "[", "A", "]"}], ",", "#"}], 
          "]"}], "||", 
         RowBox[{"NonBaryonicParticle", "[", "#", "]"}]}], ")"}], "&"}], "/@", 
      RowBox[{"Flatten", "@", 
       RowBox[{"Reaction", "[", 
        RowBox[{"[", 
         RowBox[{"2", ";;", "3"}], "]"}], "]"}]}]}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ListReactionsUpToMass", "[", 
    RowBox[{"A_Integer", ",", "ListReactions_List"}], "]"}], ":=", 
   RowBox[{"Select", "[", 
    RowBox[{"ListReactions", ",", 
     RowBox[{
      RowBox[{
       RowBox[{"ReactionUpToMaximumMass", "[", "A", "]"}], "[", "#", "]"}], 
      "&"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ListReactionsUpToMass", "[", 
    RowBox[{"Infinity", ",", "ListReactions_List"}], "]"}], ":=", 
   "ListReactions"}], ";"}]}], "Input",
 InitializationCell->True,
