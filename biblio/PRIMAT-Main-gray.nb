Cell[CellGroupData[{

Cell["Importation of reactions from external files (336 reactions)", \
"Subsection",
 CellChangeTimes->{{3.699385122497916*^9, 3.699385134648065*^9}, {
  3.6999460448645277`*^9, 3.699946061338974*^9}, {3.7003880869102287`*^9, 
  3.700388112281958*^9}, {3.7003881824564667`*^9, 3.700388191227186*^9}, {
  3.7227582272003927`*^9, 
  3.7227582321855707`*^9}},ExpressionUUID->"a7b3d8dc-f1c7-4289-b2b8-\
a4f8e68e4608"],

Cell["\<\
We collect tools to read the reactions from the external file. This is low \
level code... because we need to deal with syntax.\
\>", "Text",
 CellChangeTimes->{{3.7226978053538103`*^9, 
  3.7226978366995697`*^9}},ExpressionUUID->"5202fca7-0c22-428f-a8c4-\
62b14e8a8d3f"],

Cell["\<\
This function constructs the reverse reaction. Its arguments are the name of \
the reverse reaction, the front factor, the power on T9 and the Q of the \
reaction.\
\>", "Text",
 CellChangeTimes->{{3.699358780002651*^9, 3.6993587892577677`*^9}, {
  3.7159425783968897`*^9, 
  3.7159426096370077`*^9}},ExpressionUUID->"b4c715c2-fc1f-43c4-b2ce-\
46319c2cb525"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ReverseReaction", "[", 
     RowBox[{
     "Name_", ",", "FrontFactor_", ",", "PoweronT9_", ",", "Qoverkb_"}], 
     "]"}], ":=", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Reversname", "=", 
         RowBox[{"ToExpression", "[", 
          RowBox[{"\"\<Hold@Lbar\>\"", "<>", "Name"}], "]"}]}], ",", 
        RowBox[{"name", "=", 
         RowBox[{"Evaluate", "[", 
          RowBox[{"Symbol", "[", 
           RowBox[{"\"\<L\>\"", "<>", "Name"}], "]"}], "]"}]}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"FrontFactor", ">", "0"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"MySet", "[", 
          RowBox[{"Reversname", ",", 
           RowBox[{"Function", "[", 
            RowBox[{
             RowBox[{"{", "Tvr", "}"}], ",", 
             RowBox[{"With", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"T9", "=", 
                 RowBox[{"Tvr", "/", "Giga"}]}], "}"}], ",", 
               RowBox[{"FrontFactor", 
                SuperscriptBox[
                 RowBox[{"(", "T9", ")"}], "PoweronT9"], "*", 
                RowBox[{"Exp", "[", 
                 FractionBox["Qoverkb", "T9"], "]"}], "*", 
                RowBox[{"name", "[", "Tvr", "]"}]}]}], "]"}]}], "]"}]}], 
          "]"}], ";"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"MySet", "[", 
          RowBox[{"Reversname", ",", 
           RowBox[{"Function", "[", 
            RowBox[{
             RowBox[{"{", "Tvr", "}"}], ",", "0"}], "]"}]}], "]"}], ";"}]}], 
       "\[IndentingNewLine]", "]"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.699355921970496*^9, 3.699355932694563*^9}, {
   3.6993559821689796`*^9, 3.699356035016048*^9}, {3.699356097045679*^9, 
   3.69935618686909*^9}, {3.699356763963914*^9, 3.699356764250771*^9}, {
   3.699357195388633*^9, 3.699357226480956*^9}, 3.699363578616158*^9, {
   3.6997781085207443`*^9, 3.699778109493577*^9}, {3.699814260761485*^9, 
   3.699814266183416*^9}, {3.69986759855626*^9, 3.699867641235333*^9}, {
   3.6998949122558527`*^9, 3.699894953333109*^9}, {3.6999338207870197`*^9, 
   3.699933842645252*^9}, {3.722697771138308*^9, 3.722697778291054*^9}},
 CellLabel->
  "In[2415]:=",ExpressionUUID->"d6cdbeaf-f562-4f76-af03-31f07b9f3e47"],

Cell["\<\
We need a tool which replaces \"2a\", by \"a,a\" in the description of the \
reaction. Hence a reaction with identical particles in the initial or final \
states X (e.g. something which gives two neutrons) can be written X + X or 2 \
X.\
\>", "Text",ExpressionUUID->"6d0fe72e-d399-4517-9ed0-e13ee5c2c998"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ListSimplificationNotation", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<He4\>\"", "\[Rule]", "\"\<a\>\""}], ",", 
     RowBox[{"\"\<H3\>\"", "\[Rule]", "\"\<t\>\""}], ",", 
     RowBox[{"\"\<H2\>\"", "\[Rule]", "\"\<d\>\""}], ",", 
     RowBox[{"\"\<H1\>\"", "\[Rule]", "\"\<p\>\""}]}], "}"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellLabel->
  "In[2416]:=",ExpressionUUID->"1173d064-e47c-4da2-a70f-026259bb1b5a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ReplaceMultipleElement", "[", "str_String", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"first", ",", "rest", ",", "rule"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"StringLength", "[", "str", "]"}], "\[Equal]", "1"}], ",", 
      "str", ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"first", "=", 
        RowBox[{
         RowBox[{"StringTake", "[", 
          RowBox[{"str", ",", "1"}], "]"}], "//", "ToExpression"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"NumericQ", "[", "first", "]"}], ",", "\[IndentingNewLine]", 
         
         RowBox[{
          RowBox[{"rest", "=", 
           RowBox[{"StringDrop", "[", 
            RowBox[{"str", ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"rule", "=", 
           RowBox[{"str", "\[RuleDelayed]", 
            RowBox[{"Sequence", "@@", 
             RowBox[{"Table", "[", 
              RowBox[{"rest", ",", "first"}], "]"}]}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"str", "/.", "rule"}]}], ",", "\[IndentingNewLine]", 
         "str"}], "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
   "\[IndentingNewLine]", "]"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ReplaceMultipleElementList", "[", "list_List", "]"}], ":=", 
   RowBox[{"ReplaceMultipleElement", "/@", "list"}]}], ";"}]}], "Input",
 InitializationCell->True,
 CellLabel->
  "In[2417]:=",ExpressionUUID->"a59cc5d5-2871-45be-9ac5-7cea51ce6831"],

