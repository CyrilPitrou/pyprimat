Cell["\<\
Order of numerical scheme for Backward Differentiation Scheme (BDS) \
integration. 
-Order 1 works well but is slow. 
-Order 2 (advised) is faster. Higher orders result in numerical crash.\
\>", "Text",
 InitializationCell->
  True,ExpressionUUID->"4d36dc8e-a04f-4eb5-acea-e041c126b8ae"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PrecisionNDSolve", "=", "2"}], ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "Put", " ", "2", " ", "here", " ", "is", " ", "the", " ", "best", " ", 
    "choice"}], " ", "*)"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.937020281603258*^9, 3.9370202818319397`*^9}, {
  3.937020342965218*^9, 3.937020342980445*^9}},
 CellLabel->
  "In[1811]:=",ExpressionUUID->"140cabd0-5450-45a4-aea1-7d34ba64ecdf"],

Cell[TextData[{
 "PrecisionNDSolve is a precision parameter used in the differential equation \
solver. It is tuned such that 0 gives reasonable results, 1 gets very good \
results, and 2 gets excellent results and 3 gets super dupper precise results \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox["10", 
      RowBox[{"-", "5"}]], " ", "precision"}]}], TraditionalForm]],
  ExpressionUUID->"b56f1d5e-0845-4eaa-894d-f48b6b684a77"],
 ")."
}], "Text",
