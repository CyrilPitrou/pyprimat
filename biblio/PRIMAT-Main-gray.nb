Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{
    RowBox[{"YDistortionNeutrinos", "[", 
     RowBox[{"y_", ",", "\[Xi]_"}], "]"}], "=", 
    RowBox[{"Simplify", "[", 
     RowBox[{
      RowBox[{"1", "/", 
       RowBox[{"y", "^", "2"}]}], " ", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "^", "4"}], 
         RowBox[{"D", "[", 
          RowBox[{
           FractionBox["1", 
            RowBox[{
             RowBox[{"Exp", "[", 
              RowBox[{"y", "-", "\[Xi]"}], "]"}], "+", "1"}]], ",", "y"}], 
          "]"}]}], ",", "y"}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"YDistortionAntineutrinos", "[", 
     RowBox[{"y_", ",", "\[Xi]_"}], "]"}], "=", 
    RowBox[{"Simplify", "[", 
     RowBox[{
      RowBox[{"1", "/", 
       RowBox[{"y", "^", "2"}]}], " ", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "^", "4"}], 
         RowBox[{"D", "[", 
          RowBox[{
           FractionBox["1", 
            RowBox[{
             RowBox[{"Exp", "[", 
              RowBox[{"y", "+", "\[Xi]"}], "]"}], "+", "1"}]], ",", "y"}], 
          "]"}]}], ",", "y"}], "]"}]}], "]"}]}], ";"}], "*)"}]], "Input",
 InitializationCell->True,
