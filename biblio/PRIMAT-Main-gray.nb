    RowBox[{"T1_", ",", "T2_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"T1", "^", "4"}], "+", 
        RowBox[{"T2", "^", "4"}]}], ")"}], "/", "2"}], ")"}], "^", 
    RowBox[{"(", 
     RowBox[{"1", "/", "4"}], ")"}]}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"LoadNEVOTemperature", ":=", 
  RowBox[{"(", 
   RowBox[{"If", "[", 
