Cell["\<\
We can also extend this integration with only weak interactions to much later \
times to see what would happen without nuclear reactions.
This is only to perform plots in the paper.\
\>", "Text",
 CellChangeTimes->{{3.7191210269913073`*^9, 3.719121054736063*^9}, 
   3.722700163994226*^9, {3.722759425719233*^9, 
   3.72275943925769*^9}},ExpressionUUID->"2fcf7656-68a6-4a8d-968f-\
d9b9b37303fc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SolveValueHighTemperaturesYnOnly", ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Thread", "[", 
      RowBox[{"MySet", "[", 
       RowBox[{
        RowBox[{"Evaluate", "[", 
         RowBox[{"HoldYNames", "[", "\"\<WeakInteractionsOnly\>\"", "]"}], 
         "]"}], ",", "\[IndentingNewLine]", 
        RowBox[{"NDSolveValue", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Flatten", "@", 
           RowBox[{"Join", "[", 
            RowBox[{
             RowBox[{"SystemEquationsHT", "[", "tv", "]"}], ",", 
             RowBox[{"InitialConditionsHT", "[", "t0", "]"}]}], "]"}]}], ",", 
          "\[IndentingNewLine]", "VarList", ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"tv", ",", "t0", ",", "tend"}], "}"}], ",", 
          RowBox[{"PrecisionGoal", "\[Rule]", 
           RowBox[{"8", "+", "PrecisionNDSolve"}]}], ",", 
          RowBox[{"AccuracyGoal", "\[Rule]", "11"}], 
          RowBox[{"(*", " ", "11", "*)"}], ",", "\[IndentingNewLine]", 
          RowBox[{"InterpolationOrder", "\[Rule]", "InterpOrder"}]}], "]"}]}],
        "]"}], "]"}], ";"}], "\[IndentingNewLine]", ")"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.719120852744725*^9, 3.7191208640586653`*^9}, {
  3.719120896099424*^9, 3.719120896516164*^9}, {3.719120939182332*^9, 
  3.719120939326694*^9}, {3.719120974268017*^9, 3.719120987569648*^9}, {
  3.7191210767995787`*^9, 3.7191210785533447`*^9}, {3.9363278346378202`*^9, 
  3.936327852220759*^9}, {3.936329153188486*^9, 3.936329154086977*^9}},
 CellLabel->
  "In[2527]:=",ExpressionUUID->"5ecf2d46-e475-4593-8581-4d3bafee4c89"],

Cell[BoxData[
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{"$ResultsPlots", ",", 
    RowBox[{"SolveValueHighTemperaturesYnOnly", ";"}]}], "]"}], 
  ";"}]], "Input",
