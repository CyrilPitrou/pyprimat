e51655cbacb4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"I\[Lambda]FMBasic", "[", "pe_", "]"}], ":=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
