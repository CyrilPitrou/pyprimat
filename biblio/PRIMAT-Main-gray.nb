Cell[BoxData[
 RowBox[{"ComputeWeakRates", ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "time", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Off", "[", 
      StyleBox[
       RowBox[{"NIntegrate", "::", "slwcon"}], "MessageName"], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Off", "[", 
      StyleBox[
       RowBox[{"General", "::", "munfl"}], "MessageName"], " ", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Off", "[", 
      RowBox[{"NIntegrate", "::", "izero"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{"$RecomputeWeakRates", ",", 
       RowBox[{
       "Print", "[", 
        "\"\<The $RecomputeWeakRates option forces a recomputation of weak \
rates.\>\"", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Computing weak rates for n<->p conversions.\>\"", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"time", "=", 
      RowBox[{
       RowBox[{"Timing", "[", 
        RowBox[{
         RowBox[{"TabRatenp", "=", 
          RowBox[{"MyTableWeakRate", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"T", ",", 
              RowBox[{"\[Lambda]nTOpNormalized", "[", "T", "]"}]}], "}"}], 
            ",", 
            RowBox[{"{", 
             RowBox[{"T", ",", "ListT"}], "}"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"TabRatepn", "=", 
          RowBox[{"MyTableWeakRate", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"T", ",", 
              RowBox[{"\[Lambda]pTOnNormalized", "[", "T", "]"}]}], "}"}], 
            ",", 
            RowBox[{"{", 
             RowBox[{"T", ",", "ListT"}], "}"}]}], "]"}]}], ";"}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{"$Verbose", ",", 
       RowBox[{
        RowBox[{"Print", "[", 
         RowBox[{
         "\"\<Time spent in (re)computing weak rates was \>\"", ",", "time", 
          ",", "\"\< s\>\""}], "]"}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Export", "[", 
      RowBox[{"NamePENFilenp", ",", "TabRatenp", ",", "\"\<TSV\>\""}], "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"Export", "[", 
      RowBox[{"NamePENFilepn", ",", "TabRatepn", ",", "\"\<TSV\>\""}], "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"On", "[", 
      StyleBox[
       RowBox[{"General", "::", "munfl"}], "MessageName"], " ", "]"}], ";", 
     RowBox[{"On", "[", 
      StyleBox[
       RowBox[{"NIntegrate", "::", "slwcon"}], "MessageName"], "]"}], ";", 
     RowBox[{"On", "[", 
      RowBox[{"NIntegrate", "::", "izero"}], "]"}], ";"}]}], "]"}]}]], "Input",\

 InitializationCell->True,
 CellChangeTimes->{{3.9371916180672617`*^9, 3.937191646111223*^9}, {
  3.937191893599284*^9, 3.937191909334515*^9}},
 CellLabel->
  "In[2312]:=",ExpressionUUID->"e7a83ada-0d0e-434e-863b-2707a41ea1bd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"LoadWeakRates", ":=", 
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Not", "@", 
         RowBox[{"FileExistsQ", "[", "NamePENFilenp", "]"}]}], "||", 
        RowBox[{"Not", "@", 
         RowBox[{"FileExistsQ", "[", "NamePENFilepn", "]"}]}], "||", 
        "$RecomputeWeakRates"}], ",", "\[IndentingNewLine]", 
       RowBox[{"ComputeWeakRates", ";"}], ",", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{"$Verbose", ",", 
          RowBox[{
           RowBox[{
           "Print", "[", "\"\<Loading weak rates for n<->p conversions.\>\"", 
            "]"}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"TabRatenp", "=", 
         RowBox[{"Import", "[", 
          RowBox[{"NamePENFilenp", ",", "\"\<TSV\>\""}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"TabRatepn", "=", 
         RowBox[{"Import", "[", 
          RowBox[{"NamePENFilepn", ",", "\"\<TSV\>\""}], "]"}]}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Lambda]nTOpI", "=", 
      RowBox[{"MyInterpolationRate", "[", 
       RowBox[{"ToExpression", "[", "TabRatenp", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Lambda]pTOnI", "=", 
      RowBox[{"MyInterpolationRate", "[", 
       RowBox[{"ToExpression", "[", "TabRatepn", "]"}], "]"}]}], ";"}], 
    "\[IndentingNewLine]", ")"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.936368043010901*^9, 3.936368173262063*^9}, {
