Cell["\<\
For nuclear reactions, the mass density of baryons is in fact a number \
density of species multiplied by the atomic mass (see appendix C1 of \
companion paper for a detailed discussion). 
This differs slightly from the mass density of baryons and we take this into \
account.\
\>", "Text",ExpressionUUID->"af8417ac-769b-4b4e-a2f1-ee9cd5212662"],

Cell["\<\
If $CorrectBaryonsEnergyDensityinBBNRRates is set to False, then we use the \
baryons density naively in nuclear rates. 
Otherwise we take into account that the baryons density is in fact the number \
density times the atomic mass as explained in App. C1 of the companion Phys. \
Rept. paper.\
\>", "Text",
 CellChangeTimes->{{3.937274807566828*^9, 
  3.937274809562216*^9}},ExpressionUUID->"d2fc8ee1-bd12-4824-99bf-\
69f9e3cfa8eb"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$CorrectBaryonsEnergyDensityinBBNRRates", "=", "True"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Rho]BForBBN", "[", "av_", "]"}], ":=", 
    RowBox[{
     RowBox[{"\[Rho]B", "[", "av", "]"}], 
     RowBox[{"If", "[", 
      RowBox[{"$CorrectBaryonsEnergyDensityinBBNRRates", ",", 
       RowBox[{"ma", "/", "mbaryon0"}], ",", "1"}], "]"}]}]}], ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{"This", " ", "is", " ", 
    RowBox[{"Eq", ".", " ", "C8"}], " ", "of", " ", "the", " ", "companion", 
    " ", "paper"}], " ", "*)"}]}]}], "Input",
 InitializationCell->True,
 CellLabel->
  "In[1873]:=",ExpressionUUID->"7538b65a-b46f-429f-b38d-a17071401dcf"]
}, Open  ]],

