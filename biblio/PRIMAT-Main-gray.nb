Cell[CellGroupData[{

Cell["Check reaction coherence (formal conservation of N and Z)", "Subsection",ExpressionUUID->"1835da1a-921c-4d0f-b698-8ae17ca550e2"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"CheckReaction", "[", 
    RowBox[{"{", 
     RowBox[{"ListIn_", ",", "ListOut_"}], "}"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Znet", ",", "Nnet", ",", "Anet"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Znet", "=", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"Plus", "@@", 
          RowBox[{"(", 
           RowBox[{"Zi", "/@", "ListIn"}], ")"}]}]}], "+", 
        RowBox[{"Plus", "@@", 
         RowBox[{"(", 
          RowBox[{"Zi", "/@", "ListOut"}], ")"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Nnet", "=", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"Plus", "@@", 
          RowBox[{"(", 
           RowBox[{"Ni", "/@", "ListIn"}], ")"}]}]}], "+", 
        RowBox[{"Plus", "@@", 
         RowBox[{"(", 
          RowBox[{"Ni", "/@", "ListOut"}], ")"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Anet", "=", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"Plus", "@@", 
          RowBox[{"(", 
           RowBox[{"Ai", "/@", "ListIn"}], ")"}]}]}], "+", 
        RowBox[{"Plus", "@@", 
         RowBox[{"(", 
          RowBox[{"Ai", "/@", "ListOut"}], ")"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Print", "[", 
         RowBox[{
         "ListIn", ",", "\"\< \>\"", ",", "ListOut", ",", "\"\< \>\"", ",", 
          "Znet", ",", "Nnet", ",", "Anet"}], "]"}], ";"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Znet", "=!=", "0"}], "||", 
         RowBox[{"Nnet", "=!=", "0"}], "||", 
         RowBox[{"Anet", "=!=", "0"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{
          "\"\<ERROR! This reaction \>\"", ",", "ListIn", ",", "\"\< -> \>\"",
            ",", "ListOut", ",", 
           "\"\< is not possible.\\nThe net result for Z, N and A are \>\"", 
           ",", "Znet", ",", "\"\< \>\"", ",", "Nnet", ",", "\"\< \>\"", ",", 
           "Anet"}], "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{
         "MessageDialog", "[", 
          "\"\<A reaction is not possible. Kernel has been aborted.\>\"", 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", "\"\<We abort the evaluation !\>\"", "]"}], 
         ";", "\[IndentingNewLine]", 
         RowBox[{"Beep", "[", "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"Quit", "[", "]"}], ";"}]}], "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
         "TODO", " ", "Maybe", " ", "a", " ", "better", " ", "handling", " ", 
          "of", " ", "errors", " ", "than", " ", "just", " ", "a", " ", 
          "violent", " ", 
          RowBox[{"Quit", "[", "]"}]}], "..."}], " ", "*)"}], 
       "\[IndentingNewLine]", "]"}], ";"}]}], "\[IndentingNewLine]", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CheckReaction", "[", 
   RowBox[{"ListIn_", ",", "ListOut_"}], "]"}], ":=", 
  RowBox[{"CheckReaction", "[", 
   RowBox[{"{", 
    RowBox[{"ListIn", ",", "ListOut"}], "}"}], "]"}]}]}], "Input",
 InitializationCell->True,
 CellLabel->
  "In[2389]:=",ExpressionUUID->"7e4995d3-fd0c-4f26-a949-e41233d3d538"],

