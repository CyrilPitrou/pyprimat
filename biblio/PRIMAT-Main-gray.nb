                RowBox[{"[", 
                 RowBox[{"xi", ",", 
                  RowBox[{"Table", "[", 
                   RowBox[{
                    RowBox[{"6", "+", "i"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"i", ",", "1", ",", "GS"}], "}"}]}], "]"}]}], 
                 "]"}], "]"}]}], "}"}], "]"}], "]"}], "[", "LinearGrid", 
           "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"xi", ",", "1", ",", 
            RowBox[{"Lengthxrange", "[", "fn", "]"}]}], "}"}]}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
         "And", " ", "we", " ", "then", " ", "use", " ", "these", " ", 
          "interpolations", " ", "to", " ", "resample", " ", "the", " ", 
          "spectrum", " ", "at", " ", "each", " ", "xNEVO"}], ",", " ", 
         RowBox[{"on", " ", "a", " ", "linear", " ", "grid", " ", "of", " ", 
          RowBox[{"y", "."}]}]}], "*)"}], "\n", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{"The", " ", "Log", 
