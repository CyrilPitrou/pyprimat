Cell["\<\
Actual solver. It solves the system and affects the results to the functions \
YHT[\[OpenCurlyDoubleQuote]n\[CloseCurlyDoubleQuote]] (neutrons) and YHT[\
\[OpenCurlyDoubleQuote]p\[CloseCurlyDoubleQuote]] (protons) which are \
functions of time.\
\>", "Text",
 CellChangeTimes->{{3.715954966330755*^9, 
  3.715955005306699*^9}},ExpressionUUID->"9f416596-34e2-4a0a-a120-\
9dfaae3b3fc9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SolveValueHighTemperatures", ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Thread", "[", 
      RowBox[{"MySet", "[", 
       RowBox[{
        RowBox[{"Evaluate", "[", 
         RowBox[{"HoldYNames", "[", "\"\<HT\>\"", "]"}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"NDSolveValue", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Flatten", "@", 
           RowBox[{"Join", "[", 
            RowBox[{
             RowBox[{"SystemEquationsHT", "[", "tv", "]"}], ",", 
             RowBox[{"InitialConditionsHT", "[", "t0", "]"}]}], "]"}]}], ",", 
          "\[IndentingNewLine]", "VarList", ",", 
          RowBox[{"{", 
           RowBox[{"tv", ",", "t0", ",", "tmiddle"}], "}"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"PrecisionGoal", "\[Rule]", 
           RowBox[{"8", "+", "PrecisionNDSolve"}]}], ",", 
          RowBox[{"AccuracyGoal", "\[Rule]", "11"}], ",", 
          RowBox[{"InterpolationOrder", "\[Rule]", "InterpOrder"}]}], "]"}]}],
        "]"}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"tHT", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Y", "[", "\"\<HT\>\"", "]"}], "[", "\"\<n\>\"", "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"3", ",", "1"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]",
     ")"}]}], ";"}]], "Input",
 InitializationCell->True,
