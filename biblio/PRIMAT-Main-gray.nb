 CellLabel->
  "In[1973]:=",ExpressionUUID->"32ef8133-5a72-46b0-82f4-e2bae90f0d74"],

Cell["\<\
We check the high temperature limits (Eq. 54 of companion paper)\
\>", "Text",
 InitializationCell->
  True,ExpressionUUID->"29f7d425-fc9e-4136-844a-5440ab9bde27"],

