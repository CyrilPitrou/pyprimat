Cell[BoxData[
 RowBox[{
  RowBox[{"FillReactionMatrix", "[", "listreac_List", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "Tab", ",", "i", ",", "j", ",", "nvar", ",", "TreatReaction", ",", 
      "FactorInitialElements"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"nvar", "=", 
      RowBox[{"Length", "@", "VarList"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Tab", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"ii", ",", "1", ",", "nvar"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"FactorInitialElements", "[", "el_List", "]"}], ":=", 
      RowBox[{"Times", "@@", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"A\[Rho]B", "/", "DensityUnit"}], " ", 
              RowBox[{"Y", "[", 
               RowBox[{"KeyVal", "[", 
                RowBox[{"#", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}]}], ")"}], "^", 
            RowBox[{"#", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], "/", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"#", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "!"}], ")"}]}], "&"}], "/@", 
         "el"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"TreatReaction", "[", "reaction_List", "]"}], ":=", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"InitialParticles", "=", 
           RowBox[{"Tally", "[", 
            RowBox[{"RemoveNonNuclear", "@", 
             RowBox[{"reaction", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"FinalParticles", "=", 
           RowBox[{"Tally", "[", 
            RowBox[{"RemoveNonNuclear", "@", 
             RowBox[{"reaction", "[", 
              RowBox[{"[", "3", "]"}], "]"}]}], "]"}]}], ",", 
          "\[IndentingNewLine]", "ReactionForward", ",", "ReactionBackward", 
          ",", "FactorInitialForward", ",", "FactorInitialBackward"}], "}"}], 
        ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"ReactionForward", "=", 
          RowBox[{"L", "[", 
           RowBox[{"KeyReaction", "[", 
            RowBox[{"reaction", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"ReactionBackward", "=", 
          RowBox[{"Lbar", "[", 
           RowBox[{"KeyReaction", "[", 
            RowBox[{"reaction", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"FactorInitialForward", "=", 
          RowBox[{"FactorInitialElements", "@", "InitialParticles"}]}], ";", 
         RowBox[{"(*", " ", 
          RowBox[{"This", " ", "computes", " ", "the", " ", "product", " ", 
           RowBox[{
            SuperscriptBox[
             SubscriptBox["Y", "i"], "ni"], "/", 
            RowBox[{"ni", "!"}]}], " ", "for", " ", "initial", " ", 
           "particles"}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{"FactorInitialBackward", "=", 
          RowBox[{"FactorInitialElements", "@", "FinalParticles"}]}], ";", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Tab", "[", 
              RowBox[{"[", 
               RowBox[{"KeyVal", "[", 
                RowBox[{"#", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "]"}], "=", 
             RowBox[{
              RowBox[{"Tab", "[", 
               RowBox[{"[", 
                RowBox[{"KeyVal", "[", 
                 RowBox[{"#", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "]"}], "-", 
              RowBox[{"ReactionForward", " ", "FactorInitialForward", " ", 
               RowBox[{
                RowBox[{"#", "[", 
                 RowBox[{"[", "2", "]"}], "]"}], "/", "A\[Rho]B"}], "*", 
               "DensityUnit"}]}]}], ")"}], "&"}], "/@", "InitialParticles"}], 
         ";", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Tab", "[", 
              RowBox[{"[", 
               RowBox[{"KeyVal", "[", 
                RowBox[{"#", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "]"}], "=", 
             RowBox[{
              RowBox[{"Tab", "[", 
               RowBox[{"[", 
                RowBox[{"KeyVal", "[", 
                 RowBox[{"#", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "]"}], "+", 
              RowBox[{"ReactionForward", " ", "FactorInitialForward", " ", 
               RowBox[{
                RowBox[{"#", "[", 
                 RowBox[{"[", "2", "]"}], "]"}], "/", "A\[Rho]B"}], "*", 
               "DensityUnit"}]}]}], ")"}], "&"}], "/@", "FinalParticles"}], 
         ";", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Tab", "[", 
              RowBox[{"[", 
               RowBox[{"KeyVal", "[", 
                RowBox[{"#", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "]"}], "=", 
             RowBox[{
              RowBox[{"Tab", "[", 
               RowBox[{"[", 
                RowBox[{"KeyVal", "[", 
                 RowBox[{"#", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "]"}], "-", 
              RowBox[{"ReactionBackward", " ", "FactorInitialBackward", " ", 
               RowBox[{
                RowBox[{"#", "[", 
                 RowBox[{"[", "2", "]"}], "]"}], "/", "A\[Rho]B"}], "*", 
               "DensityUnit"}]}]}], ")"}], "&"}], "/@", "FinalParticles"}], 
         ";", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Tab", "[", 
              RowBox[{"[", 
               RowBox[{"KeyVal", "[", 
                RowBox[{"#", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "]"}], "=", 
             RowBox[{
              RowBox[{"Tab", "[", 
               RowBox[{"[", 
                RowBox[{"KeyVal", "[", 
                 RowBox[{"#", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "]"}], "+", 
              RowBox[{"ReactionBackward", " ", "FactorInitialBackward", " ", 
               RowBox[{
                RowBox[{"#", "[", 
                 RowBox[{"[", "2", "]"}], "]"}], "/", "A\[Rho]B"}], "*", 
               "DensityUnit"}]}]}], ")"}], "&"}], "/@", "InitialParticles"}], 
         ";"}]}], "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"TreatReaction", "/@", "listreac"}], ";", "\[IndentingNewLine]", 
     "Tab"}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.694937781199915*^9, 3.694937924339123*^9}, {
