Cell["\<\
The function DefineEquations wraps the definition of differential equations. \
This must be called any time we regenerate the probabilities on the reaction \
rates when including uncertainties on reaction rates in a Monte-Carlo \
analysis.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.694756634228939*^9, 3.694756649161687*^9}, {
  3.69479613756431*^9, 3.694796139901114*^9}, {3.699851648063398*^9, 
  3.69985167316745*^9}, {3.700846483433919*^9, 3.70084649135008*^9}, {
  3.7159545352389717`*^9, 
  3.715954560898499*^9}},ExpressionUUID->"5aff71f6-69e9-48b7-af82-\
e292b26521c4"],

Cell[BoxData[
 RowBox[{"DefineEquations", ":=", 
  RowBox[{"(", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "We", " ", "build", " ", "the", " ", "differential", " ", "system", " ", 
     "for", " ", "the", " ", "High", " ", "temperatures"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"So", " ", "we", " ", "associate", " ", "the", " ", 
      RowBox[{"r", ".", "h", ".", "s"}], " ", "which", " ", "is", " ", 
      "constructed", " ", "thanks", " ", "to", " ", "DYOnlyPEN"}], ",", " ", 
     RowBox[{"with", " ", "the", " ", 
      RowBox[{"l", ".", "h", ".", "s"}], " ", "made", " ", "of", " ", 
      "abundances", " ", "derivatives"}]}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"SystemEquationsHT", "[", "tv_", "]"}], "=", 
     RowBox[{
      RowBox[{"Thread", "[", 
       RowBox[{"Equal", "[", 
        RowBox[{
         RowBox[{"FunPrimeList", "[", "tv", "]"}], ",", 
         RowBox[{"(", 
          RowBox[{"DYOnlyPEN", "[", 
           RowBox[{"Tv", ",", "\[Rho]Bv", ",", "tv"}], "]"}], 
          RowBox[{"(*", 
           RowBox[{"/.", 
            RowBox[{"Dispatch", "@", "ReactionProbabilities"}]}], "*)"}], 
          ")"}]}], "]"}], "]"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Tv", "\[Rule]", 
         RowBox[{"Toft", "@", "tv"}]}], ",", 
        RowBox[{"\[Rho]Bv", "->", 
         RowBox[{"\[Rho]BForBBN", "@", 
          RowBox[{"a", "@", 
           RowBox[{"Toft", "@", "tv"}]}]}]}]}], "}"}]}]}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
     "For", " ", "middle", " ", "and", " ", "low", " ", "temperature", " ", 
      "we", " ", "distinguish", " ", "between", " ", "the", " ", "compiled", 
      " ", "and", " ", "the", " ", "uncompiled", " ", "method"}], " ", "*)"}],
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
     "$CompileNDSolve", ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Off", "[", 
        RowBox[{"General", "::", "munfl"}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"If", " ", "$CompileNDSolve"}], "=", "True"}], ",", " ", 
         RowBox[{
         "we", " ", "reinterpolate", " ", "the", " ", "rates", " ", "for", 
          " ", "the", " ", "middle", " ", "and", " ", "the", " ", "low", " ", 
          
          RowBox[{"temperatures", "."}]}]}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "The", " ", "system", " ", "is", " ", "a", " ", "matrix", " ", 
         "system", " ", "in", " ", "this", " ", "case", " ", "and", " ", "it",
          " ", "is", " ", "built", " ", "directly", " ", "in", " ", "NDSolve",
          " ", "below"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"Rules\[Lambda]RHSI", "=", 
        RowBox[{"MyInterpolationRate", "@", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Tv", ",", 
             RowBox[{"MyChop", "@", 
              RowBox[{"Rules\[Lambda]RHS", "[", "Tv", "]"}]}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"Tv", ",", 
             RowBox[{"ListTRange", "[", 
              RowBox[{"Tf", ",", "T18"}], "]"}]}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Rules\[Lambda]barRHSI", "=", 
        RowBox[{"MyInterpolationRate", "@", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Tv", ",", 
             RowBox[{"MyChop", "@", 
              RowBox[{"Rules\[Lambda]barRHS", "[", "Tv", "]"}]}]}], "}"}], 
           ",", 
           RowBox[{"{", 
            RowBox[{"Tv", ",", 
             RowBox[{"ListTRange", "[", 
              RowBox[{"Tf", ",", "T18"}], "]"}]}], "}"}]}], "]"}]}]}], ";", 
       "\n", "       ", 
       RowBox[{"Rules\[Lambda]RHS18I", "=", 
        RowBox[{"MyInterpolationRate", "@", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Tv", ",", 
             RowBox[{"Rules\[Lambda]RHS", "[", 
              RowBox[{"NReactionsSmallNetwork", ",", "Tv"}], "]"}]}], "}"}], 
           ",", 
           RowBox[{"{", 
            RowBox[{"Tv", ",", 
             RowBox[{"ListTRange", "[", 
              RowBox[{"T18", ",", "TMiddle"}], "]"}]}], "}"}]}], "]"}]}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"Rules\[Lambda]barRHS18I", "=", 
        RowBox[{"MyInterpolationRate", "@", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Tv", ",", 
             RowBox[{"Rules\[Lambda]barRHS", "[", 
              RowBox[{"NReactionsSmallNetwork", ",", "Tv"}], "]"}]}], "}"}], 
           ",", 
           RowBox[{"{", 
            RowBox[{"Tv", ",", 
             RowBox[{"ListTRange", "[", 
              RowBox[{"T18", ",", "TMiddle"}], "]"}]}], "}"}]}], "]"}]}]}], 
       ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"On", "[", 
        RowBox[{"General", "::", "munfl"}], "]"}], ";"}], ",", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"If", " ", "$CompileNDSolve"}], "=", "False"}], ",", " ", 
        RowBox[{"we", " ", 
         RowBox[{"(", 
          RowBox[{"re", "-"}], ")"}], "define", " ", "the", " ", "systems", 
         " ", "of", " ", "equations", " ", "for", " ", "Middle", " ", "and", 
         " ", "Low", " ", "temperatures"}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"We", " ", "associate", " ", "the", " ", 
         RowBox[{"r", ".", "h", ".", "s"}], " ", "formed", " ", "thanks", " ",
          "to", " ", "DY18", " ", "and", " ", "DY"}], ",", " ", 
        RowBox[{"with", " ", "the", " ", 
         RowBox[{"l", ".", "h", ".", "s"}], " ", "made", " ", "of", " ", 
         "derivatives"}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"SystemEquationsMT", "[", "tv_", "]"}], "=", 
        RowBox[{
         RowBox[{"Thread", "[", 
          RowBox[{"Equal", "[", 
           RowBox[{
            RowBox[{"FunPrimeList", "[", "tv", "]"}], ",", 
            RowBox[{"(", 
             RowBox[{"DY18", "[", 
              RowBox[{"Tv", ",", "\[Rho]Bv", ",", "tv"}], "]"}], ")"}]}], 
           "]"}], "]"}], "/.", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Tv", "\[Rule]", 
            RowBox[{"Toft", "@", "tv"}]}], ",", 
           RowBox[{"\[Rho]Bv", "->", 
            RowBox[{"\[Rho]BForBBN", "@", 
             RowBox[{"a", "@", 
              RowBox[{"Toft", "@", "tv"}]}]}]}]}], "}"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"SystemEquationsLT", "[", "tv_", "]"}], "=", 
        RowBox[{
         RowBox[{"Thread", "[", 
          RowBox[{"Equal", "[", 
           RowBox[{
            RowBox[{"FunPrimeList", "[", "tv", "]"}], ",", 
            RowBox[{"(", 
             RowBox[{"DY", "[", 
              RowBox[{"Tv", ",", "\[Rho]Bv", ",", "tv"}], "]"}], ")"}]}], 
           "]"}], "]"}], "/.", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Tv", "\[Rule]", 
            RowBox[{"Toft", "@", "tv"}]}], ",", 
           RowBox[{"\[Rho]Bv", "->", 
            RowBox[{"\[Rho]BForBBN", "@", 
             RowBox[{"a", "@", 
              RowBox[{"Toft", "@", "tv"}]}]}]}]}], "}"}]}]}], ";"}]}], 
     "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", ")"}]}]], "Input",\

 InitializationCell->True,
