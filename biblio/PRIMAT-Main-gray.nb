       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
         "Here", " ", "the", " ", "7", " ", "is", " ", "because", " ", "the", 
          " ", "interpolation", " ", "data", " ", "starts", " ", "at", " ", 
          "the", " ", "8"}], "-", 
         RowBox[{"th", " ", "column"}]}], " ", "*)"}], "\[IndentingNewLine]", 
       
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
         "Since", " ", "the", " ", "grid", " ", "in", " ", "x", " ", "is", 
          " ", "logarithmic"}], ",", " ", 
         RowBox[{
         "and", " ", "the", " ", "grid", " ", "in", " ", "y", " ", "is", " ", 
          "irregular", " ", 
          RowBox[{"(", 
           RowBox[{"Gauss", "-", 
            RowBox[{"Laguerre", " ", "Quadrature", " ", "possibly"}]}], 
           ")"}]}], ",", " ", 
         RowBox[{
         "Mathematica", " ", "cannot", " ", "perform", " ", "a", " ", "2", 
          "D", " ", 
          RowBox[{"interpolation", ".", " ", "To"}], " ", "bypass", " ", 
          "this", " ", "problem"}], ",", " ", 
         RowBox[{
         "we", " ", "first", " ", "interpolate", " ", "the", " ", "spectra", 
          " ", "for", " ", "each", " ", "xNEVO"}]}], "*)"}], "\n", "        ", 
       RowBox[{
        RowBox[{"LinearTable2DNue", "[", "fn", "]"}], "=", 
        RowBox[{"Table", "[", 
