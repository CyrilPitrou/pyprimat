Cell[CellGroupData[{

Cell["Monte - Carlo estimation of errors", "Subsection",
 CellChangeTimes->{{3.93633061078824*^9, 
  3.936330624224205*^9}},ExpressionUUID->"3aff8d44-95b9-4096-a7e1-\
3370eae2fc6c"],

Cell["\<\
There are 3 booleans which control what variables are varied randomly.
-Nuclear rates ($RandomNuclearRates)
-Neutron lifetime ($Random\[Tau]neutron)
-And possibly baryons abundance according to [Planck 2015] results when this \
is interesting to vary it as well ($Randomh2\[CapitalOmega]b).\
\>", "Text",
 CellChangeTimes->{{3.722687742286242*^9, 3.7226877943724203`*^9}, {
  3.93633062754766*^9, 3.936330630152339*^9}, {3.9363376488466377`*^9, 
