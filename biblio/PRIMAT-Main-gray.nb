\>", "Text",
 FontSize->18,ExpressionUUID->"dc789e5b-34a9-459f-a184-878f3d5ff9ce"],

Cell["\<\
The end values at middle temperatures are then used as initial conditions for \
the low temperature era.
Now the full system of equations is used.\
\>", "Text",
 CellChangeTimes->{{3.715955050294293*^9, 3.7159550647780447`*^9}, {
  3.7159550978736973`*^9, 3.715955099942622*^9}, {3.71595546776378*^9, 
  3.7159554776107063`*^9}},ExpressionUUID->"4999cb6c-f2d9-44ca-b269-\
f326f269b2ee"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"InitialConditionsLT", "[", "tv_", "]"}], ":=", 
   RowBox[{"Thread", "[", 
    RowBox[{"Equal", "[", 
     RowBox[{
      RowBox[{"FunList", "[", "tv", "]"}], ",", 
      RowBox[{
       RowBox[{"YPeriodTime", "[", "\"\<MT\>\"", "]"}], "[", "tv", "]"}]}], 
     "]"}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7001980419322042`*^9, 3.7001980972151957`*^9}, {
  3.700198185007798*^9, 3.700198198499975*^9}, {3.7002150542913017`*^9, 
  3.700215055982485*^9}, {3.717746904218412*^9, 3.717746910703947*^9}, {
  3.717746944551228*^9, 3.717746947454892*^9}, {3.717820214410516*^9, 
  3.7178202218515244`*^9}},
 CellLabel->
  "In[2537]:=",ExpressionUUID->"2e98a814-d05f-4723-b6f0-5167d8ac7b50"],

Cell[BoxData[
 RowBox[{"SolveValueLowTemperatures", ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
     "$CompileNDSolve", ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"Compiled", " ", "version"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"resLT", "=", 
        RowBox[{"NDSolveValue", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"Ytab", "'"}], "[", "tv", "]"}], "==", 
             RowBox[{"DYCN", "[", 
              RowBox[{
               RowBox[{"\[Rho]BForBBN", "@", 
                RowBox[{"a", "@", 
                 RowBox[{"Toft", "@", "tv"}]}]}], ",", 
               RowBox[{"Rules\[Lambda]RHSI", "[", 
                RowBox[{"Toft", "@", "tv"}], "]"}], ",", 
               RowBox[{"Rules\[Lambda]barRHSI", "[", 
                RowBox[{"Toft", "@", "tv"}], "]"}], ",", 
               RowBox[{"Ytab", "[", "tv", "]"}]}], "]"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"Ytab", "[", "t18", "]"}], "==", 
             RowBox[{
              RowBox[{"YPeriodTime", "[", "\"\<MT\>\"", "]"}], "[", "t18", 
              "]"}]}]}], "}"}], ",", "\[IndentingNewLine]", "Ytab", ",", 
          RowBox[{"{", 
           RowBox[{"tv", ",", "t18", ",", "tend"}], "}"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"Method", "->", 
             RowBox[{"{", 
              RowBox[{"NDSolve`LSODA", ",", 
               RowBox[{"\"\<MaxDifferenceOrder\>\"", "\[Rule]", "1"}]}], 
              "}"}]}], ","}], "*)"}], "\[IndentingNewLine]", 
          RowBox[{"Method", "\[Rule]", 
           RowBox[{"{", 
            RowBox[{"\"\<BDF\>\"", ",", 
             RowBox[{"\"\<MaxDifferenceOrder\>\"", "\[Rule]", "$BDFOrder"}]}],
             "}"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"PrecisionGoal", "\[Rule]", 
           RowBox[{"5", "+", "PrecisionNDSolve"}]}], ",", 
          RowBox[{"AccuracyGoal", "\[Rule]", "AccuracyNDSolve"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"InterpolationOrder", "\[Rule]", "InterpOrder"}], ",", 
          RowBox[{"StartingStepSize", "\[Rule]", 
           RowBox[{"10", "^", 
            RowBox[{"-", "4"}]}]}], ",", 
          RowBox[{"MaxStepSize", "\[Rule]", "500"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Y", "[", "\"\<LT\>\"", "]"}], "[", "key_", "]"}], "[", 
         RowBox[{"tv_", "?", "NumericQ"}], "]"}], ":=", 
        RowBox[{
         RowBox[{"resLT", "[", "tv", "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"KeyVal", "[", "key", "]"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"tLT", "=", 
        RowBox[{"resLT", "[", 
         RowBox[{"[", 
          RowBox[{"3", ",", "1"}], "]"}], "]"}]}], ";"}], ",", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"Uncompiled", " ", 
        RowBox[{"version", ".", " ", "Slower", "."}]}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Thread", "[", 
        RowBox[{"MySet", "[", 
         RowBox[{
          RowBox[{"Evaluate", "[", 
           RowBox[{"HoldYNames", "[", "\"\<LT\>\"", "]"}], "]"}], ",", 
          RowBox[{"NDSolveValue", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Flatten", "@", 
             RowBox[{"Join", "[", 
              RowBox[{
               RowBox[{"SystemEquationsLT", "[", "tv", "]"}], ",", 
               RowBox[{"InitialConditionsLT", "[", "t18", "]"}]}], "]"}]}], 
            ",", "\[IndentingNewLine]", "VarList", ",", 
            RowBox[{"{", 
             RowBox[{"tv", ",", "t18", ",", "tend"}], "}"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Method", "\[Rule]", 
             RowBox[{"{", 
              RowBox[{"\"\<BDF\>\"", ",", 
               RowBox[{"\"\<MaxDifferenceOrder\>\"", "\[Rule]", "$BDFOrder"}],
                ",", 
               RowBox[{
               "\"\<EquationSimplification\>\"", "\[Rule]", 
                "\"\<Solve\>\""}]}], "}"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"PrecisionGoal", "\[Rule]", 
             RowBox[{"5", "+", "PrecisionNDSolve"}]}], ",", 
            RowBox[{"AccuracyGoal", "\[Rule]", "AccuracyNDSolve"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"InterpolationOrder", "\[Rule]", "InterpOrder"}], ",", 
            RowBox[{"StartingStepSize", "\[Rule]", 
             RowBox[{"10", "^", 
              RowBox[{"-", "4"}]}]}]}], "]"}]}], "]"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"tLT", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"Y", "[", "\"\<LT\>\"", "]"}], "[", "\"\<n\>\"", "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"3", ",", "1"}], "]"}], "]"}]}], ";"}]}], 
     "\[IndentingNewLine]", "]"}], ";"}], ")"}]}]], "Input",
 InitializationCell->True,
