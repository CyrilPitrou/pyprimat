                RowBox[{"-", "e1"}], ",", "p1", ",", "x", ",", "znu", ",", 
                "sgnq"}], "]"}]}], ")"}], "\[IndentingNewLine]", "*", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", 
                FractionBox["1", "4"]}], 
               SuperscriptBox[
                RowBox[{"Log", "[", 
                 SuperscriptBox[
                  RowBox[{"(", 
                   FractionBox[
                    RowBox[{"p1", "+", "p2"}], 
