Cell["Let us apply these rules to form the r.h.s", "Text",
 CellChangeTimes->{{3.7227591123450108`*^9, 
  3.722759121887229*^9}},ExpressionUUID->"d02caf67-a77f-4413-9c7d-\
879ef2422f70"],

Cell["\<\
Here is the r.h.s of the differential system for nuclear reactions. We \
distinguish between high, middle and low temperature system of equations.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.6984379871547537`*^9, 3.698437998693118*^9}, {
  3.699851890361734*^9, 3.699851902647789*^9}, {3.7159515019719973`*^9, 
  3.715951505419718*^9}},ExpressionUUID->"c1dd1fb6-65c5-471a-8791-\
ab5b473b78ff"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"DYOnlyPEN", "[", 
     RowBox[{"Temp_", ",", "\[Rho]B_", ",", "time_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", "FormalReactionsOnlyPEN", ")"}], "/.", 
        RowBox[{"Dispatch", "@", 
         RowBox[{"Rules\[Lambda]", "[", "Temp", "]"}]}]}], "/.", 
       RowBox[{"Dispatch", "@", 
        RowBox[{"Rules\[Lambda]bar", "[", "Temp", "]"}]}]}], "/.", 
      RowBox[{"Dispatch", "@", 
       RowBox[{"RulesY", "[", "time", "]"}]}]}], "/.", 
     RowBox[{"A\[Rho]B", "\[Rule]", "\[Rho]B"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"DY18", "[", 
     RowBox[{"Temp_", ",", "\[Rho]B_", ",", "time_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", "FormalReactions18", ")"}], "/.", 
        RowBox[{"Dispatch", "@", 
         RowBox[{"Rules\[Lambda]", "[", "Temp", "]"}]}]}], "/.", 
       RowBox[{"Dispatch", "@", 
        RowBox[{"Rules\[Lambda]bar", "[", "Temp", "]"}]}]}], "/.", 
      RowBox[{"Dispatch", "@", 
       RowBox[{"RulesY", "[", "time", "]"}]}]}], "/.", 
     RowBox[{"A\[Rho]B", "\[Rule]", "\[Rho]B"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"DY", "[", 
    RowBox[{"Temp_", ",", "\[Rho]B_", ",", "time_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", "FormalReactions", ")"}], "/.", 
       RowBox[{"Dispatch", "@", 
        RowBox[{"Rules\[Lambda]", "[", "Temp", "]"}]}]}], "/.", 
      RowBox[{"Dispatch", "@", 
       RowBox[{"Rules\[Lambda]bar", "[", "Temp", "]"}]}]}], "/.", 
     RowBox[{"Dispatch", "@", 
      RowBox[{"RulesY", "[", "time", "]"}]}]}], "/.", 
    RowBox[{"A\[Rho]B", "\[Rule]", "\[Rho]B"}]}]}], 
  ";"}], "\[IndentingNewLine]"}], "Input",
 InitializationCell->True,
