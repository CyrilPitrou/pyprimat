                  "-", 
                 RowBox[{"\[Chi]tilde", "[", 
                  RowBox[{
                   RowBox[{"en", "+", "k"}], ",", "znu", ",", "sgnq"}], 
                  "]"}]}], ")"}]}], "+", 
              RowBox[{
               RowBox[{"FD", "[", 
