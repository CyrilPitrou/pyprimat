Cell["\<\
We first build the name of the file to store the PEN rates. It includes as a \
postfix the values of the booleans for the various effects taken or not taken \
into account.\
\>", "Text",
 CellChangeTimes->{{3.71567398873219*^9, 3.715673999953617*^9}, {
  3.715942273779763*^9, 
  3.7159422924775867`*^9}},ExpressionUUID->"dc3c1ded-6e9f-4608-b3f6-\
dcdd8753add6"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"LetterFromBoolean", "[", "Bool_", "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{"Bool", ",", "\"\<T\>\"", ",", "\"\<F\>\""}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"StringFromBoolean", "[", "BoolList_List", "]"}], ":=", 
   RowBox[{"StringJoin", "[", 
    RowBox[{"LetterFromBoolean", "/@", "BoolList"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"BooleanSuffixPEN", ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"string1", ",", "string2", ",", "string3"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"string1", "=", 
       RowBox[{"StringFromBoolean", "[", 
        RowBox[{"{", 
         RowBox[{
         "$RadiativeCorrections", ",", "$RadiativeThermal", ",", 
          "$FiniteNucleonMass", ",", "$CoupledFMandRC", ",", "$NEVO", ",", 
          "$TrueT\[Nu]e", ",", "$SpectralDistortions"}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"string2", "=", 
       RowBox[{"If", "[", 
        RowBox[{"$DegenerateNeutrinos", ",", 
         RowBox[{"\"\<_xi_\>\"", "<>", 
          RowBox[{"ToString", "[", "\[Xi]\[Nu]", "]"}]}], ",", "\"\<\>\""}], 
        "]"}]}], " ", ";", "\[IndentingNewLine]", 
      RowBox[{"string3", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"$SpectralDistortions", "&&", "$AnalyticDistortions"}], ",", 
         
         RowBox[{"\"\<_xidist_\>\"", "<>", 
          RowBox[{"ToString", "[", "\[CapitalDelta]\[Xi]\[Nu]", "]"}], "<>", 
          "\"\<_ysz_\>\"", "<>", 
          RowBox[{"ToString", "[", "YSZ", "]"}]}], ",", "\"\<\>\""}], "]"}]}],
       " ", ";", "\[IndentingNewLine]", 
      RowBox[{"string1", "<>", "string2", "<>", "string3"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"BooleanSuffixPlasma", ":=", 
  RowBox[{"StringFromBoolean", "[", 
   RowBox[{"{", 
    RowBox[{"$CompleteQEDPressure", ",", "$QEDOe3"}], "}"}], 
   "]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7156736603063583`*^9, 3.7156738026009827`*^9}, {
