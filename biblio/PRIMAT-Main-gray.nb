Cell[BoxData[
 RowBox[{"BuildFormalReactions", ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"FormalReactions", "=", 
     RowBox[{"FillReactionMatrix", "@", "ListReactionsUpToChosenMass"}]}], 
    ";", "\[IndentingNewLine]", 
    RowBox[{"NReactions", "=", 
     RowBox[{"Length", "[", "ListReactionsUpToChosenMass", "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "We", " ", "also", " ", "build", " ", "formally", " ", "a", " ", "small",
       " ", "network", " ", "of", " ", "reactions", " ", "which", " ", "is", 
      " ", "used", " ", "in", " ", "the", " ", "middle", " ", "temperature", 
      " ", 
      RowBox[{"era", ".", "It"}], " ", "is", " ", "the", " ", "same", " ", 
      "thing", " ", "but", " ", "with", " ", "a", " ", "reduced", " ", 
      "number", " ", "of", " ", 
      RowBox[{"equations", "."}]}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{"NReactionsSmallNetwork", "=", 
     RowBox[{"If", "[", 
      RowBox[{"$ReducedNetwork", ",", 
       RowBox[{"SmallNuclearNetworkSize", "+", "1"}], ",", "18"}], "]"}]}], 
    ";", "\[IndentingNewLine]", 
    RowBox[{"NReactions18", "=", 
     RowBox[{"Min", "[", 
      RowBox[{"NReactionsSmallNetwork", ",", 
       RowBox[{"Length", "@", "ListReactionsUpToChosenMass"}]}], "]"}]}], ";",
     "\[IndentingNewLine]", 
    RowBox[{"FormalReactions18", "=", 
     RowBox[{"FillReactionMatrix", "@", 
      RowBox[{"Take", "[", 
       RowBox[{"ListReactionsUpToChosenMass", ",", "NReactions18"}], 
       "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "We", " ", "also", " ", "build", " ", "a", " ", "differential", " ", 
      "system", " ", "with", " ", "just", " ", "neutrons", " ", "and", " ", 
      "protons", " ", "and", " ", "the", " ", "weak", " ", "interactions", 
      " ", "for", " ", "the", " ", "high", " ", "temperature", " ", "era"}], 
     "*)"}], "\[IndentingNewLine]", 
    RowBox[{"FormalReactionsOnlyPEN", "=", 
     RowBox[{"FillReactionMatrix", "[", 
      RowBox[{"{", "ReactionPEN", "}"}], "]"}]}], ";", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "We", " ", "also", " ", "compile", " ", "these", " ", "formal", " ", 
      "reactions", " ", "if", " ", "asked", " ", "by", " ", 
      RowBox[{"options", "."}]}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{"$CompileNDSolve", ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"DYCDef", ":=", 
        RowBox[{"CompileFromFormal", "[", "FormalReactions", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"DY18CDef", ":=", 
        RowBox[{"CompileFromFormal", "[", "FormalReactions18", "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"NameFileDYC", " ", "=", 
          RowBox[{"\"\<DYC_\>\"", "<>", 
           RowBox[{"ToString", "[", 
            RowBox[{"FileBaseName", "@", "ChosenReactionFile"}], "]"}], "<>", 
           "\"\<_Nreac_\>\"", "<>", 
           RowBox[{"ToString", "[", "NReactions", "]"}], "<>", 
           "\"\<_Nnuclei_\>\"", "<>", 
           RowBox[{"ToString", "[", 
            RowBox[{"Length", "@", "VarList"}], "]"}]}]}], ";"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"NameFileDYC", " ", "=", 
        RowBox[{"\"\<DYC_Nreac_\>\"", "<>", 
         RowBox[{"ToString", "[", "NReactions", "]"}], "<>", 
         "\"\<_Nnuclei_\>\"", "<>", 
         RowBox[{"ToString", "[", 
          RowBox[{"Length", "@", "VarList"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"NameFileDYC18", "=", 
          RowBox[{"\"\<DY18C_\>\"", "<>", 
           RowBox[{"ToString", "[", 
            RowBox[{"FileBaseName", "@", "ChosenReactionFile"}], "]"}], "<>", 
           "\"\<_Nreac_\>\"", "<>", 
           RowBox[{"ToString", "[", "NReactions18", "]"}], "<>", 
           "\"\<_Nnuclei_\>\"", "<>", 
           RowBox[{"ToString", "[", 
            RowBox[{"Length", "@", "VarList"}], "]"}]}]}], ";"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"NameFileDYC18", "=", 
        RowBox[{"\"\<DY18C_Nreac_\>\"", "<>", 
         RowBox[{"ToString", "[", "NReactions18", "]"}], "<>", 
         "\"\<_Nnuclei_\>\"", "<>", 
         RowBox[{"ToString", "[", 
          RowBox[{"Length", "@", "VarList"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"DYC", ":=", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"LoadCompiledFunction", "[", 
           RowBox[{
            RowBox[{"Hold", "[", "DYC", "]"}], ",", 
            RowBox[{"Hold", "[", "DYCDef", "]"}], ",", "NameFileDYC"}], "]"}],
           ";", "DYC"}], ")"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"DY18C", ":=", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"LoadCompiledFunction", "[", 
           RowBox[{
            RowBox[{"Hold", "[", "DY18C", "]"}], ",", 
            RowBox[{"Hold", "[", "DY18CDef", "]"}], ",", "NameFileDYC18"}], 
           "]"}], ";", "DY18C"}], ")"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"DYCN", "[", 
         RowBox[{
          RowBox[{"A\[Rho]B_", "?", "NumericQ"}], ",", "L_", ",", "Lbar_", 
          ",", "Y_"}], "]"}], ":=", 
        RowBox[{"DYC", "[", 
         RowBox[{"A\[Rho]B", ",", "L", ",", "Lbar", ",", "Y"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"DY18CN", "[", 
         RowBox[{
          RowBox[{"A\[Rho]B_", "?", "NumericQ"}], ",", "L_", ",", "Lbar_", 
          ",", "Y_"}], "]"}], ":=", 
        RowBox[{"DY18C", "[", 
         RowBox[{"A\[Rho]B", ",", "L", ",", "Lbar", ",", "Y"}], "]"}]}], 
       ";"}]}], "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
   ")"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.694944929091447*^9, 3.694944936878049*^9}, {
   3.694945394196466*^9, 3.69494540742454*^9}, 3.699362364127404*^9, {
   3.699459121195594*^9, 3.69945913288801*^9}, 3.6994591712880363`*^9, 
