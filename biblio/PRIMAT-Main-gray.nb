               RowBox[{"zNEVOofT", "[", "fn", "]"}], "[", "Tgmin", "]"}]}], 
             "]"}]}], " ", "]"}]}]}], "]"}]}], ";"}], "*)"}], 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"xNEVOofT", "[", "fn", "]"}], "=", 
