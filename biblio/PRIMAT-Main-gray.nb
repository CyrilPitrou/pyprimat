Cell["\<\
We also define a function which can choose between previsouly numerically \
solved function in a given era, or equilibrium values for a list of species\
\>", "Text",
 CellChangeTimes->{{3.717820559115286*^9, 
  3.7178205891128817`*^9}},ExpressionUUID->"758609fa-3d05-4e9d-9250-\
ea09b3badfc7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NumericalValueOrThermalEquilibriumValue", "[", 
    RowBox[{
    "period_", ",", "ListThermal_", ",", "name_", ",", "Tv_", ",", "tv_"}], 
    "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Yv", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"Y", "[", "period", "]"}], "[", "name", "]"}], "[", "tv", 
         "]"}]}], ",", 
       RowBox[{"Yn", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"Y", "[", "period", "]"}], "[", "\"\<n\>\"", "]"}], "[", 
         "tv", "]"}]}], ",", 
       RowBox[{"Yp", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"Y", "[", "period", "]"}], "[", "\"\<p\>\"", "]"}], "[", 
         "tv", "]"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"If", "[", " ", 
      RowBox[{
       RowBox[{"MemberQ", "[", 
        RowBox[{"ListThermal", ",", "name"}], "]"}], ",", 
       RowBox[{"YNSE", "[", 
        RowBox[{"name", ",", "Yn", ",", "Yp", ",", "Tv"}], "]"}], ",", "Yv"}],
       "]"}]}], "]"}]}], ";"}]], "Input",
 InitializationGroup->True,
 CellChangeTimes->{{3.717502399429641*^9, 3.717502532305883*^9}, {
