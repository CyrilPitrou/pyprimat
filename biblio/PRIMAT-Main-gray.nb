Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"GatherInfoReac", "[", 
     RowBox[{"ListIn_", ",", "ListOut_"}], "]"}], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"Qreaction", "[", 
        RowBox[{"ListIn", ",", "ListOut"}], "]"}], "/", "MeV"}], ",", 
      RowBox[{"FactorInverseReaction", "[", 
       RowBox[{"ListIn", ",", "ListOut"}], "]"}], ",", 
      RowBox[{"PowerT9", "[", 
       RowBox[{"ListIn", ",", "ListOut"}], "]"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         RowBox[{"Qreaction", "[", 
          RowBox[{"ListIn", ",", "ListOut"}], "]"}]}], "/", "kB"}], "/", 
       RowBox[{"10", "^", "9"}]}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"RemoveNonNuclear", "[", "Species_List", "]"}], ":=", 
   RowBox[{"Select", "[", 
    RowBox[{"Species", ",", 
     RowBox[{
      RowBox[{
       RowBox[{"#", "=!=", "\"\<g\>\""}], "&&", 
       RowBox[{"#", "=!=", "\"\<Bm\>\""}], "&&", 
       RowBox[{"#", "=!=", "\"\<Bp\>\""}]}], "&"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"InfoReaction", "[", 
    RowBox[{"{", 
     RowBox[{"ListIn_", ",", "ListOut_"}], "}"}], "]"}], ":=", 
   RowBox[{"GatherInfoReac", "[", 
    RowBox[{
     RowBox[{"RemoveNonNuclear", "@", "ListIn"}], ",", 
     RowBox[{"RemoveNonNuclear", "@", "ListOut"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"InfoReaction", "[", 
   RowBox[{"ListIn_", ",", "ListOut_"}], "]"}], ":=", 
  RowBox[{"InfoReaction", "[", 
   RowBox[{"{", 
    RowBox[{"ListIn", ",", "ListOut"}], "}"}], "]"}]}]}], "Input",
 InitializationCell->True,
