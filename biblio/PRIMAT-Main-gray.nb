Cell["\<\
We first solve  d ln(aT) / d ln(T) so as to get a(T). This is computed using \
the fact that there is a cooling of electron/photon plasma due to \
interactions with neutrinos.
We distinguish the case with and without QED corrections.\
\>", "Text",
 CellChangeTimes->{{3.700560298979485*^9, 3.7005603231981583`*^9}, {
   3.700560401134191*^9, 3.7005604296205797`*^9}, 3.717749897114719*^9, 
   3.722685587637493*^9, {3.722685637837677*^9, 
   3.722685649996593*^9}},ExpressionUUID->"7216338a-aca9-453f-8cb7-\
8d86236144e8"],

Cell["\<\
The equation solved is Eq. 62 of companion paper. SolveaOFTwhenID calls the \
solver and can be recalled anytime we have varied parameters.\
\>", "Text",ExpressionUUID->"2b4d4c8b-dd4e-4e3a-8920-ae1a95157e0e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SolveaOFTwhenID", ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"laTCQED", "=", 
      RowBox[{
       RowBox[{"NDSolveValue", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"laTCN", "'"}], "[", "lTv", "]"}], "\[Equal]", 
            FractionBox[
             RowBox[{"(", 
              RowBox[{
               RowBox[{"\[ScriptCapitalN]lT", "[", "lTv", "]"}], "-", 
               RowBox[{
                RowBox[{"DS2lTQED", "'"}], "[", "lTv", "]"}]}], ")"}], 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"\[ScriptCapitalN]lT", "[", "lTv", "]"}], "+", 
               RowBox[{"3", "*", 
                RowBox[{"DS2lTQED", "[", "lTv", "]"}]}]}], ")"}]]}], ",", 
           RowBox[{
            RowBox[{"laTCN", "[", 
             RowBox[{"Log", "@", "Tf"}], "]"}], "\[Equal]", 
            RowBox[{"Log", "[", 
             FractionBox["TCMB0", 
              SuperscriptBox[
               RowBox[{"DSTQED", "[", "Tf", "]"}], 
               RowBox[{"(", 
                RowBox[{"1", "/", "3"}], ")"}]]], "]"}]}]}], "}"}], ",", 
         RowBox[{"{", "laTCN", "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"lTv", ",", 
           RowBox[{"Log", "@", "Ti"}], ",", 
           RowBox[{"Log", "@", "Tf"}]}], "}"}], ",", 
         RowBox[{"PrecisionGoal", "\[Rule]", "30"}], 
         RowBox[{"(*", 
          RowBox[{"40", "s"}], "*)"}], ",", 
         RowBox[{"AccuracyGoal", "\[Rule]", "7"}]}], 
        RowBox[{"(*", "9", "*)"}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"laTCNoQED", "=", 
      RowBox[{
       RowBox[{"NDSolveValue", "[", 
        RowBox[{
         RowBox[{"{", 
