Cell["Hubble rate and scale factor", "Section",
 InitializationCell->True,
 CellChangeTimes->{{3.698434256227189*^9, 3.698434260871532*^9}, {
  3.936616772069388*^9, 
  3.936616775467257*^9}},ExpressionUUID->"93145db7-35ca-4c91-acc2-\
14da61dd1be2"],

Cell["\<\
Hubble function from Friedmann equation in flat FL space-time is then \
immediate\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.6983861154343643`*^9, 3.698386131195938*^9}, {
  3.715951915727253*^9, 
  3.715951920159058*^9}},ExpressionUUID->"0e80e600-648f-4c90-98ba-\
4dfe8c05c02d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"HofT", "[", "T_", "]"}], ":=", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        RowBox[{"8", "\[Pi]", " ", "GN"}], "3"], 
       RowBox[{"\[Rho]tot", "[", "T", "]"}]}], ")"}], 
     RowBox[{"(", 
      RowBox[{"1", "/", "2"}], ")"}]]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"H", "[", "a_", "]"}], ":=", 
    RowBox[{"HofT", "[", 
     RowBox[{"Tofa", "[", "a", "]"}], "]"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        RowBox[{"8", "\[Pi]", " ", "GN"}], "3"], 
       RowBox[{"\[Rho]tot", "[", 
        RowBox[{"Tofa", "[", "a", "]"}], "]"}]}], ")"}], 
     RowBox[{"(", 
      RowBox[{"1", "/", "2"}], ")"}]], ";"}], "*)"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.693930223261529*^9, 3.6939303051166773`*^9}, {
   3.6950157576407413`*^9, 3.6950157591028433`*^9}, 3.7000180729894*^9, 
   3.700018131719819*^9, {3.935118883894702*^9, 3.9351189507364693`*^9}, {
   3.9364143563101807`*^9, 3.936414388730921*^9}, {3.936414663704101*^9, 
   3.9364146664677973`*^9}},
 CellLabel->
  "In[2109]:=",ExpressionUUID->"9a819c06-0ff5-49d1-a70c-d0a2be521f47"],

Cell["\<\
This is the solver for dt/da giving t(a). Direct integration of the Friedmann \
equation\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.6947511402594557`*^9, 3.694751151831079*^9}, {
  3.699815826877348*^9, 3.699815829502079*^9}, {3.7159519303512287`*^9, 
  3.715951937484537*^9}},ExpressionUUID->"736d7db6-2000-46df-a574-\
96ec2cccbf33"],

Cell[BoxData[
 RowBox[{"Computetofa", ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"tofa", "=", 
     RowBox[{"(", 
      RowBox[{"NDSolveValue", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"tv", "'"}], "[", "av", "]"}], "\[Equal]", 
           FractionBox["1", 
            RowBox[{"(", 
             RowBox[{"av", " ", 
              RowBox[{"H", "[", "av", "]"}]}], ")"}]]}], ",", 
          RowBox[{
           RowBox[{"tv", "[", 
            RowBox[{"a", "[", "Ti", "]"}], "]"}], "\[Equal]", 
           FractionBox["1", 
            RowBox[{"(", 
             RowBox[{"2", 
              RowBox[{"H", "[", 
               RowBox[{"a", "[", "Ti", "]"}], "]"}]}], ")"}]]}]}], "}"}], ",",
         "tv", ",", 
        RowBox[{"{", 
         RowBox[{"av", ",", 
          RowBox[{"a", "[", "Ti", "]"}], ",", 
          RowBox[{"a", "[", "Tf", "]"}]}], "}"}], ",", 
        RowBox[{"PrecisionGoal", "\[Rule]", "8"}], ",", 
        RowBox[{"AccuracyGoal", "\[Rule]", "10"}]}], "]"}], ")"}]}], ";"}], 
   ")"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.693929467113291*^9, 3.693929482918538*^9}, {
