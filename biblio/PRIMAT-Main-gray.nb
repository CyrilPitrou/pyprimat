Cell["Collecting all reaction rates", "Subsection",
 CellChangeTimes->{{3.699947158099894*^9, 3.699947173385923*^9}, {
  3.700388123931964*^9, 3.7003881309152727`*^9}, {3.7003882006448193`*^9, 
  3.700388203661641*^9}},ExpressionUUID->"6c29d23a-22f0-4757-b09f-\
296f8db3b946"],

Cell["\<\
We collect the description of all rates in a single table (ListReactions). \
This include the weak rate (1 reaction), all the reactions from the external \
file (generated by the function LoadRates), and the reactions which were \
given analytically by the function DefineAnalyticRates.\
\>", "Text",
 CellChangeTimes->{{3.7159489762220907`*^9, 3.7159490450471067`*^9}, {
  3.722699209693584*^9, 
  3.722699210019956*^9}},ExpressionUUID->"1729370d-7352-4521-a766-\
24a8b4db15df"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ReactionPEN", "=", 
    RowBox[{"{", 
     RowBox[{"\"\<nTOp\>\"", ",", 
      RowBox[{"{", "\"\<n\>\"", "}"}], ",", 
      RowBox[{"{", "\"\<p\>\"", "}"}], ",", "0", ",", 
      "\"\<Phys.Rept. 754 (2018) 1-66\>\""}], "}"}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Format", " ", "is", " ", "name"}], ",", " ", 
    RowBox[{"List", " ", "of", " ", "initial", " ", "particles"}], ",", " ", 
    RowBox[{"List", " ", "of", " ", "final", " ", "particles"}], ",", " ", 
    RowBox[{"f", " ", "factor", " ", "for", " ", "uncertainty"}]}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ChosenReactionFile", ":=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"Not", "[", "$Parthenope", "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
       "$ReducedNetwork", ",", "TabulatedReactionsFileSmallNetwork", ",", 
        "TabulatedReactionsFile"}], "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
       "$ReducedNetwork", ",", "TabulatedReactionsFileSmallNetworkParthenope",
         ",", "TabulatedReactionsFileParthenope"}], "]"}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"TabulatedReactions", ":=", "\[IndentingNewLine]", 
    RowBox[{"(", 
     RowBox[{"Select", "[", 
      RowBox[{
       RowBox[{"SafeImport", "[", 
        RowBox[{"$RatesDirectory", "<>", "ChosenReactionFile"}], "]"}], ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"NumericQ", "[", 
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "]"}], "||", 
          RowBox[{"\"\<*-\>\"", "\[Equal]", 
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], "||", 
          RowBox[{"StringMatchQ", "[", 
           RowBox[{
            RowBox[{"#", "[", 
             RowBox[{"[", "1", "]"}], "]"}], ",", 
            RowBox[{"\"\<\\\\*%\>\"", "~~", "__"}]}], "]"}]}], ")"}], "&"}]}],
       "]"}], ")"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 

 RowBox[{
  RowBox[{"ReshapedTabulatedReactionsAll", ":=", 
   RowBox[{"TreatData", "[", "TabulatedReactions", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ReshapedTabulatedReactions", ":=", 
   RowBox[{"If", "[", 
    RowBox[{"$ReducedNetwork", ",", "\[IndentingNewLine]", 
