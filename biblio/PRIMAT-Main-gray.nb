Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"$NEVO", "&&", "$IncompleteNeutrinoDecoupling"}], ",", 
     RowBox[{"LogLinearPlot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"T\[Nu]overTIncompleteDecoupling", "[", "Tv", "]"}], ",", 
         RowBox[{
