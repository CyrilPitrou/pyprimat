Cell["\<\
We then have the differential equation solver. There are two possibilities \
depending on if we use the compiled version or not. 
The values are then affected to the YMT[\[OpenCurlyDoubleQuote]n\
\[CloseCurlyDoubleQuote]], YMT[\[OpenCurlyDoubleQuote]n\
\[CloseCurlyDoubleQuote]], YMT[\[OpenCurlyDoubleQuote]d\
\[CloseCurlyDoubleQuote]] etc... which are the abundances of species in this \
era.\
\>", "Text",
 CellChangeTimes->{{3.715955157079997*^9, 3.715955233831007*^9}, {
  3.715955266142583*^9, 3.715955301242116*^9}, {3.7183373011865587`*^9, 
  3.718337314754148*^9}},ExpressionUUID->"a98b2c45-6f21-4496-8b7b-\
b6006bc3cd3d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SolveValueMiddleTemperatures", ":=", 
   RowBox[{"(", 
    RowBox[{"If", "[", 
     RowBox[{
     "$CompileNDSolve", ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"Compiled", " ", 
        RowBox[{"version", "."}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"resMT", "=", 
        RowBox[{"NDSolveValue", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"Ytab", "'"}], "[", "tv", "]"}], "==", 
             RowBox[{"DY18CN", "[", 
              RowBox[{
               RowBox[{"\[Rho]BForBBN", "@", 
                RowBox[{"a", "@", 
                 RowBox[{"Toft", "@", "tv"}]}]}], ",", 
               RowBox[{"Rules\[Lambda]RHS18I", "[", 
                RowBox[{"Toft", "@", "tv"}], "]"}], ",", 
               RowBox[{"Rules\[Lambda]barRHS18I", "[", 
                RowBox[{"Toft", "@", "tv"}], "]"}], ",", 
               RowBox[{"Ytab", "[", "tv", "]"}]}], "]"}]}], ",", 
            RowBox[{
             RowBox[{"Ytab", "[", "tmiddle", "]"}], "==", 
             RowBox[{
              RowBox[{"YPeriodTimeOrStateEquilibrium", "[", 
               RowBox[{"\"\<HT\>\"", ",", "ListThermalValuesUsedMT"}], "]"}], 
              "[", 
              RowBox[{"TMiddle", ",", "tmiddle"}], "]"}]}]}], "}"}], ",", 
          "\[IndentingNewLine]", "Ytab", ",", 
          RowBox[{"{", 
           RowBox[{"tv", ",", "tmiddle", ",", "t18"}], "}"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Method", "->", 
           RowBox[{"{", 
            RowBox[{"\"\<BDF\>\"", ",", 
             RowBox[{"\"\<MaxDifferenceOrder\>\"", "\[Rule]", "$BDFOrder"}]}],
             "}"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"PrecisionGoal", "\[Rule]", 
           RowBox[{"7", "+", "PrecisionNDSolve"}]}], ",", 
          RowBox[{"AccuracyGoal", "\[Rule]", "11"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"InterpolationOrder", "\[Rule]", "InterpOrder"}], ",", 
          RowBox[{"Compiled", "\[Rule]", "Automatic"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Y", "[", "\"\<MT\>\"", "]"}], "[", "key_", "]"}], "[", 
         RowBox[{"tv_", "?", "NumericQ"}], "]"}], ":=", 
        RowBox[{
         RowBox[{"resMT", "[", "tv", "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"KeyVal", "[", "key", "]"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"tMT", "=", 
        RowBox[{"resMT", "[", 
         RowBox[{"[", 
          RowBox[{"3", ",", "1"}], "]"}], "]"}]}], ";"}], ",", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"Non", " ", "compiled", " ", 
        RowBox[{"version", ".", " ", "Slightly"}], " ", "slower"}], " ", 
       "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Thread", "[", 
        RowBox[{"MySet", "[", 
         RowBox[{
          RowBox[{"Evaluate", "[", 
           RowBox[{"HoldYNames", "[", "\"\<MT\>\"", "]"}], "]"}], ",", 
          RowBox[{"NDSolveValue", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Flatten", "@", 
             RowBox[{"Join", "[", 
              RowBox[{
               RowBox[{"SystemEquationsMT", "[", "tv", "]"}], ",", 
               RowBox[{"InitialConditionsMT", "[", 
                RowBox[{"TMiddle", ",", "tmiddle"}], "]"}]}], "]"}]}], ",", 
            "\[IndentingNewLine]", "VarList", ",", 
            RowBox[{"{", 
             RowBox[{"tv", ",", "tmiddle", ",", "t18"}], "}"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Method", "\[Rule]", 
             RowBox[{"{", 
              RowBox[{"\"\<BDF\>\"", ",", 
               RowBox[{
               "\"\<MaxDifferenceOrder\>\"", "\[Rule]", "$BDFOrder"}]}], 
              "}"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"PrecisionGoal", "\[Rule]", 
             RowBox[{"7", "+", "PrecisionNDSolve"}]}], ",", 
            RowBox[{"AccuracyGoal", "\[Rule]", "11"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"InterpolationOrder", "\[Rule]", "InterpOrder"}], ",", 
            RowBox[{"Compiled", "\[Rule]", "False"}]}], "]"}]}], "]"}], "]"}],
        ";", "\[IndentingNewLine]", 
       RowBox[{"tMT", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"Y", "[", "\"\<MT\>\"", "]"}], "[", "\"\<n\>\"", "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"3", ",", "1"}], "]"}], "]"}]}], ";"}]}], 
     "\[IndentingNewLine]", "]"}], ")"}]}], ";"}]], "Input",
 InitializationCell->True,
