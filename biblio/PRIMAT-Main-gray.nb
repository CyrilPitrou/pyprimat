Cell[CellGroupData[{

Cell["\<\
Cosmology and Friedmann equation  (scale factor - time relation)\
\>", "Chapter",
 InitializationCell->True,
 CellChangeTimes->{{3.694756410666604*^9, 3.6947564213095093`*^9}, {
  3.715958512027625*^9, 3.715958541075345*^9}, {3.9366166479316607`*^9, 
  3.936616744545395*^9}, {3.9366686148417473`*^9, 
  3.936668619192686*^9}},ExpressionUUID->"867394b5-9b49-46f6-b620-\
2df4a80b9a35"],

Cell[CellGroupData[{

Cell["Energy density", "Section",
 InitializationCell->True,
 CellChangeTimes->{{3.698433926671672*^9, 3.698433932766509*^9}, {
   3.6984339694191303`*^9, 3.698433972839882*^9}, 3.698438008790941*^9, {
   3.936616676492465*^9, 3.9366166779329853`*^9}, {3.936616766418324*^9, 
   3.936616768149571*^9}},ExpressionUUID->"44e8445c-c4a1-4797-b34f-\
e1bd3e94f8d3"],

Cell[TextData[{
 "The Friedmann equation gives the Hubble expansion rate. \nFor completeness \
we put baryons and CDM even though it makes a difference of order ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["10", 
     RowBox[{"-", "5"}]], " "}], TraditionalForm]],ExpressionUUID->
  "437c4b11-4ffa-4b81-93a1-9738d2f07ab5"],
 "which is below what we can achieve anyway with homogeneous computations."
}], "Text",
 InitializationCell->
  True,ExpressionUUID->"04a5b270-48d5-4316-9e0c-285e2e1d2a61"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["H", "2"], "=", 
  RowBox[{
   FractionBox[
    RowBox[{"8", "\[Pi]", " ", "G", " ", "\[Rho]"}], "3"], "=", 
   RowBox[{
    FractionBox["\[Rho]", 
     SubscriptBox["\[Rho]", "crit"]], " ", "so", " ", "we", " ", "build", " ",
     "first", " ", "the", " ", "energy", " ", 
    RowBox[{"density", "."}]}]}]}]], "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.693925459085713*^9, 3.6939254840692787`*^9}, {
   3.698566073729411*^9, 3.698566080628306*^9}, 3.698734663166689*^9, {
   3.7191660876094522`*^9, 3.7191661058145447`*^9}},
 FontFamily->"Arial",ExpressionUUID->"549cf7ab-0301-46c3-abda-1c5b62b60f3f"],

Cell["\<\
We select the neutrino energy density depending on options for decoupling\
\>", "Text",
 CellChangeTimes->{{3.719209391357827*^9, 3.719209407019197*^9}, {
  3.7192094882363873`*^9, 
  3.719209490483878*^9}},ExpressionUUID->"c4206ac1-8525-4d39-b01e-\
41ca7d74de3e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"\[Rho]\[Nu]", "[", "T_", "]"}], ":=", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{"$IncompleteNeutrinoDecoupling", ",", 
      RowBox[{"\[Rho]\[Nu]IncompleteDecoupling", "[", 
       RowBox[{"a", "[", "T", "]"}], "]"}], ",", 
      RowBox[{"\[Rho]\[Nu]Decoupling", "[", "T", "]"}]}], "]"}], "+", 
    RowBox[{"If", "[", 
     RowBox[{"$SpectralDistortions", ",", 
      RowBox[{"\[Rho]\[Nu]SD", "[", 
       RowBox[{
        RowBox[{"T\[Nu]overT", "[", "T", "]"}], "*", "T"}], "]"}], ",", "0"}],
      "]"}]}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.719209411490049*^9, 3.719209448773353*^9}, {
   3.720270301598461*^9, 3.720270310154229*^9}, {3.935033306612378*^9, 
   3.935033324358797*^9}, {3.9350333675610447`*^9, 3.935033369322021*^9}, {
   3.9350362307439203`*^9, 3.935036231026937*^9}, 3.935037860524806*^9, {
   3.935112628231324*^9, 3.935112636788739*^9}, 3.935113243669076*^9},
 CellLabel->
  "In[2096]:=",ExpressionUUID->"043f1be7-2ada-4f70-905e-df4f05ce0247"],

Cell["If relativistic species added, we must also add them", "Text",
 CellChangeTimes->{{3.935114342077223*^9, 
  3.935114357840775*^9}},ExpressionUUID->"789bcdaa-2cc3-4598-b4c5-\
884a2a91d87c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Rho]\[Nu]Relat", "[", "Tv_", "]"}], ":=", 
    RowBox[{"aBB", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"kB", " ", 
        RowBox[{"T\[Nu]overTDecoupling", "[", "Tv", "]"}], "Tv"}], ")"}], 
      "4"], " ", 
     FractionBox["7", "8"], " ", "*", "Nrelat"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"T\[Nu]", " ", "~", "1"}], "/", "a"}], " ", "exactly", " ", "in",
     " ", "the", " ", "decoupling", " ", "limit", " ", "hence", " ", "this", 
    " ", "corresponds", " ", "to", " ", "the", " ", "temperature", " ", "of", 
    " ", "an", " ", "unkown", " ", "relativistic", " ", "but", " ", 
    "decoupled", " ", "species"}], " ", "*)"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.935116257014093*^9, 3.935116273140471*^9}},
 CellLabel->
  "In[2097]:=",ExpressionUUID->"021efc18-0043-4e9d-a576-6da31072ee40"],

Cell["\<\
Two methods to get the total energy density. Either from energy density of \
neutrinos or from temperature. This should be (and it is...) totally \
equivalent.\
\>", "Text",ExpressionUUID->"95893bda-5f8a-40fb-a9b1-baee88c802dc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Rho]tot1", "[", "T_", "]"}], ":=", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"aBB", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"kB", " ", "T"}], ")"}], "4"], 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"D\[Rho]T", "[", "T", "]"}]}], ")"}]}], "+", 
      RowBox[{"\[Rho]\[Nu]", "[", "T", "]"}], "+", 
      RowBox[{"\[Rho]\[Nu]Relat", "[", "T", "]"}], "\[IndentingNewLine]", "+", 
      RowBox[{"nbaryons0", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"mbaryon0", "*", 
            RowBox[{"(", 
             RowBox[{"1", "+", 
              RowBox[{"h2\[CapitalOmega]c0", "/", "h2\[CapitalOmega]b0"}]}], 
             ")"}]}], "+", 
           RowBox[{
            FractionBox["3", "2"], 
            RowBox[{"(", 
             RowBox[{"kB", " ", "T"}], ")"}]}]}], ")"}], "/", 
         SuperscriptBox[
          RowBox[{"(", "clight", ")"}], "2"]}], "/", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"a", "[", "T", "]"}], ")"}], "3"]}]}]}], ")"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Rho]tot2", "[", "T_", "]"}], ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"aBB", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"kB", " ", "T"}], ")"}], "4"], 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{
         FractionBox["7", "8"], "Nneu", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"T\[Nu]AverageoverT", "[", "T", "]"}], ")"}], "4"]}], "+", 
        
        RowBox[{"D\[Rho]T", "[", "T", "]"}]}], ")"}]}], "\[IndentingNewLine]",
      "+", 
     RowBox[{"If", "[", 
      RowBox[{"$SpectralDistortions", ",", 
       RowBox[{"\[Rho]\[Nu]SD", "[", 
        RowBox[{
         RowBox[{"T\[Nu]overT", "[", "T", "]"}], "*", "T"}], "]"}], ",", 
       "0"}], "]"}], "+", 
     RowBox[{"\[Rho]\[Nu]Relat", "[", "T", "]"}], "\[IndentingNewLine]", "+", 
     
     RowBox[{"nbaryons0", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"mbaryon0", "*", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"h2\[CapitalOmega]c0", "/", "h2\[CapitalOmega]b0"}]}], 
            ")"}]}], "+", 
          RowBox[{
           FractionBox["3", "2"], 
           RowBox[{"(", 
            RowBox[{"kB", " ", "T"}], ")"}]}]}], ")"}], "/", 
        SuperscriptBox[
         RowBox[{"(", "clight", ")"}], "2"]}], "/", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"a", "[", "T", "]"}], ")"}], "3"]}]}]}], ")"}]}], 
  ";"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{
  3.9350354842986097`*^9, {3.935037434564314*^9, 3.93503743483428*^9}, 
   3.935037869708617*^9, {3.935048626492771*^9, 3.935048631197867*^9}, {
   3.935114367442172*^9, 3.9351143754674597`*^9}, {3.936497867698213*^9, 
   3.936497869690638*^9}, {3.936497900485446*^9, 3.936497902167655*^9}},
 CellLabel->
  "In[2098]:=",ExpressionUUID->"b1510971-b633-4d83-a97b-0f3064bc85ba"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Rho]tot", "[", "T_", "]"}], ":=", 
    RowBox[{"\[Rho]tot2", "[", "T", "]"}]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"If", " ", "$Taverage\[ScriptCapitalN]"}], "=", "True"}], ",", 
    " ", 
    RowBox[{"\[Rho]tot1", " ", "and", " ", "\[Rho]tot2", " ", "are", " ", 
     RowBox[{"equivalent", ".", " ", "In"}], " ", "general"}], ",", " ", 
    RowBox[{
    "we", " ", "prefer", " ", "\[Rho]tot2", " ", "which", " ", "uses", " ", 
     "the", " ", "effective", " ", "temperatures", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"better", " ", "consistency"}], ")"}], "."}]}]}], 
   "*)"}]}]], "Input",
 InitializationCell->True,
 CellLabel->
  "In[2100]:=",ExpressionUUID->"f1141b55-0610-4aa8-8432-69c95bc8b556"],

