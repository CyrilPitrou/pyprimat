Cell[TextData[{
 "Cosmological constant fraction ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalOmega]", "\[CapitalLambda]"], TraditionalForm]],
  ExpressionUUID->"d93edc42-5006-47ab-b7a4-8860eefafc5e"],
 ". Obtained by summing baryons and cold dark matter, given that radiation is \
negligible today.\nThis is just for information and it is not used since the \
cosmological constant is totally negligible for its influence in the \
expansion rate during BBN."
}], "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.6947506447155733`*^9, 3.694750653664797*^9}, {
