Cell["\<\
It is this function dFDneu that we use later to take into account the effect \
of distortions in n-p conversions. 
It also take into account that the distortion is different in neutrinos and \
in antineutrinos.\
\>", "Text",
 CellChangeTimes->{{3.80977096534614*^9, 3.8097709656210117`*^9}, {
  3.851751759899272*^9, 
  3.85175178422663*^9}},ExpressionUUID->"ac2b5a98-6c2b-4f2a-862f-\
3576dac9be7c"],

Cell["\<\
We can visualize the spectral distortion if needed. We check visually that \
the energy density contained in the spectral distortion is 0, because the \
effective neutrino temperature accounts for it.\
\>", "Text",
 CellChangeTimes->{{3.8517538991974773`*^9, 3.851753912107616*^9}, {
  3.851754011168189*^9, 3.85175405220154*^9}, {3.935569698651466*^9, 
  3.93556970958965*^9}},ExpressionUUID->"a8e7e220-8455-4542-b298-\
fa9c94551a1a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"If", "[", 
  RowBox[{"$SpectralDistortions", ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"dFDneuRawyT", "[", 
      RowBox[{"y_", ",", "T\[Gamma]_"}], "]"}], ":=", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", "=", 
         RowBox[{
          RowBox[{"me", "/", "kB"}], "/", "T\[Gamma]"}]}], "}"}], ",", " ", 
       RowBox[{"dFDneuRaw", "[", 
        RowBox[{"y", ",", "0", ",", "x", ",", " ", "1"}], "]"}]}], "]"}]}], 
    ";", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"dFDantineuRawyT", "[", 
      RowBox[{"y_", ",", "T\[Gamma]_"}], "]"}], ":=", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", "=", 
         RowBox[{
          RowBox[{"me", "/", "kB"}], "/", "T\[Gamma]"}]}], "}"}], ",", " ", 
       RowBox[{"dFDantineuRaw", "[", 
        RowBox[{"y", ",", "0", ",", "x", ",", " ", "1"}], "]"}]}], "]"}]}], 
    ";", "\n", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "^", "3"}], 
         RowBox[{"dFDneuRawyT", "[", 
          RowBox[{"y", ",", 
           RowBox[{"10", "^", "10.2"}]}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"y", "^", "3"}], 
         RowBox[{"dFDantineuRawyT", "[", 
          RowBox[{"y", ",", 
           RowBox[{"10", "^", "10.2"}]}], "]"}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "0.1", ",", "30"}], "}"}], ",", 
      RowBox[{"Frame", "->", "True"}]}], "]"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.8517535336083612`*^9, 3.8517535991965847`*^9}, 
