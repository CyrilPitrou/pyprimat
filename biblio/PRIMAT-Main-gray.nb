              "*", 
              RowBox[{"T", "/", "Tgmin"}]}]}], " ", "]"}]}], "]"}]}], "]"}]}],
       " ", ";"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{"$NeedNEVODistortions", ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"LogxNEVO", "[", "fn", "]"}], "=", 
