                RowBox[{"DS2lTNoQED", "'"}], "[", "lTv", "]"}]}], ")"}], 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"\[ScriptCapitalN]lT", "[", "lTv", "]"}], "+", 
               RowBox[{"3", "*", 
                RowBox[{"DS2lTNoQED", "[", "lTv", "]"}]}]}], ")"}]]}], ",", 
           RowBox[{
            RowBox[{"laTCNNoQED", "[", 
             RowBox[{"Log", "@", "Tf"}], "]"}], "\[Equal]", 
            RowBox[{"Log", "[", 
             FractionBox["TCMB0", 
              SuperscriptBox[
               RowBox[{"DSTNoQED", "[", "Tf", "]"}], 
               RowBox[{"(", 
                RowBox[{"1", "/", "3"}], ")"}]]], "]"}]}]}], "}"}], ",", 
         RowBox[{"{", "laTCNNoQED", "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"lTv", ",", 
           RowBox[{"Log", "@", "Ti"}], ",", 
           RowBox[{"Log", "@", "Tf"}]}], "}"}], ",", 
         RowBox[{"PrecisionGoal", "\[Rule]", "30"}], 
         RowBox[{"(*", "40", "*)"}], ",", 
         RowBox[{"AccuracyGoal", "\[Rule]", "7"}]}], 
        RowBox[{"(*", "9", "*)"}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
    ")"}]}], ";"}]], "Input",
