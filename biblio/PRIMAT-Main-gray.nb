Cell["Nuclear rates", "Text",
 CellDingbat->"\[FilledSquare]",
 CellChangeTimes->{{3.715920372139921*^9, 3.715920380925646*^9}},
 FontSize->16,
 FontVariations->{
 "Underline"->True},ExpressionUUID->"82d09e54-b4ff-49a1-b66b-df3d599eb35f"],

Cell[TextData[{
 "Most nuclear reaction rates are tabulated in a separate file. The rest of \
the rates are given as analytic fits.\nThe external file loaded with all \
reactions definitions and rates is given by the name ",
 StyleBox["TabulatedReactionsFile",
  FontFamily->"Source Code Pro",
  FontSize->13,
  FontWeight->"SemiBold"],
 ".\n\nThe user can also ask for the reduced network (12 nuclear reactions), \
see below, \nin which case only the first 12 nuclear reactions are selected \
and no extra analytic reactions."
}], "Text",
 CellChangeTimes->{{3.936844844637331*^9, 3.9368448893813066`*^9}, {
   3.937272163656271*^9, 3.937272168163217*^9}, 3.948213159567325*^9, {
   3.948213205263419*^9, 
