Cell[CellGroupData[{

Cell["\<\
Incomplete decoupling of neutrinos (method using heating functions)\
\>", "Section",ExpressionUUID->"2e77a6f5-9739-4707-8a1a-b5456e0e9559"],

Cell["\<\
We now refine to take into account the incomplete decoupling of neutrinos\
\>", "Text",ExpressionUUID->"e1c7a75f-ff4b-4258-8dbb-422ac3ff6ced"],

Cell[TextData[{
 "In the previous PRIMAT version, we were using a fit from  [PArthENoPE] for \
the heating function which caracterizes how neutrinos are (slightly) \
rehetaing due to incomplete decoupling. \nNow, if $NEVO option is set to \
True, we use the one computed by NEVO. The heating function \
\[ScriptCapitalN](z) of Parthenope is found from ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    RowBox[{
     RowBox[{"Eqs", ".", "  ", "A"}], ".24"}], " ", "-", 
    RowBox[{"A", " ", "25", " ", 
     RowBox[{"in", " ", "[", "PArthENoPE", "]"}]}]}],
   FontFamily->"Arial"]], "Input",
  CellChangeTimes->{{3.698746490576322*^9, 3.6987465102121267`*^9}},
  FontWeight->"Plain",ExpressionUUID->
  "dc34a2e8-fa0e-4297-a656-772845c6c6ec"],
 ". "
}], "Text",ExpressionUUID->"b4b72bfe-b1f8-4593-9283-fb2903d5e77f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Listnl", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "10.21703221236002"}], ",", "61.24438067531452", ",", 
      RowBox[{"-", "340.3323864212157"}], ",", "1057.2707914654834", ",", 
      RowBox[{"-", "2045.577491331372"}], ",", "2605.9087171012848", ",", 
      RowBox[{"-", "2266.1521815470196"}], ",", "1374.2623075963388", ",", 
      RowBox[{"-", "586.0618273295763"}], ",", "174.87532902234145", ",", 
      RowBox[{"-", "35.715878215468045"}], ",", "4.7538967685808755", ",", 
      RowBox[{"-", "0.3713438862054167"}], ",", "0.012908416591272199"}], 
     "}"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[ScriptCapitalN]Parthenope", "[", "z_", "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"z", "\[GreaterEqual]", "4"}], ",", "0", ",", 
     RowBox[{"Exp", "[", 
      RowBox[{"Plus", "@@", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Listnl", "[", 
           RowBox[{"[", 
            RowBox[{"i", "+", "1"}], "]"}], "]"}], 
          RowBox[{"z", "^", "i"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "0", ",", "13"}], "}"}]}], "]"}]}], "]"}]}], 
    "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[ScriptCapitalN]", "[", 
    RowBox[{"zNEVO_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{"$NEVO", ",", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"zNEVO", "<", "zminN"}], "||", 
        RowBox[{"zNEVO", "\[GreaterEqual]", "5"}]}], ",", "0", ",", 
       RowBox[{
        RowBox[{"\[ScriptCapitalN]NEVO", "[", "FileNEVOneutrinos", "]"}], "[",
         "zNEVO", "]"}]}], "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"zNEVO", "\[GreaterEqual]", "5"}], ",", "0", ",", 
       RowBox[{"\[ScriptCapitalN]Parthenope", "[", "zNEVO", "]"}]}], "]"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.934966900807617*^9, 3.934966903063478*^9}, {
   3.936367546023789*^9, 3.936367591755314*^9}, {3.936370203039013*^9, 
   3.936370204521307*^9}, 3.936532543289276*^9},
 CellLabel->
  "In[2000]:=",ExpressionUUID->"b2f002fc-fc36-4ba3-a4f5-c70bf9eba340"],

Cell[BoxData[{
 RowBox[{"Checking", " ", "the", " ", "agreement", " ", "between", " ", 
  SubscriptBox["\[ScriptCapitalN]", "NEVO"], " ", "and", " ", 
  SubscriptBox["\[ScriptCapitalN]", "PArthENoPE"], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     RowBox[{"for", " ", "T"}], ">", 
     RowBox[{
     "10", "MeV", " ", "Parthenope", " ", "fit", " ", "is", " ", "not", " ", 
      "valid"}]}], ",", " ", 
    RowBox[{"hence", " ", "the", " ", "large", " ", "difference"}]}], 
   ")"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
  "We", " ", "see", " ", "some", " ", "disagreement", " ", "around", " ", 
   "1.5"}], "-", 
  RowBox[{"2", "MeV", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"~", "1.5"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["10", "10"], " ", "K"}]}], ")"}], "."}]}]}]}], "Text",Ex\
pressionUUID->"4d5bd4d2-9917-409c-8869-c9a19fd6f6f1"],

