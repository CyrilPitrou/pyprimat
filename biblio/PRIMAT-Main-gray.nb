     RowBox[{
      RowBox[{"$LocalSuffix", "=", 
       RowBox[{"(", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{
           "\"\<$NeedNEVODistortions is \>\"", ",", "$NeedNEVODistortions"}], 
           "]"}], ";"}], "*)"}], 
        RowBox[{"If", "[", 
         RowBox[{
         "$NeedNEVODistortions", ",", "\"\<\>\"", ",", "\"\<_col_1_7\>\""}], 
         "]"}], ")"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Not", "[", 
          RowBox[{
          "ValueQ", "[", "T\[Nu]AverageOverT\[Gamma]OFT\[Gamma]NEVOSafe", 
           "]"}], "]"}], "||", "$RecomputeWeakRates"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"LoadNEVOFile", "[", "FileNEVOneutrinos", "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"LoadNEVOFile", "[", "FileNEVOantineutrinos", "]"}], ";", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"TreatNEVOFile", "[", "FileNEVOneutrinos", "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"TreatNEVOFile", "[", "FileNEVOantineutrinos", "]"}], ";", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"T\[Nu]AverageOverT\[Gamma]OFT\[Gamma]NEVOSafe", "[", 
           RowBox[{"T_", "?", "NumericQ"}], "]"}], " ", ":=", 
          RowBox[{"TempAverageNNbar", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{
             "T\[Nu]AverageOverT\[Gamma]OFT\[Gamma]NEVOS", "[", 
              "FileNEVOneutrinos", "]"}], "[", "T", "]"}], ",", 
            RowBox[{
             RowBox[{
             "T\[Nu]AverageOverT\[Gamma]OFT\[Gamma]NEVOS", "[", 
              "FileNEVOantineutrinos", "]"}], "[", "T", "]"}]}], 
           "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"T\[Nu]eOverT\[Gamma]OFT\[Gamma]NEVOSafe", "[", 
           RowBox[{"T_", "?", "NumericQ"}], "]"}], " ", ":=", 
          RowBox[{"TempAverageNNbar", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{
             "T\[Nu]eOverT\[Gamma]OFT\[Gamma]NEVOS", "[", "FileNEVOneutrinos",
               "]"}], "[", "T", "]"}], ",", 
            RowBox[{
             RowBox[{
             "T\[Nu]eOverT\[Gamma]OFT\[Gamma]NEVOS", "[", 
              "FileNEVOantineutrinos", "]"}], "[", "T", "]"}]}], 
           "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "Careful", " ", "this", " ", "is", " ", "overwritten", " ", "in", 
           " ", 
           RowBox[{"LoadDistortions", ".", " ", "Need"}], " ", "to", " ", 
           "be", " ", "more", " ", 
           RowBox[{"consistent", "."}]}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{"zminN", "=", 
          RowBox[{"me", "/", 
           RowBox[{"(", 
            RowBox[{"kB", "*", 
             RowBox[{"T\[Gamma]max", "[", "FileNEVOneutrinos", "]"}]}], 
            ")"}]}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"zmaxN", "=", 
          RowBox[{"me", "/", 
           RowBox[{"(", 
            RowBox[{"kB", "*", 
             RowBox[{"T\[Gamma]min", "[", "FileNEVOneutrinos", "]"}]}], 
            ")"}]}]}], ";"}]}], "\[IndentingNewLine]", "]"}], ";"}]}], 
    "\[IndentingNewLine]", "]"}], ")"}]}]}], "Input",
