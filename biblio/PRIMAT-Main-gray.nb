     RowBox[{"UniqueLibraryname", "[", "funcLoc_", "]"}], ":=", 
     RowBox[{"$PackageDirectory", "<>", "\"\<lib/compiled\>\"", "<>", 
      RowBox[{"ToString", "[", 
       RowBox[{"RandomInteger", "[", 
        RowBox[{"{", 
         RowBox[{"1000", ",", "9999"}], "}"}], "]"}], "]"}], "<>", 
      "\"\<.\>\"", "<>", 
      RowBox[{
       RowBox[{"StringSplit", "[", 
        RowBox[{"funcLoc", ",", "\"\<.\>\""}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"-", "1"}], "]"}], "]"}]}]}], ";"}], "*)"}]}]}], "Input",
