  3.719812828369467*^9}},ExpressionUUID->"0d999d22-0a14-4882-b609-\
309121269dc7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "We", " ", "store", " ", "the", " ", "rate", " ", "but", " ", "without", 
   " ", "the", " ", "division", " ", "by", " ", 
   RowBox[{"\[Tau]neutron", " ", ".", " ", "So"}], " ", "that", " ", "we", 
   " ", "can", " ", "use", " ", "the", " ", "same", " ", "fit", " ", "for", 
   " ", "the", " ", "reaction", " ", "rates"}], ",", " ", 
  RowBox[{"and", " ", "still", " ", "vary", " ", 
   RowBox[{"\[Tau]neutron", " ", "."}]}]}]], "Text",
 CellChangeTimes->{{3.719058709280066*^9, 3.7190587230718393`*^9}, {
  3.7190590304042273`*^9, 3.719059045927733*^9}, {3.719891110896352*^9, 
  3.719891123654189*^9}},
 FontFamily->"Arial",ExpressionUUID->"93fc9b1e-fe72-4ce6-8314-0f06c3149ce2"],

Cell[TextData[{
 "The rates in the files, once loaded, are interpolated once the division by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Tau]neutron", "  ", "has", " ", "been", " ", 
    RowBox[{"added", "."}]}], TraditionalForm]],ExpressionUUID->
  "5926d5e7-7627-4a87-b4ff-ffc60299e2a9"],
 "\nIf spectral distortions are taken into account, we could avoid \
ParallelComputation because it seems it loses time in sharing the big \
interpolation. \nTODO maybe there is a solution to that."
}], "Text",ExpressionUUID->"5f471730-4105-4182-990a-7418abed7fc0"],

Cell[BoxData[
 RowBox[{"MyTableWeakRate", ":=", 
  RowBox[{"If", "[", 
   RowBox[{"$ParallelWeakRates", 
    RowBox[{"(*", 
     RowBox[{"&&", 
      RowBox[{"Not", "[", "$SpectralDistortions", "]"}]}], "*)"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "Something", " ", "does", " ", "not", " ", "work", " ", "when", " ", 
      "we", " ", "use", " ", 
      RowBox[{"NEVO", ".", " ", "Some"}], " ", "definitions", " ", "seem", 
      " ", "not", " ", "to", " ", "be", " ", "distributed", " ", 
      RowBox[{"correctly", "."}]}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"DistributeDefinitions", "[", 
      RowBox[{
      "\[Lambda]nTOpNormalized", ",", "\[Lambda]pTOnNormalized", ",", 
       "LoadNEVO", ",", "LoadDistortions", ",", 
       RowBox[{"TableNEVOLoaded", "[", "FileNEVOneutrinos", "]"}], ",", 
       RowBox[{"TableNEVOLoaded", "[", "FileNEVOantineutrinos", "]"}], ",", 
       "TreatNEVOFile"}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"ParallelEvaluate", "[", 
      RowBox[{
       RowBox[{"Off", "[", 
        StyleBox[
         RowBox[{"NIntegrate", "::", "slwcon"}], "MessageName"], "]"}], ";"}],
       "]"}], ";", "\[IndentingNewLine]", "ParallelTable"}], ",", 
    "\[IndentingNewLine]", "Table"}], "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.936368043010901*^9, 3.936368173262063*^9}, {
   3.936370345813437*^9, 3.936370352174919*^9}, {3.9363704938590117`*^9, 
