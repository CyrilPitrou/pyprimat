Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"V1dotV2Def", ",", "V1dotV2"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"V1dotV2Def", ":=", 
   RowBox[{"Compile", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"V1", ",", "_Real", ",", "1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"V2", ",", "_Real", ",", "1"}], "}"}]}], "}"}], ",", 
     RowBox[{"V1", ".", "V2"}], ",", 
     RowBox[{"CompilationTarget", "\[Rule]", "\"\<C\>\""}], ",", 
     RowBox[{"\"\<RuntimeOptions\>\"", "\[Rule]", "\"\<Speed\>\""}]}], 
    RowBox[{"(*", 
     RowBox[{",", 
      RowBox[{"Parallelization", "->", "True"}]}], "*)"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"V1dotV2", ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"LoadCompiledFunction", "[", 
      RowBox[{
       RowBox[{"Hold", "[", "V1dotV2", "]"}], ",", 
       RowBox[{"Hold", "[", "V1dotV2Def", "]"}]}], "]"}], ";", "V1dotV2"}], 
    ")"}]}], ";"}]}], "Input",
