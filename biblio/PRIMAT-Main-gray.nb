Cell[BoxData[
 RowBox[{"Lfun", ":=", 
  RowBox[{"Lfun", "=", 
   RowBox[{"Function", "[", 
    RowBox[{
     RowBox[{"{", "x", "}"}], ",", 
     RowBox[{"Evaluate", "[", 
      RowBox[{"Integrate", "[", 
       RowBox[{
        FractionBox[
         RowBox[{"Log", "[", 
          RowBox[{"1", "-", "t"}], "]"}], "t"], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "0", ",", "x"}], "}"}], ",", 
        RowBox[{"Assumptions", "\[Rule]", 
         RowBox[{
          RowBox[{"x", "<", "1"}], "&&", 
          RowBox[{"x", ">", "0"}]}]}]}], "]"}], "]"}]}], "]"}], 
   RowBox[{"(*", " ", 
    RowBox[{
    "Lfun", " ", "is", " ", "called", " ", "the", " ", "Spence", " ", 
     "function"}], " ", "*)"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.695019761668738*^9, 3.6950197955077753`*^9}, {
