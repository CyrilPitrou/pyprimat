Cell[TextData[{
 "We check that the rate for neutron decay is what we expect at low \
temperature, that is it is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Tau]neutron", "  ", 
    RowBox[{"only", "."}]}], TraditionalForm]],ExpressionUUID->
  "5d0c442f-989a-4e87-9980-f5a685b12925"],
