Cell["Precomputation and storage of rates", "Section",
 InitializationCell->True,
 CellChangeTimes->{{3.69656927451437*^9, 3.696569299466792*^9}, {
  3.6984157233273363`*^9, 3.698415727735632*^9}, {3.700388024839624*^9, 
