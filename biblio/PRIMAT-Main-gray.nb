Cell[CellGroupData[{

Cell["Neutrino spectral distortions", "Subsection",
 CellChangeTimes->{{3.935124065856188*^9, 
  3.935124076497405*^9}},ExpressionUUID->"2f526163-2b70-4e5f-8396-\
5d5d212aeda3"],

Cell[TextData[{
 "What is stored by NEVO was the deviation with respect to a pure Fermi-Dirac \
distribution and the neutrino temperature. \n",
 StyleBox["warning",
  FontWeight->"Bold"],
 " : it is slightly inconsistent to put a chemical potential in neutrinos \
here, since when using NEVO, decoupling is computed without. \nSimilarly it \
was computed without extra relativistic degrees of freedom. In the following, \
remember that the energy of neutrinos is in units of the electron mass."
}], "Text",
 CellChangeTimes->{
  3.935124059333976*^9, {3.937275161116621*^9, 
   3.93727520342924*^9}},ExpressionUUID->"4fb04ab6-660e-4905-b75e-\
5e61a1e48d7c"],

Cell["\<\
The shape chosen for the Y - type distortion contains 4 times more energy \
density than the Fermi-Dirac (it is obvious using integrations by parts and \
valid even if the FD has a chemical potential).\
\>", "Text",
 CellChangeTimes->{{3.9351253906621323`*^9, 3.9351254698110447`*^9}, {
   3.935569675595909*^9, 3.935569682613228*^9}, 
   3.937275215158228*^9},ExpressionUUID->"9952e714-e22d-4468-b05e-\
c25d1134c22c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"MuDistortionNeutrinos", "[", 
    RowBox[{"y_", ",", "\[Xi]_", ",", "d\[Xi]_"}], "]"}], "=", 
   RowBox[{"(", 
    RowBox[{
     FractionBox["1", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"y", "-", 
         RowBox[{"(", 
          RowBox[{"\[Xi]", "+", "d\[Xi]"}], ")"}]}], "]"}], "+", "1"}]], "-", 
     
     FractionBox["1", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"y", "-", "\[Xi]"}], "]"}], "+", "1"}]]}], ")"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"MuDistortionAntineutrinos", "[", 
    RowBox[{"y_", ",", "\[Xi]_", ",", "d\[Xi]_"}], "]"}], "=", 
   RowBox[{"(", 
    RowBox[{
     FractionBox["1", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"y", "+", 
         RowBox[{"(", 
          RowBox[{"\[Xi]", "+", "d\[Xi]"}], ")"}]}], "]"}], "+", "1"}]], "-", 
     
     FractionBox["1", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"y", "+", "\[Xi]"}], "]"}], "+", "1"}]]}], ")"}]}], 
  ";"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.936526949828093*^9, 3.9365270906377277`*^9}, {
  3.936527313488006*^9, 3.9365273759761553`*^9}, {3.9365274523222446`*^9, 
  3.936527494530571*^9}},
 CellLabel->
  "In[1925]:=",ExpressionUUID->"c7b7f671-f948-4b93-ad1c-445aeeea2bb5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       SuperscriptBox["y", "3"], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"MuDistortionNeutrinos", "[", 
          RowBox[{"y", ",", "\[Xi]", ",", "d\[Xi]"}], "]"}], "+", 
         RowBox[{"MuDistortionAntineutrinos", "[", 
          RowBox[{"y", ",", "\[Xi]", ",", "d\[Xi]"}], "]"}]}], ")"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "0", ",", "Infinity"}], "}"}], ",", 
      RowBox[{"Assumptions", "->", 
       RowBox[{"Element", "[", 
        RowBox[{"\[Phi]", ",", "Reals"}], "]"}]}]}], "]"}], 
    "\[IndentingNewLine]", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"%", ",", 
      RowBox[{"Assumptions", "->", 
       RowBox[{
        RowBox[{"Element", "[", 
         RowBox[{"\[Xi]", ",", "Reals"}], "]"}], "&&", 
        RowBox[{"Element", "[", 
         RowBox[{"d\[Xi]", ",", "Reals"}], "]"}]}]}]}], "]"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Inty3MuDistortion", "[", 
     RowBox[{"\[Xi]_", ",", "d\[Xi]_"}], "]"}], "=", 
    RowBox[{
     FractionBox["1", "4"], " ", "d\[Xi]", " ", 
     RowBox[{"(", 
      RowBox[{"d\[Xi]", "+", 
       RowBox[{"2", " ", "\[Xi]"}]}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["d\[Xi]", "2"], "+", 
       RowBox[{"2", " ", "d\[Xi]", " ", "\[Xi]"}], "+", 
       RowBox[{"2", " ", 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["\[Pi]", "2"], "+", 
          SuperscriptBox["\[Xi]", "2"]}], ")"}]}]}], ")"}]}]}], 
   ";"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.936526949828093*^9, 3.9365270906377277`*^9}, {
