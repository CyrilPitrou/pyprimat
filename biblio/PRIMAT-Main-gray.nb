Cell[BoxData[{
 RowBox[{
  RowBox[{"TFreeze", "=", 
   RowBox[{"0.8", " ", 
    RowBox[{"MeV", "/", "kB"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"tFreeze", "=", 
  RowBox[{"tofa", "@", 
   RowBox[{"a", "@", "TFreeze"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"YnF", "[", "tv_", "]"}], ":=", 
   RowBox[{
    RowBox[{"1", "/", 
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"Q", "/", "kB"}], "/", "TFreeze"}], "]"}]}], ")"}]}], 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"(", 
        RowBox[{"tv", "-", "tFreeze"}], ")"}]}], "/", "\[Tau]neutron"}], " ", 
     "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"YpF", "[", "tv_", "]"}], ":=", 
   RowBox[{"1", "-", 
