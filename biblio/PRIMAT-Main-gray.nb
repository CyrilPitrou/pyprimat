Cell["\<\
For a line (the list of elements of this line more precisely) describing a \
reaction we build the rates and inverse rates, and we output a formal \
description of the reaction in terms of initial and final particles\
\>", "Text",
 CellChangeTimes->{{3.699358792959258*^9, 3.699358845199709*^9}, {
  3.715942623890226*^9, 
  3.715942624092636*^9}},ExpressionUUID->"0d02c845-827d-4ba5-ae46-\
0653569605c6"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TreatData", "[", "Data_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "reac", ",", "constants", ",", "ireaction", ",", "MaxNumberReaction", 
       ",", "ReferencePaper", ",", "dat", ",", "rest", ",", "list", ",", 
       "resultat", ",", "reacreshaped", ",", "replacements", ",", "time"}], 
      "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"resultat", "=", 
       RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"list", "=", "Data"}], ";", "\[IndentingNewLine]", 
      RowBox[{"ireaction", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"MaxNumberReaction", ":=", 
       RowBox[{"If", "[", 
        RowBox[{
        "$ReducedNetwork", ",", "SmallNuclearNetworkSize", ",", "Infinity"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Length", "@", "list"}], ">", "0"}], ")"}], "&&", 
         RowBox[{"ireaction", "<=", "MaxNumberReaction"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"reac", "=", 
          RowBox[{"list", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"ReferencePaper", "=", 
          RowBox[{"StringDrop", "[", 
           RowBox[{
            RowBox[{"list", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "1"}], "]"}], "]"}], ",", "2"}], "]"}]}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"Print", "[", "ReferencePaper", "]"}], ";"}], "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"Print", "[", "reac", "]"}], ";"}], "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{"constants", "=", 
          RowBox[{"list", "[", 
           RowBox[{"[", "3", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"rest", "=", 
          RowBox[{"Drop", "[", 
           RowBox[{"list", ",", "3"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"dat", "=", 
          RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"While", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"rest", "=!=", 
             RowBox[{"{", "}"}]}], "&&", 
            RowBox[{"NumericQ", "[", 
             RowBox[{"rest", "[", 
              RowBox[{"[", 
               RowBox[{"1", ",", "1"}], "]"}], "]"}], "]"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"dat", "=", 
             RowBox[{"Append", "[", 
              RowBox[{"dat", ",", 
               RowBox[{"rest", "[", 
                RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"rest", "=", 
             RowBox[{"Rest", "@", "rest"}]}], ";"}]}], "\[IndentingNewLine]", 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"list", "=", "rest"}], ";", "\[IndentingNewLine]", 
         RowBox[{"reacreshaped", "=", 
          RowBox[{"Append", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"ReplaceMultipleElementList", "@", 
               RowBox[{"Select", "[", 
                RowBox[{"reac", ",", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"#", "=!=", "\"\<+\>\""}], "&&", 
                    RowBox[{"#", "=!=", "\"\<*-\>\""}]}], ")"}], "&"}]}], 
                "]"}]}], ",", "constants", ",", "ReferencePaper"}], "}"}], 
            ",", "dat"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"resultat", "=", 
          RowBox[{"Append", "[", 
           RowBox[{"resultat", ",", 
            RowBox[{"reacreshaped", "/.", "ListSimplificationNotation"}]}], 
           "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"ireaction", "++"}], ";"}]}], "\[IndentingNewLine]", "]"}], 
      ";", "\[IndentingNewLine]", "resultat"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.936270367724369*^9, 3.936270373649138*^9}, {
  3.936270441531145*^9, 3.93627046556065*^9}, {3.936839178582471*^9, 
  3.936839226638989*^9}, {3.9368392592167263`*^9, 3.936839298478362*^9}, {
  3.93683935118077*^9, 3.936839360857121*^9}, {3.9368393967920856`*^9, 
  3.936839422393735*^9}, {3.936839463348681*^9, 3.936839465348835*^9}, {
  3.936839547609706*^9, 3.9368396238399982`*^9}},
 CellLabel->
  "In[2420]:=",ExpressionUUID->"ac7715de-6ed6-48a4-bb54-1e552a072f5e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TruncateRateVariation", "[", "rate_", "]"}], ":=", 
  RowBox[{"Min", "[", 
   RowBox[{"$MaxVariationRate", ",", "rate"}], "]"}]}]], "Input",
