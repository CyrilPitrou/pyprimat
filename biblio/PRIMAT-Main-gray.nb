Cell["\<\
If $CompileNDSolve is set to True (advised), then the differential equation \
solver uses compiled functions. This is slightly faster. \
\>", "Text",ExpressionUUID->"a5e71a2c-60ab-4434-b4f4-204dffe2387e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"$StoreCompilation", "=", "True"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "Stores", " ", "compilation", " ", "in", " ", "lib", " ", "folder", " ", 
    "if", " ", 
    RowBox[{"True", ".", " ", "Otherwise"}], " ", "it", " ", "is", " ", 
    "compiled", " ", "everytime", " ", "the", " ", "Kernel", " ", "is", " ", 
    "loaded", " ", 
    RowBox[{"(", 
     RowBox[{"a", " ", "few", " ", "seconds", " ", "lost"}], ")"}]}], " ", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$Recompile", "=", "False"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "If", " ", "this", " ", "true", " ", "it", " ", "forces", " ", "the", " ",
      "compilation", " ", "of", " ", "previously", " ", "compiled", " ", 
     "and", " ", "stored", " ", 
     RowBox[{"functions", ".", " ", "May"}], " ", "be", " ", "necessary", " ",
      "if", " ", "you", " ", "change", " ", "something", " ", 
     RowBox[{"subtle", ".", " ", "Or"}], " ", "you", " ", "erase", " ", "all",
      " ", "files", " ", "in", " ", "the", " ", "lib", " ", "folder", " ", 
     "and", " ", "this", " ", "will", " ", "force", " ", "the", " ", 
     "Recompilation", " ", "as", " ", "well"}], ".."}], "*)"}]}]}], "Input",
