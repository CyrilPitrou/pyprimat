Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"TreatReactionLine", "[", "line_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "rescalefactor", ",", "reac", ",", "constants", ",", "interpfunction", 
        ",", "data", ",", "len", ",", "table", ",", "Tmin", ",", "rmin", ",", 
        "wedgeposition", ",", "colonposition", ",", "InitialParticles", ",", 
        "FinalParticles", ",", "BoolenFileData", ",", "Q", ",", "FrontFactor",
         ",", "PoweronT9", ",", "Qoverkb", ",", "Name", ",", "Lname", ",", 
        "rv", ",", "ReferencePaper", ",", "InfoFromAudi2017", ",", 
        "timeref"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"timeref", "=", 
         RowBox[{"AbsoluteTime", "[", "]"}]}], ";"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"reac", "=", 
        RowBox[{"line", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{"\"\<Treating reaction : \>\"", ",", "reac"}], "]"}], ";"}],
         "*)"}], "\[IndentingNewLine]", 
       RowBox[{"constants", "=", 
        RowBox[{"line", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"ReferencePaper", "=", 
        RowBox[{"line", "[", 
         RowBox[{"[", "3", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"data", "=", 
        RowBox[{"line", "[", 
         RowBox[{"[", "4", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"len", "=", 
        RowBox[{"Length", "@", "line"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"wedgeposition", "=", 
        RowBox[{
         RowBox[{"Position", "[", 
          RowBox[{"reac", ",", "\"\<>\>\""}], "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"colonposition", "=", 
        RowBox[{
         RowBox[{"Position", "[", 
          RowBox[{"reac", ",", "\"\<;\>\""}], "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"InitialParticles", "=", 
        RowBox[{"Take", "[", 
         RowBox[{"reac", ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", 
            RowBox[{"wedgeposition", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"FinalParticles", "=", 
        RowBox[{"Take", "[", 
         RowBox[{"reac", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"wedgeposition", "+", "1"}], ",", 
            RowBox[{"colonposition", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
         "We", " ", "quit", " ", "if", " ", "the", " ", "reaction", " ", 
          "does", " ", "not", " ", "conserve", " ", "formally", " ", "Z", " ",
           "or", " ", "N"}], ",", " ", 
         RowBox[{
         "that", " ", "is", " ", "if", " ", "it", " ", "cannot", " ", 
          "exist"}]}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"CheckReaction", "[", 
        RowBox[{"InitialParticles", ",", "FinalParticles"}], "]"}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"Name", "=", 
        RowBox[{
         RowBox[{"StringJoin", "@@", 
          RowBox[{"ToString", "/@", "InitialParticles"}]}], "<>", 
         "\"\<TO\>\"", "<>", 
         RowBox[{"StringJoin", "@@", 
          RowBox[{"ToString", "/@", "FinalParticles"}]}]}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"Q", "=", 
        RowBox[{"constants", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"FrontFactor", "=", 
        RowBox[{"constants", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"PoweronT9", "=", 
        RowBox[{"constants", "[", 
         RowBox[{"[", "3", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Qoverkb", "=", 
        RowBox[{"constants", "[", 
         RowBox[{"[", "4", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "We", " ", "check", " ", "the", " ", "constants", " ", "used", " ", 
         "in", " ", "reverse", " ", "rates"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"InfoFromAudi2017", "=", 
        RowBox[{"InfoReaction", "[", 
         RowBox[{"InitialParticles", ",", "FinalParticles"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{
          "InitialParticles", ",", "\"\< \>\"", ",", "FinalParticles", ",", 
           "\"\< \>\"", ",", "InfoFromAudi2017"}], "]"}], ";"}], "*)"}], 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Abs", "[", 
           RowBox[{
            RowBox[{"FrontFactor", "/", 
             RowBox[{"InfoFromAudi2017", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], "-", "1"}], "]"}], ">", 
          "0.001"}], ",", 
         RowBox[{"Print", "[", 
          RowBox[{
          "Name", ",", "\"\< WARNING. We use \[Alpha]=\>\"", ",", 
           "FrontFactor", ",", "\"\< but we should use \>\"", ",", 
           RowBox[{"InfoFromAudi2017", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", 
        "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Abs", "[", 
           RowBox[{
            RowBox[{"Qoverkb", "/", 
             RowBox[{"InfoFromAudi2017", "[", 
              RowBox[{"[", "4", "]"}], "]"}]}], "-", "1"}], "]"}], ">", 
          "0.001"}], ",", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
          "Name", ",", " ", 
           "\"\< WARNING. We use Q/\!\(\*SubscriptBox[\(k\), \(B\)]\)=\>\"", 
           ",", "Qoverkb", ",", "\"\< but we should use \>\"", ",", 
           RowBox[{"InfoFromAudi2017", "[", 
            RowBox[{"[", "4", "]"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", 
        "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"PoweronT9", "=!=", 
          RowBox[{"InfoFromAudi2017", "[", 
           RowBox[{"[", "3", "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
          "Name", ",", " ", "\"\< WARNING. We use power on T9 =\>\"", ",", 
           "PoweronT9", ",", "\"\< but we should use \>\"", ",", 
           RowBox[{"InfoFromAudi2017", "[", 
            RowBox[{"[", "3", "]"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{"**", "**", "**", "**", "**"}], "******)"}], 
       "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{"**", "*"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "For", " ", "exploration", " ", "of", " ", "parameters", " ", "we", 
         " ", "can", " ", "redefine", " ", "some", " ", "front", " ", 
         "factors", " ", "to", " ", "rescale", " ", 
         RowBox[{"reactions", ".", " ", "For"}], " ", "instance", " ", "the", 
         " ", "DPG", " ", "reaction"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Added", " ", "on", " ", "request", " ", "of", " ", "Antony", " ", 
         "Lewis"}], " ", "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"rescalefactor", "=", "1"}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{"Name", ",", 
           RowBox[{"FullForm", "[", "Name", "]"}]}], "]"}], ";"}], "*)"}], 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{"$RescaleSomeRates", ",", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"NumericQ", "[", 
            RowBox[{"Symbol", "[", 
             RowBox[{"Name", "<>", "\"\<Factor\>\""}], "]"}], "]"}], ",", " ",
            "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"rescalefactor", "=", 
             RowBox[{"Symbol", "[", 
              RowBox[{"Name", "<>", "\"\<Factor\>\""}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             RowBox[{
             "Name", ",", "\"\<  reaction is rescaled by \>\"", ",", 
              "rescalefactor"}], "]"}], ";"}]}], "\[IndentingNewLine]", 
          "]"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"table", "=", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Giga", " ", 
              RowBox[{"#", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}], ",", 
             RowBox[{
              RowBox[{"#", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "Hz"}], ",", 
             RowBox[{"#", "[", 
              RowBox[{"[", "3", "]"}], "]"}]}], "}"}], "&"}], ",", "data"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Tmin", "=", 
        RowBox[{
         RowBox[{"Last", "[", "table", "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"rmin", "=", 
        RowBox[{
         RowBox[{"Last", "[", "table", "]"}], "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Lname", "=", 
        RowBox[{"ToExpression", "[", 
         RowBox[{"\"\<Hold@L\>\"", "<>", "Name"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rv", "=", "NormalRealisation"}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "We", " ", "also", " ", "rescale", " ", "some", " ", "nuclear", " ", 
         "according", " ", "to", " ", "QED", " ", "corrections", " ", 
         RowBox[{"(", 
          RowBox[{
          "pair", " ", "productions", " ", "in", " ", "the", " ", "final", 
           " ", "state", " ", "if", " ", "it", " ", "produces", " ", "a", " ",
            "\[Gamma]"}], " "}]}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{"This", " ", "is", " ", "based", " ", 
         RowBox[{"on", " ", "[", 
          RowBox[{
           RowBox[{"Pitrou", "&"}], "Posepelov", " ", "2020"}], "]"}]}], " ", 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"RescaleFunction", "[", "T9_", "]"}], ":=", "1"}], ";", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
         "Possible", " ", "RescaleFunction", " ", "for", " ", "some", " ", 
          "selected", " ", "rates"}], ",", " ", 
         RowBox[{"in", " ", "function", " ", "of", " ", "T9"}]}], "*)"}], 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"This", " ", "is", " ", "the", " ", "np"}], "\[Rule]", 
          RowBox[{
          "dg", " ", "correction", " ", "from", " ", "pair", " ", "particle", 
           " ", "production"}]}], ",", " ", 
         RowBox[{"found", " ", "from", " ", "our", " ", 
          RowBox[{"electric", "/", "dipole"}], " ", "modelization", " ", "of",
           " ", "base", " ", "rate"}], ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"etc", "..."}], " ", "using", " ", "Landau"}], "-", 
          RowBox[{"Lifshitz", ".", "\[IndentingNewLine]", 
           RowBox[{"See", " ", "[", 
            RowBox[{
             RowBox[{"Pitrou", "&"}], "Pospelov", " ", "2020"}], "]"}]}]}]}], 
        "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
        "$NuclearRatesQEDCorrections", ",", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"Name", "===", "\"\<npTOdg\>\""}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"RescaleFunction", "[", "T9_", "]"}], ":=", 
              "\[IndentingNewLine]", 
              RowBox[{"Min", "[", 
               RowBox[{
                TagBox[
                 StyleBox["1.0009003934476768`",
                  ShowSpecialCharacters->False,
                  ShowStringCharacters->True,
