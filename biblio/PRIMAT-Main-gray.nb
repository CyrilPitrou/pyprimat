Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"IPENdpFrom\[Chi]CCR", "[", 
    RowBox[{
    "en_", ",", "pe_", ",", "x_", ",", "znu_", ",", "sgnq_", ",", 
     "\[Chi]function_"}], "]"}], ":=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"q", "=", 
        RowBox[{"Q", "/", "me"}]}], " ", ",", 
       RowBox[{"b", "=", 
        RowBox[{"pe", "/", "en"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      SuperscriptBox["pe", "2"], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Chi]function", "[", 
          RowBox[{"en", ",", "pe", ",", "x", ",", "znu", ",", "sgnq"}], "]"}], 
         RowBox[{"(", 
          RowBox[{"RadiativeCorrections", "[", 
           RowBox[{"b", ",", 
            RowBox[{"Abs", "[", 
             RowBox[{
              RowBox[{"sgnq", " ", 
               RowBox[{"Q", "/", "me"}]}], "-", "en"}], "]"}], ",", "en"}], 
           "]"}], ")"}], 
         RowBox[{"Fermi", "[", 
          RowBox[{"sgnq", ",", "1", ",", "b"}], "]"}]}], "+", 
        RowBox[{
         RowBox[{"\[Chi]function", "[", 
          RowBox[{
           RowBox[{"-", "en"}], ",", "pe", ",", "x", ",", "znu", ",", 
           "sgnq"}], "]"}], 
         RowBox[{"(", 
          RowBox[{"RadiativeCorrections", "[", 
           RowBox[{"b", ",", " ", 
            RowBox[{"Abs", "[", 
             RowBox[{
              RowBox[{"sgnq", " ", 
               RowBox[{"Q", "/", "me"}]}], "+", "en"}], "]"}], ",", "en"}], 
           "]"}], ")"}], 
         RowBox[{"Fermi", "[", 
          RowBox[{"sgnq", ",", 
           RowBox[{"-", "1"}], ",", "b"}], "]"}]}]}], ")"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 InitializationCell->True,
