 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"LoadCompiledFunction", "[", 
     RowBox[{
      RowBox[{"Hold", "[", "fname_", "]"}], ",", 
      RowBox[{"Hold", "[", "functiondef_", "]"}], ",", "fnamestring_String"}],
      "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"funcLoc", ",", "ShouldCompile"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{"$StoreCompilation", ",", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"fnamestring", "=", 
            RowBox[{"ToString", "[", 
             RowBox[{"HoldForm", "[", "fname", "]"}], "]"}]}], ";"}], "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"Print", "[", 
            RowBox[{"\"\<fnamestring is \>\"", ",", "fnamestring"}], "]"}], 
           ";"}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"mxname", "=", " ", 
           RowBox[{
           "$libDirectory", "<>", "fnamestring", "<>", "\"\<.mx\>\""}]}], ";",
           "\[IndentingNewLine]", "\[IndentingNewLine]", 
          RowBox[{"ShouldCompile", "=", "False"}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"Not", "[", 
             RowBox[{"FileExistsQ", "[", "mxname", "]"}], "]"}], ",", 
            RowBox[{
             RowBox[{"ShouldCompile", "=", "True"}], ";"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"Get", "[", "mxname", "]"}], ";", "\[IndentingNewLine]", 
             
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"Not", "[", 
                RowBox[{"FileExistsQ", "[", "newfuncLoc", "]"}], "]"}], ",", 
               "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"ShouldCompile", "=", "True"}], ";"}], ",", 
               "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"If", "[", 
                 RowBox[{"$Recompile", ",", "\[IndentingNewLine]", 
                  RowBox[{
                   RowBox[{"Print", "[", 
                    RowBox[{
                    "\"\<I will erase the associate library : \>\"", ",", 
                    "newfuncLoc"}], "]"}], ";", "\[IndentingNewLine]", 
                   RowBox[{"DeleteFile", "[", "newfuncLoc", "]"}], ";", 
                   "\[IndentingNewLine]", 
                   RowBox[{"ShouldCompile", "=", "True"}]}]}], 
                 "\[IndentingNewLine]", "]"}], ";"}]}], "\[IndentingNewLine]",
               "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
          "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"ShouldCompile", "||", "$Recompile"}], ",", 
            "\[IndentingNewLine]", "\[IndentingNewLine]", 
            RowBox[{"(*", 
             RowBox[{
              RowBox[{"Print", "[", "cpf", "]"}], ";"}], "*)"}], 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"fname", "=", "functiondef"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"funcLoc", "=", 
              RowBox[{"fname", "[", 
               RowBox[{"[", 
                RowBox[{
                 RowBox[{"-", "1"}], ",", "1"}], "]"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{
               RowBox[{"newfuncLoc", "=", 
                RowBox[{"UniqueLibraryname", "[", "funcLoc", "]"}]}], ";"}], 
              "*)"}], "\[IndentingNewLine]", 
             RowBox[{"newfuncLoc", "=", 
              RowBox[{"UniqueLibraryname", "[", 
               RowBox[{"funcLoc", ",", "fnamestring"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"Print", "[", 
              RowBox[{
              "\"\<I store the following compiled function : \>\"", ",", 
               "fnamestring", ",", "\"\< in \>\"", ",", "mxname", ",", 
               "\"\< with library \>\"", ",", "newfuncLoc"}], "]"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"CopyFile", "[", 
              RowBox[{"funcLoc", ",", "newfuncLoc", ",", 
               RowBox[{"OverwriteTarget", "->", "False"}]}], "]"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"DumpSave", "[", 
              RowBox[{"mxname", ",", 
               RowBox[{"{", 
                RowBox[{"fname", ",", "newfuncLoc"}], "}"}]}], "]"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"fname", "=", 
              RowBox[{"ReplacePart", "[", 
               RowBox[{"fname", ",", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"-", "1"}], ",", "1"}], "}"}], "->", 
                 "newfuncLoc"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
            RowBox[{"(*", 
             RowBox[{
              RowBox[{"Print", "[", 
               RowBox[{"fname", "/.", " ", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"CompiledFunction", "->", "List"}], ",", 
                  RowBox[{"LibraryFunction", "->", "List"}]}], "}"}]}], "]"}],
               ";"}], "*)"}], ",", "\[IndentingNewLine]", 
            RowBox[{"(*", 
             RowBox[{
             "If", " ", "exists", " ", "already", " ", "we", " ", "load", " ",
               "it", " ", "and", " ", "fo", " ", "the", " ", "appropriate", 
              " ", "replacement", " ", "of", " ", "library", " ", 
              RowBox[{"paths", "."}]}], "*)"}], "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"Get", "[", "mxname", "]"}], ";", "\[IndentingNewLine]", 
             
             RowBox[{"If", "[", 
              RowBox[{"$Verbose", ",", 
               RowBox[{
                RowBox[{"Print", "[", 
                 RowBox[{
                 "\"\<I load compiled function from \>\"", ",", "mxname", 
                  ",", "\"\< and the library linked is \>\"", ",", 
                  "newfuncLoc"}], "]"}], ";"}]}], "]"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"fname", "=", 
              RowBox[{"ReplacePart", "[", 
               RowBox[{"fname", ",", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"-", "1"}], ",", "1"}], "}"}], "->", 
                 "newfuncLoc"}]}], "]"}]}], ";"}]}], "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"Print", "[", 
              RowBox[{"fname", "/.", " ", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"CompiledFunction", "->", "List"}], ",", 
                 RowBox[{"LibraryFunction", "->", "List"}]}], "}"}]}], "]"}], 
             ";"}], "*)"}], "\[IndentingNewLine]", "]"}], ";"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"fname", "=", "functiondef"}], ";"}]}], "]"}], ";"}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
