Cell[TextData[{
 "An option to use the ",
 StyleBox["PArthENoPE",
  FontFamily->"Source Code Pro",
  FontWeight->"Regular"],
 " rates [",
 ButtonBox["arXiv:2103.05027",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/abs/2103.05027"], None},
  ButtonNote->"https://arxiv.org/abs/2103.05027"],
 "] for ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["d", "TI"], "+", 
         StyleBox["d", "TI"], "\[LeftRightArrow]", 
         StyleBox["t", "TI"], "+", 
         StyleBox["p", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "d+d \\leftrightarrow t + p", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d60252dd-699b-4d3c-98ce-868fd45b38aa"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["d", "TI"], "+", 
         StyleBox["d", "TI"], "\[LeftRightArrow]", 
         StyleBox["n", "TI"], "+", 
         SuperscriptBox["\[Null]", "3"], "He"}], TraditionalForm], 
     "errors" -> {}, "input" -> "d+d \\leftrightarrow n + {}^3 {\\rm He}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b4d17675-ae0a-4328-a100-df339f6cef81"],
 ". If it is True, then the codes uses ",
 StyleBox["TabulatedReactionsFileParthenope",
  FontFamily->"Source Code Pro",
  FontSize->13,
  FontWeight->"SemiBold"],
 " or ",
 StyleBox["TabulatedReactionsFileSmallNetworkParthenope",
  FontFamily->"Source Code Pro",
  FontSize->13,
  FontWeight->"SemiBold"],
 " if the small network option (see below) is True."
}], "Text",
 CellChangeTimes->{{3.936844755709506*^9, 3.9368448359649076`*^9}, {
   3.94821324762365*^9, 3.9482134067245197`*^9}, {3.948213445016485*^9, 
