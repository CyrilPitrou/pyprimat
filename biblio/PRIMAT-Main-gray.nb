   3.72268962410982*^9, 3.72268962504112*^9}, 3.722689747917446*^9, 
   3.722689955433695*^9, 3.936371586719963*^9, {3.936391048258658*^9, 
   3.936391139298078*^9}, {3.936391592368939*^9, 
   3.9363916076597023`*^9}},ExpressionUUID->"3909f3b7-520c-4dbd-b4a1-\
d93814d63201"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"NamesMassNumber", "[", "A_", "]"}], ":=", 
  RowBox[{
   RowBox[{"Select", "[", 
    RowBox[{"NamesWithWeights", ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Plus", "@@", 
          RowBox[{"(", 
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}], ")"}]}], ")"}], "\[Equal]", "A"}],
        ")"}], "&"}]}], "]"}], "[", 
   RowBox[{"[", 
    RowBox[{"All", ",", "1"}], "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"NamesAtomicNumber", "[", "Z_", "]"}], ":=", 
  RowBox[{
   RowBox[{"Select", "[", 
    RowBox[{"NamesWithWeights", ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", 
          RowBox[{"2", ",", "2"}], "]"}], "]"}], "\[Equal]", "Z"}], ")"}], 
      "&"}]}], "]"}], "[", 
   RowBox[{"[", 
    RowBox[{"All", ",", "1"}], "]"}], "]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.699359803314328*^9, 3.699359858955772*^9}, 
   3.699362234476458*^9, {3.699365446381321*^9, 3.69936545121282*^9}, 
   3.699768579141118*^9, {3.6998686504075727`*^9, 3.699868667158586*^9}, 
   3.699889279728875*^9, 3.70089249749959*^9, {3.71377068767056*^9, 
   3.713770701671472*^9}, 3.722599037163265*^9, 3.722688904646348*^9, {
   3.72268962410982*^9, 3.72268962504112*^9}, 3.722689747917446*^9, 
   3.722689955433695*^9, 3.936371586719963*^9, {3.936391048258658*^9, 
   3.936391139298078*^9}, 3.936391592368939*^9},
 CellLabel->
  "In[2452]:=",ExpressionUUID->"1f9d062b-66b7-42fa-8c48-a400c6db5a83"],

Cell["\<\
We use two ways of noting the abundance of a species. One notation is Ynipj \
where i is the number of neutrons and j the number of protons. For instance \
Yn2p2 is He4. 

But we also want to use short names. For instance He4 for Helium4. So we want \
to relate automatically YHe4 to Yn2p2.\
\>", "Text",
 CellChangeTimes->{{3.715949627799944*^9, 3.715949696576696*^9}, {
  3.722699295531753*^9, 
  3.722699302237155*^9}},ExpressionUUID->"5017c69e-124a-4372-b5dc-\
76c522572cd4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"StackY", "[", "name_", "]"}], ":=", 
   RowBox[{"\"\<Y\>\"", "<>", 
    RowBox[{"ToString", "[", "name", "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"YName", "[", "PostString_", "]"}], "[", 
    RowBox[{"n_", ",", "p_"}], "]"}], ":=", 
   RowBox[{"ToExpression", "@", 
    RowBox[{"StackY", "[", 
     RowBox[{"\"\<n\>\"", "<>", 
      RowBox[{"ToString", "[", "n", "]"}], "<>", "\"\<p\>\"", "<>", 
      RowBox[{"ToString", "[", "p", "]"}], "<>", "PostString"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ShortString", "[", 
    RowBox[{"nameshort_", ",", "np_List"}], "]"}], ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"Evaluate", "@", 
       RowBox[{"ToExpression", "[", 
        RowBox[{"\"\<Y\>\"", "<>", "nameshort"}], "]"}]}], ":=", 
      RowBox[{
       RowBox[{"YName", "[", "\"\<\>\"", "]"}], "@@", "np"}]}], ";"}], 
    ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"Yn", "=!=", "Yn1p0"}], ",", 
     RowBox[{
      RowBox[{"ShortString", "@@@", "NamesWithWeightsAll"}], ";"}]}], "]"}], 
   ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "The", " ", "condition", " ", "is", " ", "to", " ", "avoid", " ", 
    "infinite", " ", "recursion", " ", "when", " ", "loading", " ", "PRIMAT", 
    " ", "several", " ", 
    RowBox[{"times", "."}]}], "*)"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.6993348279020348`*^9, 3.699334874692212*^9}, {
   3.699334960316167*^9, 3.699334972789893*^9}, 3.699335121073937*^9, {
