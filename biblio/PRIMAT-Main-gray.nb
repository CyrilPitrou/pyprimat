        RowBox[{"b", "=", 
         RowBox[{"pe", "/", "en"}]}], "}"}], ",", 
       RowBox[{
        SuperscriptBox["pe", "2"], "*", "\[IndentingNewLine]", 
        RowBox[{"(", 
         RowBox[{"\[Chi]FMNeutronDecay", "[", 
          RowBox[{"en", ",", "pe"}], "]"}], ")"}]}]}], "\[IndentingNewLine]", 
      "]"}]}], "]"}]}], ";"}]], "Input",
