Cell[BoxData[
 RowBox[{
  RowBox[{"MyCompile", "[", 
   RowBox[{"LV_List", ",", "Body_"}], "]"}], ":=", 
  RowBox[{"Compile", "[", 
   RowBox[{"LV", ",", 
    RowBox[{"Evaluate", "[", "Body", "]"}], ",", 
    RowBox[{"\"\<RuntimeOptions\>\"", "\[Rule]", "\"\<Speed\>\""}], ",", 
    RowBox[{"CompilationTarget", "\[Rule]", "\"\<C\>\""}], ",", 
