  3.93557528765665*^9, 3.935575288331416*^9}, {3.935575683172379*^9, 
  3.935575683585578*^9}, {3.935576208077668*^9, 3.9355762085976458`*^9}, {
  3.935576608356686*^9, 3.935576608746809*^9}, {3.935577295579443*^9, 
  3.9355772964077377`*^9}, {3.9355837377999268`*^9, 3.935583738156097*^9}, {
  3.935651423450037*^9, 3.935651423982836*^9}, {3.935980393672571*^9, 
