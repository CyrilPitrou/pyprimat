     RowBox[{"{", 
      RowBox[{"\"\<InlineExternalDefinitions\>\"", "\[Rule]", "True"}], 
      "}"}]}], ",", 
    RowBox[{"RuntimeAttributes", "\[Rule]", 
     RowBox[{"{", "Listable", "}"}]}], ",", 
