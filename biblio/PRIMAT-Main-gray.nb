Cell[BoxData[
 RowBox[{
  RowBox[{"CheckOptions", ":=", 
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Not", "@", "$QEDPlasmaCorrections"}], " ", "&&", " ", 
        "$CompleteQEDPressure"}], ",", " ", 
       RowBox[{
        RowBox[{
        "Print", "[", 
         "\"\<Inconsistent Options, I set $CompleteQEDPressure=False\>\"", 
         "]"}], ";", 
        RowBox[{"$CompleteQEDPressure", "=", "False"}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Not", "@", "$QEDPlasmaCorrections"}], " ", "&&", " ", 
        "$QEDOe3"}], ",", 
       RowBox[{
        RowBox[{
        "Print", "[", "\"\<Inconsistent Options, I set $QEDOe3=False\>\"", 
         "]"}], ";", 
        RowBox[{"$QEDOe3", "=", "False"}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Not", "@", "$NEVO"}], "&&", "$TrueT\[Nu]e"}], ",", 
       RowBox[{
        RowBox[{
        "Print", "[", 
         "\"\<Inconsistent Options, I set $TrueT\[Nu]e=False\>\"", "]"}], ";", 
        RowBox[{"$TrueT\[Nu]e", "=", "False"}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Not", "@", "$NEVO"}], "&&", 
        RowBox[{"Not", "[", "$AnalyticDistortions", "]"}], "&&", 
        "$SpectralDistortions"}], ",", 
       RowBox[{
        RowBox[{
        "Print", "[", 
         "\"\<Inconsistent Options, I set $SpectralDistortions=False\>\"", 
         "]"}], ";", 
        RowBox[{"$SpectralDistortions", "=", "False"}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"$NEVO", "&&", 
        RowBox[{"Not", "[", "$IncompleteNeutrinoDecoupling", "]"}]}], ",", 
       RowBox[{
        RowBox[{
        "Print", "[", "\"\<Inconsistent Options, I set $NEVO=False\>\"", 
         "]"}], ";", 
        RowBox[{"$NEVO", "=", "False"}], ";"}]}], "]"}]}], 
    "\[IndentingNewLine]", ")"}]}], ";"}]], "Input",
 InitializationCell->True,
