 RowBox[{
  RowBox[{
  "If", " ", "NEVO", " ", "results", " ", "are", " ", "not", " ", "used", " ",
    "for", " ", "neutrino", " ", "decoupling"}], ",", " ", 
  RowBox[{
  "then", " ", "we", " ", "cannot", " ", "have", " ", "the", " ", "true", " ", 
   SubscriptBox["\[Nu]", "e"], " ", 
   RowBox[{"temperature", ".", " ", "\[IndentingNewLine]", "If"}], " ", "we", 
   " ", "do", " ", "not", " ", "use", " ", "NEVO", " ", "and", " ", "there", 
   " ", "are", " ", "no", " ", "AnalyticDistortions"}], ",", " ", 
  RowBox[{"then", " ", "we", " ", "cannot", " ", "have", " ", "Spectral", " ", 
