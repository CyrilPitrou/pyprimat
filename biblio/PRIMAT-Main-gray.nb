Cell[CellGroupData[{

Cell["Main species of the small network", "Subsection",
 CellChangeTimes->{{3.7003889951818447`*^9, 
  3.700389002279378*^9}},ExpressionUUID->"f4c93c93-9306-468c-b917-\
68e37eb32b64"],

Cell["\<\
The plots assume that we have used the full nuclear network and not the \
reduced one. 
Otherwise some nuclides might not exist and Mathematica should complain ...\
\>", "Text",ExpressionUUID->"637ea8bd-c3d5-44ec-afa4-95fe5d9e2f0f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"BBNsmall", "=", 
  RowBox[{"LogLogPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"YI", "[", "\"\<n\>\"", "]"}], "[", "tv", "]"}], ",", 
      RowBox[{
       RowBox[{"YI", "[", "\"\<p\>\"", "]"}], "[", "tv", "]"}], ",", 
      RowBox[{"2", 
       RowBox[{
        RowBox[{"YI", "[", "\"\<d\>\"", "]"}], "[", "tv", "]"}]}], ",", 
      RowBox[{"3", 
       RowBox[{
        RowBox[{"YI", "[", "\"\<t\>\"", "]"}], "[", "tv", "]"}]}], ",", 
      RowBox[{"3", 
       RowBox[{
        RowBox[{"YI", "[", "\"\<He3\>\"", "]"}], "[", "tv", "]"}]}], ",", 
      RowBox[{"4", 
       RowBox[{
        RowBox[{"YI", "[", "\"\<a\>\"", "]"}], "[", "tv", "]"}]}], ",", 
      RowBox[{
       RowBox[{"YI", "[", "\"\<Li6\>\"", "]"}], "[", "tv", "]"}], ",", 
      RowBox[{
       RowBox[{"YI", "[", "\"\<Li7\>\"", "]"}], "[", "tv", "]"}], ",", 
      RowBox[{"7", 
       RowBox[{
        RowBox[{"YI", "[", "\"\<Be7\>\"", "]"}], "[", "tv", "]"}]}]}], "}"}], 
    ",", 
    RowBox[{"{", 
     RowBox[{"tv", ",", "tmiddle", ",", "tend"}], "}"}], ",", 
    RowBox[{"Frame", "\[Rule]", "True"}], ",", 
    RowBox[{"FrameStyle", "\[Rule]", 
     RowBox[{"Thickness", "[", "0.003", "]"}]}], ",", 
    RowBox[{"FrameLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
      "\"\<t (s)\>\"", ",", 
       "\"\<\!\(\*SubscriptBox[\(A\), \(i\)]\)\!\(\*SubscriptBox[\(Y\), \
\(i\)]\)\>\""}], "}"}]}], ",", 
    RowBox[{"LabelStyle", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"FontSize", "\[Rule]", "12"}], "}"}]}], ",", 
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"10", "^", 
        RowBox[{"-", "40"}]}], ",", "10"}], "}"}]}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"Black", ",", "Red", ",", 
       RowBox[{"{", 
