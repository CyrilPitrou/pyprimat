     RowBox[{"b", ",", "y", ",", "en"}], "]"}], ",", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{
       FractionBox["\[Alpha]FS", 
        RowBox[{"2", "\[Pi]"}]], 
       RowBox[{"Cd", "[", 
