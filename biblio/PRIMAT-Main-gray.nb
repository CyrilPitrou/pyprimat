Cell[CellGroupData[{

Cell["Binding energies and spins of nuclei", "Subsection",
 CellChangeTimes->{{3.717579917532316*^9, 3.71757992719598*^9}, {
  3.7175807015026493`*^9, 
  3.71758070162115*^9}},ExpressionUUID->"6ea66168-0ce6-49d6-9eb0-\
29d11c47d469"],

Cell["Tools to reshape the file \"nubase2016.asc\"", "Text",
 CellChangeTimes->{{3.717579948973797*^9, 3.717579960045233*^9}, {
  3.7226974643214893`*^9, 
  3.722697477619766*^9}},ExpressionUUID->"5c444be5-0af8-4c81-a3f3-\
ab86630ff75f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"SpinFromCharList", "[", "charlist_List", "]"}], ":=", 
  RowBox[{"StringReplace", "[", 
   RowBox[{
    RowBox[{"StringJoin", "@@", "charlist"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<(\>\"", "\[Rule]", "\"\<\>\""}], ",", 
      RowBox[{"\"\<)\>\"", "\[Rule]", "\"\<\>\""}], ",", 
      RowBox[{"\"\<,\>\"", "\[Rule]", "\"\<\>\""}], ",", 
      RowBox[{"\"\<+\>\"", "\[Rule]", "\"\<\>\""}], ",", 
      RowBox[{"\"\<-\>\"", "\[Rule]", "\"\<\>\""}], ",", 
      RowBox[{"\"\< \>\"", "\[Rule]", "\"\<\>\""}], ",", 
      RowBox[{"\"\<#\>\"", "\[Rule]", "\"\<\>\""}], ",", 
      RowBox[{"\"\<*\>\"", "\[Rule]", "\"\<\>\""}]}], "}"}]}], 
   "]"}]}], "\n", 
 RowBox[{
  RowBox[{"MassFromCharList", "[", "charlist_List", "]"}], ":=", 
  RowBox[{"StringReplace", "[", 
   RowBox[{
    RowBox[{"StringJoin", "@@", "charlist"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\< \>\"", "\[Rule]", "\"\<\>\""}], ",", 
      RowBox[{"\"\<#\>\"", "\[Rule]", "\"\<\>\""}]}], "}"}]}], 
   "]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7175736007049932`*^9, 3.7175737943574944`*^9}, {
   3.717573841034152*^9, 3.717573844084982*^9}, {3.71757388244722*^9, 
   3.717573882587225*^9}, {3.717574118883388*^9, 3.7175741224515676`*^9}, 
   3.717579935288033*^9, {3.717580889341352*^9, 3.7175809080931997`*^9}, {
   3.935550316975667*^9, 3.935550320089221*^9}},
 CellLabel->
  "In[2352]:=",ExpressionUUID->"cbac9410-a374-4adf-a36b-370b8b96a27f"],

Cell["\<\
**OLD method : Nubase 2016. New methods with NUbase 2020 below**\
\>", "Text",
 CellChangeTimes->{{3.935550091900545*^9, 
  3.9355501119804153`*^9}},ExpressionUUID->"69c41471-6190-42f7-91d3-\
5dee8a9666cd"],

Cell["\<\
We load the file \"nubtab06.asc\" OLD Method. Now we prefere to load nubase \
2020 from the file nubase_4.mas20.txt, see below.\
\>", "Text",
 CellChangeTimes->{{3.717579961885364*^9, 3.717579966488873*^9}, {
  3.9355486497735567`*^9, 
  3.9355486820893917`*^9}},ExpressionUUID->"a13b2d42-d6cf-4910-aa1e-\
929b47a17555"],

Cell["\<\
NUBASE 2016 Syntax :
  The first three characters of each line are the A . 
   Characters from 5 to 7 are Z (but the 8th character is a number for a \
possibel excited state. Hence we use character 5 to 8 for 10*Z, and then \
divide by 10. If it is an integer it is not an excited state. Otherwise it is \
discarded. This is a dirty hack)
  From 20 to 29 it is mass excess .
  From 80 to 93 it is some information on spin and parity .\
\>", "Text",
 CellChangeTimes->{{3.935548619524701*^9, 3.935548629062249*^9}, {
  3.935548997008459*^9, 3.9355489994808283`*^9}, {3.935549236384733*^9, 
  3.935549239825891*^9}, {3.935549969419003*^9, 
  3.9355500270086937`*^9}},ExpressionUUID->"bf9f05b6-21f4-4b7e-9e4c-\
1e5e6e5754e0"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{"StringListParticles", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"#", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "&"}], "/@", 
     RowBox[{"Import", "[", 
