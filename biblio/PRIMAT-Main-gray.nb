          RowBox[{"DSTNoQEDT", "[", "T", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"T", ",", "ListT"}], "}"}]}], "]"}]}]}], ";"}], 
   "*)"}]}]}], "Input",
