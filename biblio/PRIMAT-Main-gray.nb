Cell["\<\
It is this function \[Delta]FD\[Nu] that we use later to take into account \
the effect of distortions in n-p conversions.\
\>", "Text",
 CellChangeTimes->{{3.80977096534614*^9, 
  3.8097709656210117`*^9}},ExpressionUUID->"48468536-d3f9-49b8-8370-\
d6316c7072e6"]
}, Open  ]]
