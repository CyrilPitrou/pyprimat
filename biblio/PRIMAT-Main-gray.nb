Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"\[Delta]\[Chi]", "[", 
    RowBox[{"en_", ",", "pe_", ",", "x_", ",", "znu_", ",", "sgnq_"}], "]"}], 
   ":=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"q", "=", 
       RowBox[{"Q", "/", "me"}]}], " ", "}"}], ",", 
     RowBox[{
      RowBox[{"dFDneu", "[", 
       RowBox[{
        RowBox[{"en", "-", 
         RowBox[{"sgnq", " ", "q"}]}], ",", 
        RowBox[{"sgnq", " ", "\[Xi]\[Nu]"}], ",", "x", ",", "znu", ",", 
        "sgnq"}], "]"}], 
      RowBox[{"FD", "[", 
       RowBox[{
        RowBox[{"-", "en"}], ",", "x"}], "]"}], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"en", "-", 
         RowBox[{"sgnq", " ", "q"}]}], ")"}], "2"]}]}], "]"}]}], 
  ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{3.9349653120679913`*^9},
 CellLabel->
  "In[2200]:=",ExpressionUUID->"7d1a7b18-031c-44b6-ae0f-77892793459d"],

Cell["\<\
We add this spectral distortions effect at the Born approximation level.\
\>", "Text",
 CellChangeTimes->{{3.782814446023917*^9, 
  3.782814482330453*^9}},ExpressionUUID->"84fc9bd3-1901-4f4a-be54-\
