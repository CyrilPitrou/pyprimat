        RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"N", "=", 
       RowBox[{"Pair", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"A", "=", 
       RowBox[{"Z", "+", "N"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
