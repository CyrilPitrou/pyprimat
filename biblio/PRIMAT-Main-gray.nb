Cell["\<\
We build a table with (a, T) so as to obtain the inverse T(a) via an \
interpolation. 
In the incomplete neutrino case we have already performed such inversion so \
there is a slight loss of time and computer energy.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.693925103060994*^9, 3.693925144048552*^9}, {
  3.6939251742437267`*^9, 3.693925175315997*^9}, {3.693930819690785*^9, 
  3.693930820182519*^9}, {3.715941909091235*^9, 3.7159419604680853`*^9}, {
  3.720270692661057*^9, 3.720270697026326*^9}, {3.720270793161281*^9, 
  3.720270821474946*^9}},ExpressionUUID->"800aded9-154b-4de1-9d6e-\
b5c060050664"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"InvertaOFT", ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Tofa", "=", 
      RowBox[{"Interpolation", "@", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"a", "[", "T", "]"}], ",", "T"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"T", ",", "ListT"}], "}"}]}], "]"}]}]}], ";"}], ")"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"aI", "=", 
     RowBox[{"Interpolation", "@", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"T", ",", 
          RowBox[{"a", "[", "T", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"T", ",", "ListT"}], "}"}]}], "]"}]}]}], ";"}], 
   "*)"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.699812849955882*^9, 3.699812860607586*^9}, {
  3.700446617917966*^9, 3.700446618097731*^9}, {3.700561910733116*^9, 
  3.700561919575713*^9}, {3.720270350345332*^9, 3.720270378683249*^9}, {
  3.720270589814473*^9, 3.720270593778656*^9}},
 CellLabel->
