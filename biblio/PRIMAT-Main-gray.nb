Cell[CellGroupData[{

Cell["Checks of  the conservation of total number of baryons", "Section",
 CellChangeTimes->{{3.698490241251979*^9, 3.698490254801991*^9}, {
  3.700390090871045*^9, 
  3.700390094361822*^9}},ExpressionUUID->"36831475-0a15-4988-a3aa-\
edb041233dfc"],

Cell[TextData[{
 "The total number MUST be conserved. We build it from the nuclear weights of \
species.\nAt high temperatures we check visually. By construction the \
quantity Ytot = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalSigma]", "i"], " ", 
    SubscriptBox["A", "i"], 
    SubscriptBox["Y", "i"], " ", "should", " ", "be", " ", "1", " ", "and", 
    " ", 
    RowBox[{"conserved", ".", " ", "We"}], " ", "define", " ", "it", " ", 
    "and", " ", "plot", " ", "the", " ", "difference", " ", "with", " ", 
    RowBox[{"unity", "."}]}], TraditionalForm]],ExpressionUUID->
  "7809af98-d0d5-460b-809a-3c9398e1e79b"]
}], "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.694793047730411*^9, 3.694793057911633*^9}, {
  3.6947961531986628`*^9, 3.694796163875288*^9}, {3.696572787372614*^9, 
  3.696572795719692*^9}, {3.698436967797186*^9, 3.698436975554577*^9}, {
  3.7159555880658216`*^9, 3.715955633946353*^9}, {3.7161200478373413`*^9, 
  3.716120048699442*^9}},ExpressionUUID->"45c11889-3f82-4b70-b695-\
9b7aec3af4da"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Ytot", "[", "period_String", "]"}], ":=", 
   RowBox[{"Function", "[", 
    RowBox[{
     RowBox[{"{", "tv", "}"}], ",", 
     RowBox[{"Plus", "@@", 
      RowBox[{"(", 
       RowBox[{"WeightsNuclear", "*", 
        RowBox[{
         RowBox[{"YPeriodTime", "[", "period", "]"}], "[", "tv", "]"}]}], 
       ")"}]}]}], "]"}]}], ";"}]], "Input",
