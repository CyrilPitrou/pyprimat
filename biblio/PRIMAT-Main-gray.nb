              RowBox[{"Lx", "\[LessEqual]", 
               RowBox[{"Logxmax", "[", "fn", "]"}]}], ",", 
              RowBox[{
               RowBox[{"dfNuelogxySafey", "[", "fn", "]"}], "[", 
               RowBox[{"Lx", ",", "y"}], "]"}], ",", 
              RowBox[{
               RowBox[{"dfNuelogxySafey", "[", "fn", "]"}], "[", 
