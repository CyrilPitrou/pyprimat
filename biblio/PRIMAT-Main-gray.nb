Cell["\<\
[Lopez&Turner 1997] define some quantity to parameterize how good detailed \
balance is obtained, this is the parameter \[Alpha]. 
\[Alpha] should be 0 so we use it to estimate the failure of detailed balance\
\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.698399777081094*^9, 3.69839987232202*^9}, {
  3.722695012065412*^9, 
  3.722695019713744*^9}},ExpressionUUID->"55e09df8-a879-4c0f-b262-\
ac7892a4ae4b"],

Cell["\<\
We first solve for \[Alpha] correctly, and then we do it when forcing the \
temperature of neutrinos to be the one of photons, in which case detailed \
balance must be true. Indeed if we do not force the temperature of neutrinos \
to be the one of photons, then it is only true before electrons/positrons \
annihilate, and at low temperature detailed balance is not satisfied.\
\>", "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.698399877434156*^9, 
  3.698399948428933*^9}},ExpressionUUID->"227939c3-7e6b-4aa2-bac5-\
d31958036960"],

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"\[Alpha]Lopez", ",", "\[Alpha]LopezCheatNeutrino"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Alpha]Lopez", "[", "T_", "]"}], ":=", 
   RowBox[{
    RowBox[{"\[Alpha]Lopez", "[", "T", "]"}], "=", 
    RowBox[{"\[Alpha]", "/.", 
     RowBox[{
      RowBox[{"Solve", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Normal", "@", 
          RowBox[{"Series", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"\[Lambda]nTOpBORN", "[", "T", "]"}], "+", 
                RowBox[{"\[Lambda]nTOpFMNoCCR", "[", "T", "]"}]}], ")"}], "/", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"\[Lambda]pTOnBORN", "[", "T", "]"}], "+", 
                RowBox[{"\[Lambda]pTOnFMNoCCR", "[", "T", "]"}]}], ")"}]}], 
             "*", 
             RowBox[{"DetailedBalanceRatio", "[", "T", "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"\[Alpha]", ",", "0", ",", "1"}], "}"}]}], "]"}]}], 
         "\[Equal]", "1"}], ",", "\[Alpha]"}], "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}]}]}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Alpha]LopezCheatNeutrino", "[", "T_", "]"}], ":=", 
  RowBox[{
   RowBox[{"\[Alpha]LopezCheatNeutrino", "[", "T", "]"}], "=", 
   RowBox[{"\[Alpha]", "/.", 
    RowBox[{
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Normal", "@", 
         RowBox[{"Series", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"\[Lambda]nTOpBORNCheatNeutrino", "[", "T", "]"}], "+", 
               RowBox[{"\[Lambda]nTOpCheatNeutrinoFM", "[", "T", "]"}]}], 
              ")"}], "/", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"\[Lambda]pTOnBORNCheatNeutrino", "[", "T", "]"}], "+", 
               RowBox[{"\[Lambda]pTOnCheatNeutrinoFM", "[", "T", "]"}]}], 
              ")"}]}], "*", 
            RowBox[{"DetailedBalanceRatio", "[", "T", "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"\[Alpha]", ",", "0", ",", "1"}], "}"}]}], "]"}]}], 
        "\[Equal]", "1"}], ",", "\[Alpha]"}], "]"}], "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}]}]}], "Input",
 CellChangeTimes->{{3.6965655574431963`*^9, 3.696565611377757*^9}, {
   3.6965671619755793`*^9, 3.6965672003454227`*^9}, {3.696582993428934*^9, 
   3.696582993719572*^9}, 3.6965890339892673`*^9, {3.696761354889915*^9, 
   3.696761393252475*^9}, {3.6968408082277527`*^9, 3.6968408803159523`*^9}, 
   3.698399875364376*^9, {3.69841357424718*^9, 3.698413597874288*^9}, {
   3.7162793069870787`*^9, 3.716279313415699*^9}, {3.716280104748596*^9, 
   3.716280119957148*^9}},
 CellLabel->
  "In[2243]:=",ExpressionUUID->"32e4dafe-d648-4f46-bb03-921fa1f69012"],

Cell[TextData[{
 "\nWe plot something similar to Fig. 4 of [Lopez&Turner 1997]. The remaining \
error should come from second order corrections. For instance at low \
temperature it remains an effect of order ",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"Q", "/", "mn"}], " ", ")"}], "2"]}], TraditionalForm]],
  ExpressionUUID->"d8a682fa-ac90-47cb-8397-66b6dac0385d"],
 " so \[Alpha] is expected to differ from a null value by something of order ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "/", "mn", " "}], TraditionalForm]],ExpressionUUID->
  "8c3450d2-9201-433c-8fc4-b008fe421409"],
 "=0.002. We also see that below 5x",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["10", "10"], "K"}], ","}], TraditionalForm]],
  ExpressionUUID->"0c1554c5-cea5-4297-8028-fb3294d9cbaa"],
 " detailed balance does not work because neutrinos no longer have the \
temperature of photons but it works if we force neutrinos to be at the \
temperature of photons."
}], "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.6965679496032867`*^9, 3.696568064507167*^9}, {
   3.696568116270546*^9, 3.696568145526404*^9}, {3.6965682255317783`*^9, 
   3.696568293935913*^9}, {3.698399954664131*^9, 3.698399993755897*^9}, {
   3.698438558686653*^9, 3.698438578607565*^9}, {3.698491030431748*^9, 
