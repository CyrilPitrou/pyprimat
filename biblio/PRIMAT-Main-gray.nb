  RowBox[{"IPENdpFrom\[Chi]NoCCR", "[", 
   RowBox[{
    RowBox[{"Sqrt", "[", 
     RowBox[{
      SuperscriptBox["pe", "2"], "+", "1"}], "]"}], ",", "pe", ",", "x", ",", 
    "x", ",", "sgnq", ",", "\[Chi]"}], "]"}]}]], "Input",
