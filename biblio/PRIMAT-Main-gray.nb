Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"InitialConditionsMT", "[", 
    RowBox[{"Tv_", ",", "tv_"}], "]"}], ":=", 
   RowBox[{"Thread", "[", 
    RowBox[{"Equal", "[", 
     RowBox[{
      RowBox[{"FunList", "[", "tv", "]"}], ",", 
      RowBox[{
       RowBox[{"YPeriodTimeOrStateEquilibrium", "[", 
        RowBox[{"\"\<HT\>\"", ",", "ListThermalValuesUsedMT"}], "]"}], "[", 
       RowBox[{"Tv", ",", "tv"}], "]"}]}], "]"}], "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7001980419322042`*^9, 3.7001980972151957`*^9}, 
   3.700198185007798*^9, {3.700198408215209*^9, 3.700198411927658*^9}, {
