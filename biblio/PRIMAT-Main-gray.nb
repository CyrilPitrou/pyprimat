    ",", 
    RowBox[{"FrameTicks", "\[Rule]", "MyTickst"}], ",", 
    RowBox[{"ImagePadding", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"50", ",", "10"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"40", ",", "25"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"PlotLegends", "\[Rule]", 
     RowBox[{"Placed", "[", 
      RowBox[{
       RowBox[{"LineLegend", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "\"\<n\>\"", ",", "\"\<p\>\"", ",", 
           "\"\<\!\(\*SuperscriptBox[\(\[InvisiblePrefixScriptBase]\), \(2\)]\
\)H\>\"", ",", 
           "\"\<\!\(\*SuperscriptBox[\(\[InvisiblePrefixScriptBase]\), \(3\)]\
\)H\>\"", ",", 
           "\"\<\!\(\*SuperscriptBox[\(\[InvisiblePrefixScriptBase]\), \(3\)]\
\)He\>\"", ",", 
